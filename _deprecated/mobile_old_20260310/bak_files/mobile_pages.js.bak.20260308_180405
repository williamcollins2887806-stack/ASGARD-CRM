/**
 * АСГАРД CRM — Мобильные страницы (Премиум-редизайн)
 * Полная переработка каждой страницы для мобильных устройств.
 *
 * Подход:
 * 1. Универсальный table-to-cards трансформер (для ~40 таблиц)
 * 2. Пост-процессинг каждой страницы после рендеринга
 * 3. Мобильные фильтры (горизонтальные чипы)
 * 4. Мобильные формы (полная ширина, правильные отступы)
 * 5. Мобильные графики (адаптация размеров)
 */
;(function() {
  'use strict';

  var isMobile = function() {
    return document.body.classList.contains('is-mobile') || window.innerWidth <= 768;
  };

  if (!isMobile()) return; // Desktop — не трогаем

  // ═══════════════════════════════════════════════════════════════
  // 1. УНИВЕРСАЛЬНЫЙ TABLE → CARDS ТРАНСФОРМЕР
  // ═══════════════════════════════════════════════════════════════

  /**
   * Превращает <table class="asg"> в мобильные карточки.
   * Автоматически берёт заголовки из <thead> и создаёт data-label для каждой ячейки.
   */
  function transformTableToCards(table) {
    if (!table || table.dataset.mobileTransformed) return;
    table.dataset.mobileTransformed = '1';

    var thead = table.querySelector('thead');
    var tbody = table.querySelector('tbody');
    if (!tbody) return;

    // Собираем заголовки
    var headers = [];
    if (thead) {
      var ths = thead.querySelectorAll('th');
      for (var i = 0; i < ths.length; i++) {
        headers.push(ths[i].textContent.trim());
      }
    }

    // Создаём контейнер карточек
    var container = document.createElement('div');
    container.className = 'm-auto-cards';

    // Скрываем оригинальную таблицу
    table.style.display = 'none';
    table.parentNode.insertBefore(container, table.nextSibling);

    // Наблюдаем за изменениями tbody
    function rebuildCards() {
      var rows = tbody.querySelectorAll('tr');
      if (!rows.length) {
        container.innerHTML = '<div class="m-empty-state">Нет данных</div>';
        return;
      }

      var html = '';
      for (var r = 0; r < rows.length; r++) {
        var tr = rows[r];
        var cells = tr.querySelectorAll('td');
        if (!cells.length) continue;

        var id = tr.dataset.id || '';
        var cardHtml = '<div class="m-auto-card" data-id="' + id + '">';

        // Первая ячейка — заголовок карточки (обычно это имя/название)
        if (cells[0]) {
          cardHtml += '<div class="m-ac-title">' + cells[0].innerHTML + '</div>';
        }

        // Остальные ячейки — поля
        cardHtml += '<div class="m-ac-fields">';
        for (var c = 1; c < cells.length; c++) {
          var content = cells[c].innerHTML.trim();
          if (!content || content === '—' || content === '-') continue;

          // Пропускаем чекбоксы
          if (cells[c].querySelector('input[type="checkbox"]')) continue;

          var label = (c < headers.length && headers[c]) ? headers[c] : '';

          // Если это кнопка, выносим в футер
          if (cells[c].querySelector('button, .btn, a.btn')) {
            cardHtml += '</div>'; // close m-ac-fields
            cardHtml += '<div class="m-ac-actions">' + content + '</div>';
            cardHtml += '<div class="m-ac-fields" style="display:none">'; // dummy open for close
            continue;
          }

          if (label) {
            cardHtml += '<div class="m-ac-field"><span class="m-ac-label">' + label + '</span><span class="m-ac-value">' + content + '</span></div>';
          } else {
            cardHtml += '<div class="m-ac-field"><span class="m-ac-value">' + content + '</span></div>';
          }
        }
        cardHtml += '</div>'; // close m-ac-fields
        cardHtml += '</div>'; // close m-auto-card

        html += cardHtml;
      }

      container.innerHTML = html;

      // Привязываем клик-обработчики
      container.querySelectorAll('.m-auto-card').forEach(function(card) {
        // Проброс кликов на кнопки внутри
        card.querySelectorAll('button[data-act], .btn[data-act]').forEach(function(btn) {
          // Кнопки уже имеют свои обработчики из оригинальной таблицы
        });

        // Клик по карточке = клик по "Открыть" если есть
        card.addEventListener('click', function(e) {
          if (e.target.closest('button, a, input, select')) return;
          var openBtn = card.querySelector('[data-act="open"], .btn');
          if (openBtn) openBtn.click();
        });
      });
    }

    rebuildCards();

    // Наблюдаем за изменениями tbody
    var observer = new MutationObserver(function() {
      rebuildCards();
    });
    observer.observe(tbody, { childList: true, subtree: true });

    return { container: container, observer: observer };
  }


  // ═══════════════════════════════════════════════════════════════
  // 2. МОБИЛЬНЫЙ ФИЛЬТР-БАР (горизонтальный скролл)
  // ═══════════════════════════════════════════════════════════════

  function transformFilters(toolsEl) {
    if (!toolsEl || toolsEl.dataset.mobileTransformed) return;
    toolsEl.dataset.mobileTransformed = '1';

    toolsEl.classList.add('m-filter-bar');

    // Все .field элементы — делаем компактными
    var fields = toolsEl.querySelectorAll('.field');
    fields.forEach(function(field) {
      field.classList.add('m-filter-field');
    });

    // Если фильтров > 3, добавляем "Ещё фильтры" toggle
    if (fields.length > 3) {
      var extraFields = [];
      for (var i = 3; i < fields.length; i++) {
        extraFields.push(fields[i]);
        fields[i].style.display = 'none';
        fields[i].classList.add('m-filter-extra');
      }

      var toggleBtn = document.createElement('button');
      toggleBtn.className = 'btn ghost m-filter-toggle';
      toggleBtn.textContent = 'Ещё фильтры ▼';
      toggleBtn.style.cssText = 'font-size:12px;padding:6px 12px;border-radius:8px;min-height:36px;white-space:nowrap;margin-top:4px;';

      var firstBtn = toolsEl.querySelector('.btn:not(.ghost)') || toolsEl.querySelector('.btn');
      if (firstBtn && firstBtn.parentNode === toolsEl) {
        toolsEl.insertBefore(toggleBtn, firstBtn);
      } else {
        toolsEl.appendChild(toggleBtn);
      }

      var expanded = false;
      toggleBtn.addEventListener('click', function() {
        expanded = !expanded;
        extraFields.forEach(function(f) { f.style.display = expanded ? '' : 'none'; });
        toggleBtn.textContent = expanded ? 'Скрыть фильтры ▲' : 'Ещё фильтры ▼';
      });
    }
  }


  // ═══════════════════════════════════════════════════════════════
  // 3. МОБИЛЬНЫЕ ФОРМЫ
  // ═══════════════════════════════════════════════════════════════

  function transformForms() {
    // Все формы и .tools — одноколоночные
    document.querySelectorAll('.tools, .form-grid, .form-row, [class*="form"]').forEach(function(el) {
      if (el.dataset.mobileTransformed) return;
      el.dataset.mobileTransformed = '1';

      // Принудительно одна колонка для гридов с несколькими колонками
      if (el.style.gridTemplateColumns && el.style.gridTemplateColumns !== '1fr') {
        el.style.gridTemplateColumns = '1fr';
      }
    });

    // Все input/select/textarea — правильный размер для тач
    document.querySelectorAll('input:not([type="checkbox"]):not([type="radio"]):not([type="hidden"]), select, textarea').forEach(function(inp) {
      if (inp.dataset.mobileSized) return;
      inp.dataset.mobileSized = '1';
      var s = inp.style;
      if (!s.minHeight || parseInt(s.minHeight) < 42) s.minHeight = '42px';
      if (!s.fontSize || parseInt(s.fontSize) < 14) s.fontSize = '14px';
      s.borderRadius = s.borderRadius || '10px';
    });
  }


  // ═══════════════════════════════════════════════════════════════
  // 4. МОБИЛЬНЫЙ PANEL УЛУЧШЕНИЯ
  // ═══════════════════════════════════════════════════════════════

  function enhancePanels() {
    document.querySelectorAll('.panel').forEach(function(panel) {
      if (panel.dataset.mobileEnhanced) return;
      panel.dataset.mobileEnhanced = '1';

      // Убираем overflow:auto с обёрток таблиц
      panel.querySelectorAll('[style*="overflow:auto"], [style*="overflow: auto"]').forEach(function(wrap) {
        // Оставляем overflow но добавляем webkit touch scroll
        wrap.style.webkitOverflowScrolling = 'touch';
      });

      // Хелпер-текст — скрываем длинный на мобильных
      panel.querySelectorAll('.help').forEach(function(help) {
        if (help.textContent.length > 100) {
          var full = help.innerHTML;
          var short = help.textContent.substring(0, 80) + '...';
          help.innerHTML = '<span class="m-help-short">' + short + '</span>';
          help.style.cursor = 'pointer';
          help.addEventListener('click', function() {
            if (help.classList.contains('m-help-expanded')) {
              help.innerHTML = '<span class="m-help-short">' + short + '</span>';
              help.classList.remove('m-help-expanded');
            } else {
              help.innerHTML = full;
              help.classList.add('m-help-expanded');
            }
          });
        }
      });
    });
  }


  // ═══════════════════════════════════════════════════════════════
  // 5. МОБИЛЬНЫЙ ГРАФИК-ОБЁРТКА
  // ═══════════════════════════════════════════════════════════════

  function wrapCanvases() {
    document.querySelectorAll('canvas').forEach(function(canvas) {
      if (canvas.dataset.mobileWrapped) return;
      canvas.dataset.mobileWrapped = '1';

      // Убедимся что canvas помещается в экран
      if (!canvas.style.maxWidth) {
        canvas.style.maxWidth = '100%';
      }

      // Обёртка с горизонтальным скроллом для слишком широких
      var parent = canvas.parentElement;
      if (parent && !parent.classList.contains('m-chart-wrap')) {
        if (canvas.width > window.innerWidth - 40) {
          parent.style.overflowX = 'auto';
          parent.style.webkitOverflowScrolling = 'touch';
          parent.classList.add('m-chart-wrap');
        }
      }
    });
  }


