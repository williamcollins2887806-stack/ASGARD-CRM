  // ═══════════════════════════════════════════════════════════════
  // 8. MAIN POST-PROCESSOR (вызывается после каждого рендера страницы)
  // ═══════════════════════════════════════════════════════════════

  function processPage() {
    if (!isMobile()) return;

    var hash = location.hash.split('?')[0].replace('#', '');

    // 1. Универсальные трансформации
    // Все таблицы без специального обработчика → auto-cards
    document.querySelectorAll('table.asg, table.t').forEach(function(t) {
      if (t.dataset.mobileTransformed) return;
      // Проверяем, не обработана ли уже через кастомный рендерер (тендеры, работы)
      if (t.style.display === 'none') return;
      transformTableToCards(t);
    });

    // 2. Фильтры
    document.querySelectorAll('.tools').forEach(function(t) {
      transformFilters(t);
    });

    // 3. Формы
    transformForms();

    // 4. Панели
    enhancePanels();

    // 5. Графики
    wrapCanvases();

    // 6. Inline grids reset
    document.querySelectorAll('[style*="grid-template-columns"]').forEach(function(el) {
      // Не трогаем навигацию, таббар, заголовок
      if (el.closest('.m-tabbar, .m-header, .nav-tabs, .tab-nav, .btn-group-grid, .m-auto-cards')) return;
      if (el.classList.contains('m-tabbar') || el.classList.contains('m-header')) return;
      if (el.classList.contains('dash-grid') || el.classList.contains('fin-summary')) return;
      if (el.classList.contains('m-work-cards') || el.classList.contains('m-tender-cards') || el.classList.contains('m-auto-cards')) return;

      var cols = el.style.gridTemplateColumns;
      // Если 2 колонки и это KPI-like — оставляем
      if (cols === '1fr 1fr' || cols === 'repeat(2, 1fr)') {
        // Check if it's KPI-style (small cards)
        var children = el.children;
        if (children.length <= 6 && el.querySelector('[style*="text-align:center"]')) return;
      }
      // Если >2 колонки — сбрасываем в 1
      if (cols && cols !== '1fr' && !cols.includes('auto-fit')) {
        el.style.gridTemplateColumns = '1fr';
      }
    });

    // 7. Страница-специфичные трансформации
    if (pageTransformers[hash]) {
      try { pageTransformers[hash](); } catch(e) { console.warn('[MobilePages] Transform error:', e); }
    }
  }


  // ═══════════════════════════════════════════════════════════════
  // 9. HOOKS — Запуск пост-процессора
  // ═══════════════════════════════════════════════════════════════

  // Hook 1: При каждом hashchange
  window.addEventListener('hashchange', function() {
    setTimeout(processPage, 150);
    setTimeout(processPage, 600);
    setTimeout(processPage, 1500);
  });

  // Hook 2: MutationObserver на #mainContent
  function initObserver() {
    var content = document.getElementById('mainContent') || document.querySelector('.m-content');
    if (!content) {
      setTimeout(initObserver, 500);
      return;
    }

    var debounce;
    var observer = new MutationObserver(function() {
      clearTimeout(debounce);
      debounce = setTimeout(processPage, 100);
    });

    observer.observe(content, { childList: true, subtree: false });
  }

  // Hook 3: Intercept original onPageRendered
  var origOnPageRendered = (window.AsgardMobile && AsgardMobile.onPageRendered) ? AsgardMobile.onPageRendered : null;
  if (window.AsgardMobile) {
    var _origOPR = AsgardMobile.onPageRendered;
    AsgardMobile.onPageRendered = function(route) {
      if (_origOPR) _origOPR(route);
      setTimeout(processPage, 80);
    };
  }

  // Startup
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initObserver();
      setTimeout(processPage, 300);
    });
  } else {
    initObserver();
    setTimeout(processPage, 300);
  }

  // Export
  window.AsgardMobilePages = {
    processPage: processPage,
    transformTableToCards: transformTableToCards,
    transformFilters: transformFilters
  };

  console.log('[MobilePages] v2.0 loaded — ' + Object.keys(pageTransformers).length + ' page transformers ready');
