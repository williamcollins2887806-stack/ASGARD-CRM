     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardChat', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;
    var messages = [];
    try { messages = await AsgardDB.all('chat_messages') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    messages.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    /* Group by chat */
    var chats = {};
    messages.forEach(function(m) {
      var key = m.chat_type === 'direct' ? 'dm_' + [m.user_id, m.to_user_id].sort().join('_') :
                m.entity_id ? m.chat_type + '_' + m.entity_id : 'general';
      if (!chats[key]) chats[key] = { key: key, title: m.entity_title || m.chat_type || 'Общий', lastMsg: m, messages: [], unread: 0 };
      chats[key].messages.push(m);
      if (!m.is_read && m.user_id !== user.id) chats[key].unread++;
    });
    var chatList = Object.values(chats);
    chatList.sort(function(a, b) { return String(b.lastMsg.created_at || '').localeCompare(String(a.lastMsg.created_at || '')); });

    var body = M.mTablePage({
      stats: [
        { label: 'Чатов', value: chatList.length, icon: '💬', color: 'var(--info)' },
        { label: 'Сообщений', value: messages.length, icon: '📝', color: 'var(--gold)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: chatList,
      renderCard: function(chat) {
        var last = chat.lastMsg;
        var preview = (last.text || '').substring(0, 60);
        return M.mCard({
          title: esc(chat.title || 'Чат'),
          subtitle: esc(last.user_name || '') + ': ' + esc(preview),
          badge: chat.unread > 0 ? chat.unread + '' : '', badgeColor: 'gold',
          fields: [
            { label: 'Последнее', value: fmtDateShort(last.created_at) },
            { label: 'Сообщений', value: chat.messages.length }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Чат' });
  });


