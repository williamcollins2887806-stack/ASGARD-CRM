/**
 * ASGARD CRM — Mobile Native Renders v3.0
 * Патчит ВСЕ методы (render, renderList, renderCard, renderSettings и др.)
 * ВСЕХ page-модулей, добавляя мобильную ветку.
 *
 * Загружается ПОСЛЕ всех page-модулей, ПЕРЕД app.js.
 * Не трогает существующий код — только оборачивает.
 */
;(function() {
  'use strict';

  var M = window.AsgardMobileUI;
  if (!M) { console.warn('[MobileRenders] AsgardMobileUI not loaded'); return; }

  /* ═══════════════════════════════════════════════════════════════
     УТИЛИТЫ
     ═══════════════════════════════════════════════════════════════ */
  var esc = M.esc;
  var _patchCount = 0;

  function money(n) {
    if (n == null || n === '') return '—';
    return Number(n).toLocaleString('ru-RU') + ' ₽';
  }

  function fmtDate(d) {
    if (!d) return '—';
    try { return new Date(d).toLocaleDateString('ru-RU'); } catch(e) { return String(d); }
  }

  function fmtDateShort(d) {
    if (!d) return '—';
    try { return new Date(d).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' }); } catch(e) { return String(d); }
  }

  function norm(s) { return String(s || '').toLowerCase().trim(); }

  var fmtMoney = money; /* alias */

  function showError(msg) {
    if (window.AsgardUI && AsgardUI.toast) {
      AsgardUI.toast('Ошибка', msg || 'Не удалось загрузить данные', 'err');
    }
  }

  function authCheck() {
    return AsgardAuth.requireUser().then(function(auth) {
      if (!auth) { location.hash = '#/login'; return null; }
      return auth;
    });
  }

  /* Универсальный патчер: оборачивает ЛЮБОЙ метод модуля.
     Автоматически определяет DOM-element аргумент (модули типа CashPage, TasksAdminPage)
     и оборачивает его в {layout, title} для единообразия мобильных рендеров.
     Показывает shimmer-скелетон во время загрузки данных (Sber-level UX). */
  function patchMethod(moduleName, methodName, mobileFn) {
    var mod = window[moduleName];
    if (!mod || typeof mod[methodName] !== 'function') return;
    var orig = mod[methodName];
    mod[methodName] = async function(opts) {
      if (M.isMobile()) {
        try {
          // Если аргумент — DOM-элемент (роутер уже вызвал layout(), передаёт контейнер)
          if (opts instanceof HTMLElement) {
            opts.setAttribute('data-mobile-native', '1');
            // Показываем скелетон пока данные грузятся
            opts.innerHTML = M.mSkeleton('stats', 3) + M.mSkeleton('card', 4);
            var wrappedOpts = {
              layout: async function(html) { opts.innerHTML = html; },
              title: '',
              container: opts
            };
            return await mobileFn(wrappedOpts);
          }

          // Для {layout, title} паттерна — скелетон с задержкой 120мс
          // Если данные загрузятся быстрее — скелетон не покажется (нет мерцания)
          // Если данные грузятся дольше — появится shimmer (как в Сбере/Яндексе)
          if (opts && typeof opts.layout === 'function') {
            var origLayout = opts.layout;
            var skeletonHtml = '<div class="m-page" data-mobile-native="1">' +
              M.mSkeleton('stats', 3) + M.mSkeleton('card', 4) + '</div>';
            var skeletonTimer = setTimeout(function() {
              try { origLayout(skeletonHtml, { title: opts.title || '' }); } catch(x) {}
            }, 120);
            var wrappedLayout = async function(html, layoutOpts) {
              clearTimeout(skeletonTimer);
              return origLayout(html, layoutOpts);
            };
            opts = Object.assign({}, opts, { layout: wrappedLayout });
          }

          return await mobileFn(opts);
        } catch(e) {
          console.error('[MobileRenders] Error in ' + moduleName + '.' + methodName + ':', e);
          return orig.call(mod, opts);
        }
      }
      return orig.call(mod, opts);
    };
    _patchCount++;
  }

  /* Совместимый патчер .render() */
  function patchModule(moduleName, renderMobileFn) {
    patchMethod(moduleName, 'render', renderMobileFn);
  }


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PERSONNEL  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardPersonnelPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var list = await AsgardDB.all('employees');
    var rows = (list || []).slice();
    rows.sort(function(a, b) {
      return (b.rating_avg || 0) - (a.rating_avg || 0) || String(a.fio || '').localeCompare(String(b.fio || ''), 'ru');
    });

    // Stats
    var total = rows.length;
    var available = rows.filter(function(e) { return (e.availability_status || '').toLowerCase() === 'свободен'; }).length;
    var avgRating = 0;
    var ratedCount = 0;
    rows.forEach(function(e) {
      if (e.rating_avg != null && e.rating_avg !== '') { avgRating += Number(e.rating_avg); ratedCount++; }
    });
    avgRating = ratedCount > 0 ? (avgRating / ratedCount).toFixed(1) : '—';

    var body = M.mTablePage({
      stats: [
        { label: 'Всего', value: total, icon: '👥', color: 'var(--info)' },
        { label: 'Свободны', value: available, icon: '✅', color: 'var(--ok-t)' },
        { label: 'Ср. рейтинг', value: avgRating, icon: '⭐', color: 'var(--gold)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск: ФИО, роль, город...' },
        actions: [
          { id: 'btnSchedule', label: 'График', icon: '📅', cls: 'ghost' },
          { id: 'btnAdd', label: 'Добавить', icon: '+', cls: 'primary' }
        ]
      },
      items: rows,
      renderCard: function(e) {
        return M.mCard({
          id: e.id,
          title: esc(e.fio || ''),
          subtitle: esc(e.role_tag || ''),
          badge: e.availability_status || '',
          badgeColor: (e.availability_status || '').toLowerCase() === 'свободен' ? 'ok' : 'warn',
          fields: [
            { label: 'Город', value: esc(e.city || '—') },
            { label: 'Телефон', value: esc(e.phone || '—') },
            { label: 'Рейтинг', value: e.rating_avg != null && e.rating_avg !== '' ? Number(e.rating_avg).toFixed(1) + ' ⭐' : '—' },
            { label: 'Разряд', value: esc(e.grade || '—') }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет сотрудников'
    });

    await layout(body, { title: title || 'Дружина' });

    // Search handler
    var searchEl = document.getElementById('mSearch');
    if (searchEl) {
      searchEl.addEventListener('input', function() {
        var q = norm(searchEl.value);
        var cards = document.querySelectorAll('.m-card');
        var listEl = document.getElementById('mobileList');
        var visibleCount = 0;
        cards.forEach(function(card) {
          var id = card.dataset.id;
          var emp = rows.find(function(e) { return String(e.id) === id; });
          if (!emp) return;
          var haystack = norm((emp.fio || '') + ' ' + (emp.role_tag || '') + ' ' + (emp.city || ''));
          var show = !q || haystack.indexOf(q) !== -1;
          card.style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });
      });
    }

    // Card click -> open employee
    var listEl = document.getElementById('mobileList');
    if (listEl) {
      listEl.addEventListener('click', function(e) {
        var card = e.target.closest('.m-card');
        if (card && card.dataset.id) {
          location.hash = '#/employee?id=' + card.dataset.id;
        }
      });
    }

    // Schedule button
    var btnSch = document.getElementById('btnSchedule');
    if (btnSch) btnSch.addEventListener('click', function() { location.hash = '#/workers-schedule'; });

    // Add button
    var btnAdd = document.getElementById('btnAdd');
    if (btnAdd) {
      btnAdd.addEventListener('click', function() {
        M.showSheet('Новый сотрудник', M.mForm([
          { type: 'text', id: 'e_fio', label: 'ФИО', placeholder: 'Фамилия Имя Отчество', required: true },
          { type: 'text', id: 'e_role', label: 'Роль', placeholder: 'Слесарь / Мастер...' },
          { type: 'text', id: 'e_city', label: 'Город', placeholder: 'Москва' },
          { type: 'tel', id: 'e_phone', label: 'Телефон', placeholder: '+7...' },
          { type: 'text', id: 'e_grade', label: 'Разряд', placeholder: '3..6' }
        ], {
          buttons: [
            { id: 'btnSave', label: 'Сохранить', cls: 'primary' }
          ]
        }));
        setTimeout(function() {
          var btnSave = document.getElementById('btnSave');
          if (btnSave) {
            btnSave.addEventListener('click', async function() {
              var fio = (document.getElementById('e_fio').value || '').trim();
              if (!fio) { AsgardUI.toast('Ошибка', 'ФИО обязательно', 'err'); return; }
              await AsgardDB.add('employees', {
                fio: fio,
                role_tag: (document.getElementById('e_role').value || '').trim(),
                city: (document.getElementById('e_city').value || '').trim(),
                phone: (document.getElementById('e_phone').value || '').trim(),
                grade: (document.getElementById('e_grade').value || '').trim(),
                availability_status: 'Свободен',
                rating_avg: null,
                created_at: new Date().toISOString()
              });
              M.hideSheet();
              AsgardUI.toast('Готово', 'Сотрудник добавлен');
              location.hash = '#/personnel';
            });
          }
        }, 100);
      });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  INVOICES  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardInvoicesPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    // Load data via API
    var invoices = [], works = [], customers = [];
    try {
      var headers = { 'Authorization': 'Bearer ' + auth.token };
      var results = await Promise.all([
        fetch('/api/invoices', { headers }).then(function(r) { return r.json(); }),
        fetch('/api/works', { headers }).then(function(r) { return r.json(); }),
        fetch('/api/customers', { headers }).then(function(r) { return r.json(); })
      ]);
      invoices = (results[0].invoices || results[0] || []);
      works = (results[1].works || results[1] || []);
      customers = (results[2].customers || results[2] || []);
    } catch(e) {
      console.error('Load error:', e);
      showError('Не удалось загрузить счета');
    }

    // If data comes from IndexedDB instead
    if (!invoices.length) {
      try { invoices = await AsgardDB.all('invoices') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    }

    var STATUSES = {
      'pending': { label: 'Ожидает', color: 'warn' },
      'partial': { label: 'Частично', color: 'info' },
      'paid':    { label: 'Оплачен', color: 'ok' },
      'cancelled': { label: 'Отменён', color: 'err' }
    };

    // Stats
    var totalAmount = 0, paidAmount = 0, pendingCount = 0;
    invoices.forEach(function(inv) {
      totalAmount += Number(inv.amount || 0);
      paidAmount += Number(inv.paid_amount || 0);
      if (inv.status === 'pending') pendingCount++;
    });

    var body = M.mTablePage({
      stats: [
        { label: 'Всего', value: invoices.length, icon: '📄', color: 'var(--info)' },
        { label: 'Сумма', value: money(totalAmount), icon: '💰', color: 'var(--gold)' },
        { label: 'Оплачено', value: money(paidAmount), icon: '✅', color: 'var(--ok-t)' },
        { label: 'Ожидает', value: pendingCount, icon: '⏳', color: 'var(--warn)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск счёта...' },
        filters: [{
          id: 'mFilterStatus',
          options: [
            { value: '', text: 'Все статусы' },
            { value: 'pending', text: 'Ожидает' },
            { value: 'partial', text: 'Частично' },
            { value: 'paid', text: 'Оплачен' }
          ]
        }],
        actions: [
          { id: 'btnAddInvoice', label: 'Новый счёт', icon: '+', cls: 'primary' }
        ]
      },
      items: invoices,
      renderCard: function(inv) {
        var st = STATUSES[inv.status] || { label: inv.status || '—', color: 'draft' };
        var custName = inv.customer_name || '';
        if (!custName && inv.customer_id) {
          var cust = customers.find(function(c) { return c.id === inv.customer_id; });
          if (cust) custName = cust.name || cust.short_name || '';
        }
        return M.mCard({
          id: inv.id,
          title: '№ ' + esc(inv.number || inv.id),
          subtitle: esc(custName),
          badge: st.label,
          badgeColor: st.color,
          fields: [
            { label: 'Дата', value: fmtDate(inv.date || inv.created_at) },
            { label: 'Сумма', value: money(inv.amount), mono: true },
            { label: 'Оплачено', value: money(inv.paid_amount), mono: true },
            { label: 'Остаток', value: money((inv.amount || 0) - (inv.paid_amount || 0)), mono: true }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет счетов'
    });

    await layout(body, { title: title || 'Счета и оплаты' });

    // Search
    var searchEl = document.getElementById('mSearch');
    var filterEl = document.getElementById('mFilterStatus');
    function applyFilters() {
      var q = norm(searchEl ? searchEl.value : '');
      var status = filterEl ? filterEl.value : '';
      document.querySelectorAll('.m-card').forEach(function(card) {
        var id = card.dataset.id;
        var inv = invoices.find(function(i) { return String(i.id) === id; });
        if (!inv) return;
        var haystack = norm((inv.number || '') + ' ' + (inv.customer_name || '') + ' ' + (inv.amount || ''));
        var matchQ = !q || haystack.indexOf(q) !== -1;
        var matchStatus = !status || inv.status === status;
        card.style.display = (matchQ && matchStatus) ? '' : 'none';
      });
    }
    if (searchEl) searchEl.addEventListener('input', applyFilters);
    if (filterEl) filterEl.addEventListener('change', applyFilters);
  });


