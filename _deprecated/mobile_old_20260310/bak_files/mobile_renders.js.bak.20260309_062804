  /* CALENDAR — мобильный Agenda View (события по дням) */
  patchModule('AsgardCalendarPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var events = [];
    try { events = await AsgardDB.all('calendar_events') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var userMap = {};
    users.forEach(function(u) { userMap[u.id] = u; });

    // Сортируем по дате/времени
    events.sort(function(a, b) {
      var da = a.date || a.created_at || '';
      var db = b.date || b.created_at || '';
      return String(da).localeCompare(String(db)) || String(a.time || '').localeCompare(String(b.time || ''));
    });

    // Группируем по дню
    var today = new Date(); today.setHours(0,0,0,0);
    var upcoming = events.filter(function(e) {
      try { return new Date(e.date) >= today; } catch(x) { return true; }
    });
    if (upcoming.length === 0) upcoming = events.slice(-20).reverse();

    var grouped = {};
    upcoming.forEach(function(ev) {
      var day = ev.date ? ev.date.substring(0, 10) : 'Без даты';
      if (!grouped[day]) grouped[day] = [];
      grouped[day].push(ev);
    });

    var TYPE_ICONS = { meeting: '🤝', call: '📞', visit: '🏢', deadline: '⏰', reminder: '🔔', other: '📌' };
    var TYPE_COLORS = { meeting: 'info', call: 'ok', visit: 'gold', deadline: 'err', reminder: 'warn', other: 'draft' };

    var sectionsHtml = '';
    Object.keys(grouped).forEach(function(day) {
      var dayLabel = day;
      try {
        var d = new Date(day);
        var todayStr = today.toISOString().substring(0,10);
        var tomorrowStr = new Date(today.getTime() + 86400000).toISOString().substring(0,10);
        if (day === todayStr) dayLabel = 'Сегодня';
        else if (day === tomorrowStr) dayLabel = 'Завтра';
        else dayLabel = d.toLocaleDateString('ru-RU', { weekday: 'short', day: 'numeric', month: 'long' });
      } catch(x) {}

      var cardsHtml = grouped[day].map(function(ev) {
        var icon = TYPE_ICONS[ev.type] || '📌';
        var pNames = '';
        if (Array.isArray(ev.participants)) {
          pNames = ev.participants.map(function(pid) { return (userMap[pid] || {}).name || pid; }).join(', ');
        }
        return M.mCard({
          id: ev.id,
          title: icon + ' ' + esc(ev.title || 'Событие'),
          subtitle: ev.time ? ev.time.substring(0, 5) : '',
          badge: ev.type || '', badgeColor: TYPE_COLORS[ev.type] || 'draft',
          fields: [
            { label: 'Описание', value: esc((ev.description || '').substring(0, 80)), full: ev.description },
            pNames ? { label: 'Участники', value: esc(pNames) } : null
          ].filter(Boolean),
          onClick: true
        });
      }).join('');
      sectionsHtml += M.mSection(dayLabel, cardsHtml);
    });

    if (!sectionsHtml) sectionsHtml = M.mEmpty('Нет предстоящих событий', '📅');

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mStats([
        { label: 'Всего', value: events.length, icon: '📅', color: 'var(--info)' },
        { label: 'Сегодня', value: (grouped[today.toISOString().substring(0,10)] || []).length, icon: '📌', color: 'var(--gold)' }
      ]) +
      M.mToolbar({ search: { id: 'mSearch', placeholder: 'Поиск событий...' } }) +
      sectionsHtml +
    '</div>';
    await layout(body, { title: title || 'Календарь' });
  });


