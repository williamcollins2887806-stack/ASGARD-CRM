      M.mForm([
        { label: 'Дни подготовки', id: 'cPrepDays', type: 'number', value: '2', placeholder: '2' },
        { label: 'Дни работы', id: 'cWorkDays', type: 'number', placeholder: '10' },
        { label: 'Дни демобилизации', id: 'cDemobDays', type: 'number', value: '1', placeholder: '1' }
      ]) + '</div>';

    var totalsTab = '<div class="m-calc-tab m-hidden" id="calc-tab-totals">' +
      '<div class="m-card">' +
        '<div class="m-card-title m-title-md">Результаты расчёта</div>' +
        '<div class="m-card-fields" id="calcResults">' +
          '<div class="m-field"><span class="m-field-label">Заполните все вкладки</span></div>' +
        '</div>' +
        '<div class="m-card-actions m-flex-stretch">' +
          '<button class="m-action-btn m-btn-primary" id="btnCalcCompute">Рассчитать</button>' +
        '</div>' +
      '</div></div>';

    container.innerHTML = '<div class="m-page" data-mobile-native="1">' +
      tabsHtml + objectTab + paramsTab + crewTab + timeTab + totalsTab + '</div>';

    // Tab switching
    container.querySelectorAll('.m-tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        container.querySelectorAll('.m-tab-btn').forEach(function(b) { b.classList.remove('m-tab-active'); });
        btn.classList.add('m-tab-active');
        TABS.forEach(function(t) {
          var el = document.getElementById('calc-tab-' + t.id);
          if (el) el.classList.toggle('m-hidden', t.id !== btn.dataset.calcTab);
        });
      });
    });

    // Расчёт
    document.getElementById('btnCalcCompute')?.addEventListener('click', function() {
      var crewSize = Number(document.getElementById('cCrewSize')?.value || 4);
      var foreman = Number(document.getElementById('cForeman')?.value || 1);
      var rate = Number(document.getElementById('cRate')?.value || 3000);
      var foremanRate = Number(document.getElementById('cForemanRate')?.value || 4500);
      var prepDays = Number(document.getElementById('cPrepDays')?.value || 2);
      var workDays = Number(document.getElementById('cWorkDays')?.value || 10);
      var demobDays = Number(document.getElementById('cDemobDays')?.value || 1);
      var margin = Number(document.getElementById('cMargin')?.value || 20);

      var totalDays = prepDays + workDays + demobDays;
      var laborCost = (crewSize * rate + foreman * foremanRate) * totalDays;
      var total = laborCost * (1 + margin / 100);

      document.getElementById('calcResults').innerHTML =
        '<div class="m-field"><span class="m-field-label">Всего дней</span><span class="m-field-value">' + totalDays + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">ФОТ</span><span class="m-field-value m-mono">' + money(laborCost) + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Наценка ' + margin + '%</span><span class="m-field-value m-mono">' + money(total - laborCost) + '</span></div>' +
        '<div class="m-field m-calc-total"><span class="m-field-label">ИТОГО</span><span class="m-field-value">' + money(total) + '</span></div>';
    });
  });


  console.info('[MobileRenders] v8.0.0 — ' + _patchCount + ' methods patched across all modules');
})();
