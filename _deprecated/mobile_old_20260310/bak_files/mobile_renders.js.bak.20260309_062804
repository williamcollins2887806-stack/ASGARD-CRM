  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CHAT GROUPS / MESSENGER  ██████
     Роутер: /messenger → AsgardChatGroups.render({layout})
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardChatGroups', async function(opts) {
    var layoutFn = opts && opts.layout;
    if (!layoutFn) return;
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;
    var token = localStorage.getItem('asgard_token');

    // v8.0.0 — Telegram-level chat
    var chats = [];
    try {
      var resp = await fetch('/api/chat-groups', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); chats = d.chats || d.groups || d || []; }
    } catch(e) { M.showError && M.showError('Ошибка загрузки чатов'); }
    if (!Array.isArray(chats)) chats = [];
    chats.sort(function(a, b) {
      return String(b.last_message_at || b.created_at || '').localeCompare(String(a.last_message_at || a.created_at || ''));
    });

    // Check if we need to open a specific chat (deep link)
    var params = new URLSearchParams(location.hash.split('?')[1] || '');
    var openChatId = params.get('id');

    // Render chat list (Telegram-style)
    // Group chats by type
    var directChats = chats.filter(function(c) { return !c.is_group && !c.project_id; });
    var groupChats = chats.filter(function(c) { return c.is_group && !c.project_id; });
    var projectChats = chats.filter(function(c) { return !!c.project_id; });

    function formatChatItem(c) {
      var chatName = c.is_group ? (c.name || 'Группа') : (c.direct_user_name || 'Чат');
      var lastMsg = c.last_message ? c.last_message.substring(0, 50) : '';
      var timeStr = '';
      if (c.last_message_at) {
        var d = new Date(c.last_message_at);
        var now = new Date();
        timeStr = d.toDateString() === now.toDateString() ? d.toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : d.toLocaleDateString('ru', {day:'numeric',month:'short'});
      }
      return M.mChatListItem({ id: c.id, name: chatName, avatar: c.avatar_url || '', lastMessage: lastMsg, time: timeStr, unread: c.unread_count || 0, online: (c.last_seen && (Date.now() - new Date(c.last_seen).getTime()) < 300000) || false });
    }

    function chatSection(title, items) {
      if (!items.length) return '';
      return '<div class="m-chat-section-title">' + title + '</div>' + items.map(formatChatItem).join('');
    }

    var chatListHtml = chats.length > 0
      ? (chatSection('Личные', directChats) + chatSection('Групповые', groupChats) + chatSection('По объектам', projectChats)) || chats.map(formatChatItem).join('')
      : M.mEmpty('Нет чатов. Начните переписку!', '💬');

    var searchBar = '<div class="m-chat-search-wrap">' +
      '<input class="m-search-input m-chat-search-field" id="mChatSearch" placeholder="Поиск чатов...">' +
      '</div>';

    var body = '<div class="m-page" data-mobile-native="1">' +
      '<div id="chatListView">' + searchBar +
        '<div id="chatListContainer">' + chatListHtml + '</div>' +
      '</div>' +
      '<div id="chatConvView" style="display:none">' +
        '<div id="chatConvHeader"></div>' +
        '<div class="m-chat-messages" id="chatMessages"></div>' +
        M.mTypingIndicator('') +
        M.mChatInput() +
        '<button class="m-chat-scroll-down" id="chatScrollDown">\u2193</button>' +
      '</div>' +
      M.mChatContextMenu() +
    '</div>';
    await layoutFn(body, { title: 'Мессенджер' });

    // === Chat list interactions ===
    var chatListContainer = document.getElementById('chatListContainer');
    var chatListView = document.getElementById('chatListView');
    var chatConvView = document.getElementById('chatConvView');
    var chatMessages = document.getElementById('chatMessages');
    var chatInput = document.getElementById('chatInput');
    var chatSendBtn = document.getElementById('chatSendBtn');
    var chatVoiceBtn = document.getElementById('chatVoiceBtn');
    var chatScrollDown = document.getElementById('chatScrollDown');
    var chatReplyBar = document.getElementById('chatReplyBar');
    var chatCtxMenu = document.getElementById('chatCtxMenu');
    var currentChatId = null;
    var currentChatName = '';
    var replyToMsg = null;

    // Search
    var searchInput = document.getElementById('mChatSearch');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var q = this.value.toLowerCase();
        var items = chatListContainer.querySelectorAll('.m-chat-list-item');
        items.forEach(function(item) {
          var name = (item.querySelector('.m-chat-name') || {}).textContent || '';
          var preview = (item.querySelector('.m-chat-preview') || {}).textContent || '';
          item.style.display = (name.toLowerCase().includes(q) || preview.toLowerCase().includes(q)) ? '' : 'none';
        });
      });
    }


    // Pull-to-Refresh for chat list
    (function initChatPTR() {
      var cl = document.getElementById('chatListContainer');
      if (!cl) return;
      var startY = 0, pulling = false, ptrEl = null;
      cl.addEventListener('touchstart', function(e) {
        if (cl.scrollTop <= 0) { startY = e.touches[0].clientY; pulling = true; }
      }, { passive: true });
      cl.addEventListener('touchmove', function(e) {
        if (!pulling) return;
        var dy = e.touches[0].clientY - startY;
        if (dy > 0 && dy < 150) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435...</span>';
            cl.parentNode.insertBefore(ptrEl, cl);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      cl.addEventListener('touchend', function() {
        if (!pulling) return;
        pulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          fetch('/api/chat-groups', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var chats = data.data || data || [];
            var container = document.getElementById('chatListContainer');
            if (container) {
              container.innerHTML = chats.length
                ? chats.map(function(c) {
                    return M.mChatListItem({
                      id: c.id,
                      name: c.name || c.title || '\u0427\u0430\u0442',
                      lastMessage: c.last_message || '',
                      time: c.last_message_at || '',
                      unread: c.unread_count || 0,
                      online: (c.last_seen && (Date.now() - new Date(c.last_seen).getTime()) < 300000) || false
                    });
                  }).join('')
                : M.mEmpty('\u041D\u0435\u0442 \u0447\u0430\u0442\u043E\u0432', '\uD83D\uDCAC');
            }
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          })
          .catch(function() {
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Open chat
    function openChat(chatId) {
      currentChatId = chatId;
      var chatData = chats.find(function(c) { return String(c.id) === String(chatId); });
      currentChatName = chatData ? (chatData.is_group ? (chatData.name || 'Группа') : (chatData.direct_user_name || 'Чат')) : 'Чат';

      // Render conversation header
      var headerEl = document.getElementById('chatConvHeader');
      headerEl.innerHTML = M.mChatHeader({
        name: currentChatName,
        online: chatData && chatData.last_seen && (Date.now() - new Date(chatData.last_seen).getTime() < 300000),
        lastSeen: chatData && chatData.last_seen ? 'был(a) ' + new Date(chatData.last_seen).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : ''
      });

      // Switch views
      chatListView.style.display = 'none';
      chatConvView.style.display = '';
      // Hide tabbar
      var tabbar = document.querySelector('.m-tabbar');
      if (tabbar) tabbar.style.display = 'none';
      // Hide header
      var header = document.querySelector('.m-header');
      if (header) header.style.display = 'none';

      // Load messages
      loadMessages(chatId);
      // Start typing indicator poll
      if (typeof startTypingPoll === 'function') startTypingPoll();

      // Back button
      var backBtn = document.getElementById('chatBackBtn');
      if (backBtn) {
        backBtn.onclick = function() {
          chatConvView.style.display = 'none';
          chatListView.style.display = '';
          currentChatId = null;
          if (typingPollInterval) clearInterval(typingPollInterval);
          if (tabbar) tabbar.style.display = '';
          if (header) header.style.display = '';
        };
      }
    }

    // Load messages
    async function loadMessages(chatId) {
      chatMessages.innerHTML = M.mSkeleton('card', 5);
      try {
        var resp = await fetch('/api/chat-groups/' + chatId + '/messages?limit=50', {
          headers: { 'Authorization': 'Bearer ' + token }
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        var data = await resp.json();
        var msgs = data.messages || data || [];

        // Group by date
        var lastDate = '';
        var html = '';
        msgs.forEach(function(msg) {
          var msgDate = msg.created_at ? new Date(msg.created_at).toLocaleDateString('ru') : '';
          if (msgDate !== lastDate) {
            var today = new Date().toLocaleDateString('ru');
            var yesterday = new Date(Date.now() - 86400000).toLocaleDateString('ru');
            var dateLabel = msgDate === today ? 'Сегодня' : (msgDate === yesterday ? 'Вчера' : msgDate);
            html += M.mChatDateSep(dateLabel);
            lastDate = msgDate;
          }
          var time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : '';
          html += M.mChatBubble({
            id: msg.id,
            text: msg.text || msg.message || '',
            time: time,
            isMine: String(msg.user_id) === String(user.id),
            senderName: msg.user_name || '',
            status: msg.is_read ? 'read' : 'sent',
            replyTo: msg.reply_to ? { name: msg.reply_to_name || '', text: msg.reply_to_text || '' } : null
          });
        });

        chatMessages.innerHTML = html || M.mEmpty('Нет сообщений. Напишите первое!', '💬');
        // Scroll to bottom
        chatMessages.scrollTop = chatMessages.scrollHeight;
      } catch(e) {
        chatMessages.innerHTML = M.mEmpty('Ошибка загрузки сообщений', '⚠');
      }
    }

    // Send message
    async function sendMessage() {
      var text = chatInput.value.trim();
      if (!text || !currentChatId) return;
      chatInput.value = '';
      chatInput.style.height = 'auto';
      chatSendBtn.classList.remove('visible');
      chatVoiceBtn.style.display = '';

      // Optimistic UI
      var tempId = 'temp_' + Date.now();
      var now = new Date();
      var bubble = M.mChatBubble({
        id: tempId,
        text: text,
        time: now.toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}),
        isMine: true,
        status: 'sent',
        replyTo: replyToMsg
      });
      chatMessages.insertAdjacentHTML('beforeend', bubble);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      // Clear reply
      if (replyToMsg) {
        replyToMsg = null;
        chatReplyBar.style.display = 'none';
      }

      // Send to server
      try {
        var payload = { text: text, chat_group_id: currentChatId };
        if (replyToMsg) payload.reply_to_id = replyToMsg.id;
        await fetch('/api/chat-groups/' + currentChatId + '/messages', {
          method: 'POST',
          headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
      } catch(e) { console.warn('[Chat] send failed:', e.message || e); }
    }

    // Input interactions
    if (chatInput) {
      chatInput.addEventListener('input', function() {
        // Auto-grow
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        // Toggle send/voice
        if (this.value.trim()) {
          chatSendBtn.classList.add('visible');
          chatVoiceBtn.style.display = 'none';
        } else {
          chatSendBtn.classList.remove('visible');
          chatVoiceBtn.style.display = '';
        }
      });
      chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });

      // Typing indicator — send typing event every 3 seconds
      var typingTimer = null;
      var lastTypingSent = 0;
      chatInput.addEventListener('input', function() {
        var now = Date.now();
        if (currentChatId && now - lastTypingSent > 3000) {
          lastTypingSent = now;
          fetch('/api/chat-groups/' + currentChatId + '/typing', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token }
          }).catch(function() {});
        }
        clearTimeout(typingTimer);
        typingTimer = setTimeout(function() { lastTypingSent = 0; }, 5000);
      });

      // Poll for typing indicator from others
      var chatTypingEl = document.getElementById('chatTyping');
      var typingPollInterval = null;
      function startTypingPoll() {
        if (typingPollInterval) clearInterval(typingPollInterval);
        typingPollInterval = setInterval(function() {
          if (!currentChatId) return;
          fetch('/api/chat-groups/' + currentChatId + '/typing', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var typers = data.typing || [];
            var others = typers.filter(function(t) { return String(t.user_id) !== String(user.id); });
            if (chatTypingEl) {
              if (others.length > 0) {
                var names = others.map(function(t) { return t.name || 'Кто-то'; }).join(', ');
                chatTypingEl.querySelector('.m-chat-typing-name').textContent = names + ' печатает...';
                chatTypingEl.style.display = '';
              } else {
                chatTypingEl.style.display = 'none';
              }
            }
          })
          .catch(function() {});
        }, 3000);
      }
    }
    if (chatSendBtn) chatSendBtn.addEventListener('click', sendMessage);

    // Reply close
    var replyClose = document.getElementById('chatReplyClose');
    if (replyClose) {
      replyClose.addEventListener('click', function() {
        replyToMsg = null;
        chatReplyBar.style.display = 'none';
      });
    }

    // Swipe-to-reply on chat bubbles
    (function initSwipeReply() {
      if (!chatMessages) return;
      var swStartX = 0, swStartY = 0, swBubble = null;
      chatMessages.addEventListener('touchstart', function(e) {
        var bubble = e.target.closest('.m-chat-bubble.other');
        if (!bubble) return;
        swStartX = e.touches[0].clientX;
        swStartY = e.touches[0].clientY;
        swBubble = bubble;
      }, { passive: true });
      chatMessages.addEventListener('touchmove', function(e) {
        if (!swBubble) return;
        var dx = e.touches[0].clientX - swStartX;
        var dy = Math.abs(e.touches[0].clientY - swStartY);
        if (dy > 30) { swBubble.style.transform = ''; swBubble = null; return; }
        if (dx > 0 && dx < 80) {
          swBubble.style.transform = 'translateX(' + dx + 'px)';
          swBubble.style.transition = 'none';
        }
      }, { passive: true });
      chatMessages.addEventListener('touchend', function(e) {
        if (!swBubble) return;
        var dx = e.changedTouches ? e.changedTouches[0].clientX - swStartX : 0;
        swBubble.style.transition = 'transform 0.2s ease';
        swBubble.style.transform = '';
        if (dx > 60 && chatReplyBar) {
          var msgText = (swBubble.querySelector('.m-chat-bubble-text') || {}).textContent || '';
          var sender = (swBubble.querySelector('.m-chat-bubble-sender') || {}).textContent || '';
          replyToMsg = { id: swBubble.dataset.msgId, name: sender, text: msgText };
          document.getElementById('chatReplyName').textContent = sender || 'Сообщение';
          document.getElementById('chatReplyText').textContent = msgText.substring(0, 80);
          chatReplyBar.style.display = '';
          if (chatInput) chatInput.focus();
        }
        swBubble = null;
      }, { passive: true });
    })();

    // Scroll-to-bottom button
    if (chatMessages && chatScrollDown) {
      chatMessages.addEventListener('scroll', function() {
        var atBottom = chatMessages.scrollHeight - chatMessages.scrollTop - chatMessages.clientHeight < 100;
        chatScrollDown.classList.toggle('visible', !atBottom);
      });
      chatScrollDown.addEventListener('click', function() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      });
    }

    // Pull-to-refresh for older messages in chat
    (function initChatPTR() {
      if (!chatMessages) return;
      var ptrStartY = 0, ptrPulling = false, ptrEl = null;
      chatMessages.addEventListener('touchstart', function(e) {
        if (chatMessages.scrollTop <= 0) { ptrStartY = e.touches[0].clientY; ptrPulling = true; }
      }, { passive: true });
      chatMessages.addEventListener('touchmove', function(e) {
        if (!ptrPulling) return;
        var dy = e.touches[0].clientY - ptrStartY;
        if (dy < 0) { ptrPulling = false; return; }
        if (dy > 10) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>Загрузка сообщений...</span>';
            chatMessages.insertBefore(ptrEl, chatMessages.firstChild);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      chatMessages.addEventListener('touchend', function() {
        ptrPulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          // Load older messages
          var oldestMsg = chatMessages.querySelector('.m-chat-bubble');
          var oldestId = oldestMsg ? oldestMsg.dataset.msgId : null;
          fetch('/api/chat-groups/' + currentChatId + '/messages?before=' + (oldestId || '') + '&limit=20', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var msgs = data.messages || data || [];
            if (msgs.length > 0) {
              var oldScrollH = chatMessages.scrollHeight;
              var html = '';
              msgs.reverse().forEach(function(m) {
                html += M.mChatBubble({
                  id: m.id,
                  text: m.content || m.text || '',
                  time: m.created_at ? new Date(m.created_at).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : '',
                  isMine: String(m.user_id) === String(user.id),
                  senderName: m.user_name || '',
                  status: m.read_by ? 'read' : 'sent'
                });
              });
              if (ptrEl) ptrEl.insertAdjacentHTML('afterend', html);
              // Preserve scroll position
              chatMessages.scrollTop = chatMessages.scrollHeight - oldScrollH;
            }
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          })
          .catch(function() { if (ptrEl) { ptrEl.remove(); ptrEl = null; } });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Long-press context menu on bubbles
    var longPressTimer = null;
    var targetBubble = null;
    if (chatMessages) {
      chatMessages.addEventListener('touchstart', function(e) {
        var bubble = e.target.closest('.m-chat-bubble');
        if (!bubble) return;
        targetBubble = bubble;
        longPressTimer = setTimeout(function() {
          // Show context menu
          var rect = bubble.getBoundingClientRect();
          chatCtxMenu.style.top = Math.min(rect.bottom, window.innerHeight - 200) + 'px';
          chatCtxMenu.style.left = (bubble.classList.contains('mine') ? rect.left - 180 : rect.right) + 'px';
          chatCtxMenu.classList.add('visible');
          // Haptic
          if (navigator.vibrate) navigator.vibrate(10);
        }, 500);
      });
      chatMessages.addEventListener('touchend', function() { clearTimeout(longPressTimer); });
      chatMessages.addEventListener('touchmove', function() { clearTimeout(longPressTimer); });
    }

    // Context menu actions
    if (chatCtxMenu) {
      chatCtxMenu.addEventListener('click', function(e) {
        var item = e.target.closest('.m-chat-ctx-item');
        if (!item || !targetBubble) return;
        var action = item.dataset.action;
        var msgId = targetBubble.dataset.msgId;
        var msgText = (targetBubble.querySelector('.m-chat-bubble-text') || {}).textContent || '';

        switch(action) {
          case 'reply':
            replyToMsg = { id: msgId, name: (targetBubble.querySelector('.m-chat-bubble-sender') || {}).textContent || '', text: msgText };
            document.getElementById('chatReplyName').textContent = replyToMsg.name || 'Сообщение';
            document.getElementById('chatReplyText').textContent = msgText.substring(0, 80);
            chatReplyBar.style.display = '';
            chatInput.focus();
            break;
          case 'copy':
            navigator.clipboard.writeText(msgText).then(function() {
              if (M.showSuccess) M.showSuccess('Скопировано');
            });
            break;
          case 'forward':
            // Forward picker — show modal with chat list
            (function() {
              var fwdOverlay = document.createElement('div');
              fwdOverlay.className = 'm-forward-overlay';
              fwdOverlay.innerHTML =
                '<div class="m-forward-picker">' +
                  '<div class="m-forward-picker-header">' +
                    '<span class="m-forward-picker-title">Переслать в...</span>' +
                    '<button class="m-forward-close" id="fwdClose">✕</button>' +
                  '</div>' +
                  '<input class="m-search-input m-forward-search" id="fwdSearch" placeholder="Поиск чата...">' +
                  '<div class="m-forward-list" id="fwdList">' +
                    '<div class="m-loading-dots"><span></span><span></span><span></span></div>' +
                  '</div>' +
                '</div>';
              document.body.appendChild(fwdOverlay);
              requestAnimationFrame(function() { fwdOverlay.classList.add('visible'); });

              // Load chats
              fetch('/api/chat-groups', {
                headers: { 'Authorization': 'Bearer ' + token }
              })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                var chats = data.data || data || [];
                var fwdList = document.getElementById('fwdList');
                if (!chats.length) {
                  fwdList.innerHTML = '<div class="m-search-empty">Нет доступных чатов</div>';
                  return;
                }
                fwdList.innerHTML = chats.map(function(c) {
                  var name = c.name || c.title || 'Чат';
                  var avatar = (name[0] || '?').toUpperCase();
                  return '<div class="m-forward-item" data-chat-id="' + c.id + '">' +
                    '<div class="m-chat-avatar"><span>' + avatar + '</span></div>' +
                    '<div class="m-forward-item-name">' + name + '</div>' +
                  '</div>';
                }).join('');

                // Search filter
                document.getElementById('fwdSearch').addEventListener('input', function(e) {
                  var q = e.target.value.toLowerCase();
                  fwdList.querySelectorAll('.m-forward-item').forEach(function(item) {
                    var name = item.querySelector('.m-forward-item-name').textContent.toLowerCase();
                    item.style.display = name.indexOf(q) >= 0 ? '' : 'none';
                  });
                });

                // Click to forward
                fwdList.addEventListener('click', function(e) {
                  var item = e.target.closest('.m-forward-item');
                  if (!item) return;
                  var targetChatId = item.dataset.chatId;
                  // Send forwarded message
                  fetch('/api/chat-groups/' + targetChatId + '/messages', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify({
                      text: '↪ Пересланное сообщение:\n' + msgText
                    })
                  })
                  .then(function() {
                    if (M.showSuccess) M.showSuccess('Сообщение переслано');
                    closeFwd();
                  })
                  .catch(function(err) {
                    console.warn('[Chat] forward failed:', err.message || err);
                    if (M.showSuccess) M.showSuccess('Ошибка пересылки');
                    closeFwd();
                  });
                });
              })
              .catch(function(err) {
                console.warn('[Chat] load chats for forward:', err.message || err);
                document.getElementById('fwdList').innerHTML = '<div class="m-search-empty">Ошибка загрузки</div>';
              });

              function closeFwd() {
                fwdOverlay.classList.remove('visible');
                setTimeout(function() { fwdOverlay.remove(); }, 300);
              }

              document.getElementById('fwdClose').addEventListener('click', closeFwd);
              fwdOverlay.addEventListener('click', function(e) {
                if (e.target === fwdOverlay) closeFwd();
              });
            })();
            break;
          case 'delete':
            targetBubble.remove();
            fetch('/api/chat-groups/' + currentChatId + '/messages/' + msgId, {
              method: 'DELETE',
              headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
            break;
        }
        chatCtxMenu.classList.remove('visible');
      });

      // Close ctx menu on outside click
      document.addEventListener('click', function(e) {
        if (!chatCtxMenu.contains(e.target)) chatCtxMenu.classList.remove('visible');
      });
    }

    // Click on chat list item
    if (chatListContainer) {
      chatListContainer.addEventListener('click', function(e) {
        var item = e.target.closest('.m-chat-list-item');
        if (item && item.dataset.chatId) {
          openChat(item.dataset.chatId);
        }
      });
    }

    // Voice message (basic implementation)
    var mediaRecorder = null;
    var audioChunks = [];
    if (chatVoiceBtn) {
      chatVoiceBtn.addEventListener('click', async function() {
        if (mediaRecorder && mediaRecorder.state === 'recording') {
          mediaRecorder.stop();
          chatVoiceBtn.classList.remove('recording');
          return;
        }
        try {
          var stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];
          mediaRecorder.ondataavailable = function(e) { audioChunks.push(e.data); };
          mediaRecorder.onstop = async function() {
            stream.getTracks().forEach(function(t) { t.stop(); });
            var blob = new Blob(audioChunks, { type: 'audio/webm' });
            // Send voice message
            var formData = new FormData();
            formData.append('audio', blob, 'voice.webm');
            formData.append('chat_group_id', currentChatId);
            formData.append('type', 'voice');
            try {
              await fetch('/api/chat-groups/' + currentChatId + '/messages', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token },
                body: formData
              });
              await loadMessages(currentChatId);
            } catch(e) { console.warn('[MobileRender]', e.message || e); }
          };
          mediaRecorder.start();
          chatVoiceBtn.classList.add('recording');
          if (navigator.vibrate) navigator.vibrate(10);
        } catch(e) {
          if (M.showError) M.showError('Нет доступа к микрофону');
        }
      });
    }

    // Deep link - open specific chat
    // Update unread badge on Chat tab
    var totalUnread = chats.reduce(function(sum, c) { return sum + (c.unread_count || 0); }, 0);
    if (totalUnread > 0) {
      var chatTab = document.querySelector('.m-tab-item[data-tab="chat"]');
      if (chatTab) {
        var badge = chatTab.querySelector('.m-tab-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'm-tab-badge';
          chatTab.style.position = 'relative';
          chatTab.appendChild(badge);
        }
        badge.textContent = totalUnread > 99 ? '99+' : String(totalUnread);
        badge.style.display = '';
      }
    }

        if (openChatId) {
      setTimeout(function() { openChat(openChatId); }, 100);
    }
  });


