  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TASKS CRUD  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardTasksCrudPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var userMap = {};
    users.forEach(function(u) { userMap[u.id] = u; });

    var tasks = [];
    try {
      var token = localStorage.getItem('asgard_token');
      var resp = await fetch('/api/tasks?limit=500', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (resp.ok) {
        var data = await resp.json();
        tasks = data.tasks || [];
      }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var PRIORITIES = { high: '🔴 Высокий', medium: '🟡 Средний', low: '🟢 Низкий' };
    var statusNew = tasks.filter(function(t) { return t.status === 'Новая'; }).length;
    var statusWork = tasks.filter(function(t) { return t.status === 'В работе'; }).length;
    var statusDone = tasks.filter(function(t) { return t.status === 'Выполнена'; }).length;

    var body = M.mTablePage({
      stats: [
        { label: 'Все', value: tasks.length, icon: '📋', color: 'var(--info)' },
        { label: 'Новые', value: statusNew, icon: '🆕', color: 'var(--purple-l)' },
        { label: 'В работе', value: statusWork, icon: '⚡', color: 'var(--amber)' },
        { label: 'Выполнено', value: statusDone, icon: '✅', color: 'var(--ok-t)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск задач...' },
        actions: [
          { id: 'btnNewTask', label: 'Создать', icon: '+', cls: 'primary' }
        ]
      },
      items: tasks,
      renderCard: function(t) {
        var assignee = userMap[t.assigned_to] || {};
        var overdue = t.due_date && new Date(t.due_date) < new Date() && t.status !== 'Закрыта' && t.status !== 'Выполнена';
        var prioLabel = PRIORITIES[t.priority] || '🟡 Средний';

        var actionBtn = '';
        if (t.status === 'Новая') actionBtn = '<button class="m-info-btn" data-action="В работе" data-tid="' + t.id + '">▶ В работу</button>';
        if (t.status === 'В работе') actionBtn = '<button class="m-approve-btn" data-action="Выполнена" data-tid="' + t.id + '">✓ Выполнена</button>';
        if (t.status === 'Выполнена') actionBtn = '<button class="m-skip-btn" data-action="Закрыта" data-tid="' + t.id + '">🔒 Закрыть</button>';

        return M.mCard({
          id: t.id,
          title: esc(t.title || 'Без названия'),
          subtitle: esc(assignee.name || '— Не назначен'),
          badge: t.status || '—',
          badgeColor: M.statusColor(t.status),
          accentColor: overdue ? 'var(--err-t)' : undefined,
          fields: [
            { label: 'Приоритет', value: prioLabel },
            { label: 'Дедлайн', value: (t.due_date ? fmtDate(t.due_date) : '—') + (overdue ? ' ⚠️' : '') },
            { label: 'Автор', value: esc((userMap[t.created_by] || {}).name || '—') },
            { label: 'Исполнитель', value: esc(assignee.name || '—') }
          ],
          footer: actionBtn ? '<div class="m-card-actions">' + actionBtn + '</div>' : '',
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Задачи' });

    /* Status change handler */
    var container = document.getElementById('mobileList');
    if (container) {
      container.addEventListener('click', async function(e) {
        var btn = e.target.closest('[data-action]');
        if (!btn) return;
        e.stopPropagation();
        var newStatus = btn.getAttribute('data-action');
        var tid = parseInt(btn.getAttribute('data-tid'));
        if (!tid || !newStatus) return;
        try {
          var token = localStorage.getItem('asgard_token');
          var resp = await fetch('/api/tasks/' + tid + '/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify({ status: newStatus })
          });
          if (!resp.ok) throw new Error('Ошибка');
          var card = btn.closest('.m-card');
          if (newStatus === 'Выполнена' || newStatus === 'Закрыта') M.showSuccessAnimation(card);
          if (typeof AsgardUI !== 'undefined' && AsgardUI.toast) AsgardUI.toast('Готово', 'Статус: ' + newStatus);
          setTimeout(function() { location.hash = location.hash; }, 500);
        } catch(er) {
          if (typeof AsgardUI !== 'undefined' && AsgardUI.toast) AsgardUI.toast('Ошибка', er.message, 'err');
        }
      });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  MY MAIL (Mobile Email Client)  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardMyMailPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = auth.token || localStorage.getItem('asgard_token');

    /* v8.0.0 — Yandex Mail level */
    var configured = false;
    try {
      var resp = await fetch('/api/my-mail/account', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var acc = await resp.json(); configured = !!acc.email; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    if (!configured) {
      var body = '<div class="m-page" data-mobile-native="1">' +
        M.mEmpty('Почта не настроена. Настройте подключение в \xABНастройки почты\xBB.', '\uD83D\uDCE7') +
      '</div>';
      await layout(body, { title: title || 'Моя почта' });
      return;
    }

    var currentFolder = 'inbox';
    var emails = [];
    var folders = [
      { id: 'inbox', label: 'Входящие', count: 0, active: true },
      { id: 'sent', label: 'Отправленные', count: 0 },
      { id: 'drafts', label: 'Черновики', count: 0 },
      { id: 'spam', label: 'Спам', count: 0 },
      { id: 'trash', label: 'Корзина', count: 0 }
    ];

    async function fetchEmails(folder) {
      try {
        var resp = await fetch('/api/my-mail/emails?limit=50&folder=' + folder, {
          headers: { 'Authorization': 'Bearer ' + token }
        });
        if (resp.ok) {
          var data = await resp.json();
          emails = data.emails || [];
          if (data.stats) {
            folders[0].count = data.stats.inbox_unread || 0;
            folders[2].count = data.stats.drafts || 0;
          }
        }
      } catch(e) { emails = []; }
    }

    await fetchEmails('inbox');

    function renderMailList() {
      if (!emails.length) return M.mEmpty('Нет писем', '\uD83D\uDCEB');
      return emails.map(function(e) {
        return M.mMailItem({
          id: e.id,
          from: e.from_name || e.from_email || e.from || '',
          subject: e.subject || '',
          snippet: (e.body_text || e.preview || '').replace(/<[^>]+>/g, '').substring(0, 60),
          time: fmtDateShort(e.date || e.created_at),
          unread: !e.is_read,
          starred: e.is_starred,
          hasAttachment: e.has_attachment || (e.attachments && e.attachments.length > 0)
        });
      }).join('');
    }

    var folderTitle = 'Входящие';
    var unreadCount = emails.filter(function(e) { return !e.is_read; }).length;

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mMailFolders(folders) +
      M.mMailCompose() +
      '<div id="mailMainView">' +
        '<div class="m-mail-toolbar">' +
          '<button class="m-chat-back-btn m-mail-burger-icon" id="mailBurgerBtn">\u2630</button>' +
          '<span id="mailFolderTitle" class="m-mail-toolbar-title">' + folderTitle + (unreadCount ? ' (' + unreadCount + ')' : '') + '</span>' +
          '<button class="m-chat-back-btn" id="mailSearchToggle">\uD83D\uDD0D</button>' +
          '<button class="m-chat-back-btn m-mail-compose-icon" id="mailComposeBtn">\u270F</button>' +
        '</div>' +
        '<input class="m-search-input m-mail-search-field" id="mailSearch" placeholder="\u041F\u043E\u0438\u0441\u043A \u043F\u0438\u0441\u0435\u043C...">' +
        '<div id="mailList">' + renderMailList() + '</div>' +
      '</div>' +
      '<div id="mailDetailView" style="display:none"></div>' +
    '</div>';

    await layout(body, { title: title || 'Моя почта' });

    var mailList = document.getElementById('mailList');
    var mailMainView = document.getElementById('mailMainView');
    var mailDetailView = document.getElementById('mailDetailView');
    var mailDrawer = document.getElementById('mailDrawer');
    var mailDrawerOverlay = document.getElementById('mailDrawerOverlay');
    var mailCompose = document.getElementById('mailCompose');

    // Burger -> open folder drawer
    var burgerBtn = document.getElementById('mailBurgerBtn');
    if (burgerBtn) {
      burgerBtn.addEventListener('click', function() {
        mailDrawer.classList.add('open');
        mailDrawerOverlay.classList.add('open');
      });
    }
    if (mailDrawerOverlay) {
      mailDrawerOverlay.addEventListener('click', function() {
        mailDrawer.classList.remove('open');
        mailDrawerOverlay.classList.remove('open');
      });
    }

    // Folder selection
    if (mailDrawer) {
      mailDrawer.addEventListener('click', async function(e) {
        var item = e.target.closest('.m-mail-folder-item');
        if (!item) return;
        var folderId = item.dataset.folder;
        currentFolder = folderId;
        // Update active state
        mailDrawer.querySelectorAll('.m-mail-folder-item').forEach(function(i) { i.classList.remove('active'); });
        item.classList.add('active');
        // Close drawer
        mailDrawer.classList.remove('open');
        mailDrawerOverlay.classList.remove('open');
        // Reload emails
        mailList.innerHTML = M.mSkeleton('card', 5);
        await fetchEmails(folderId);
        mailList.innerHTML = renderMailList();
        initSwipe();
        // Update title
        var folderLabel = folders.find(function(f) { return f.id === folderId; });
        document.getElementById('mailFolderTitle').textContent = folderLabel ? folderLabel.label : folderId;
      });
    }

    // Search toggle
    var searchToggle = document.getElementById('mailSearchToggle');
    var searchInput = document.getElementById('mailSearch');
    if (searchToggle && searchInput) {
      searchToggle.addEventListener('click', function() {
        searchInput.classList.toggle('open');
        if (searchInput.classList.contains('open')) searchInput.focus();
      });
      searchInput.addEventListener('input', function() {
        var q = this.value.toLowerCase();
        var items = mailList.querySelectorAll('.m-mail-swipe-wrap');
        items.forEach(function(item) {
          var sender = (item.querySelector('.m-mail-sender') || {}).textContent || '';
          var subject = (item.querySelector('.m-mail-subject') || {}).textContent || '';
          item.style.display = (sender.toLowerCase().includes(q) || subject.toLowerCase().includes(q)) ? '' : 'none';
        });
      });
    }


    // Pull-to-Refresh for mail
    (function initMailPTR() {
      var ml = document.getElementById('mailList');
      if (!ml) return;
      var startY = 0, pulling = false, ptrEl = null;
      ml.addEventListener('touchstart', function(e) {
        if (ml.scrollTop <= 0) { startY = e.touches[0].clientY; pulling = true; }
      }, { passive: true });
      ml.addEventListener('touchmove', function(e) {
        if (!pulling) return;
        var dy = e.touches[0].clientY - startY;
        if (dy > 0 && dy < 150) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435...</span>';
            ml.parentNode.insertBefore(ptrEl, ml);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      ml.addEventListener('touchend', function() {
        if (!pulling) return;
        pulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          fetchEmails(currentFolder).then(function() {
              mailList.innerHTML = renderMailList();
              initSwipe();
              if (ptrEl) { ptrEl.remove(); ptrEl = null; }
            }).catch(function() {
              if (ptrEl) { ptrEl.remove(); ptrEl = null; }
            });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Compose button
    var composeBtn = document.getElementById('mailComposeBtn');
    if (composeBtn && mailCompose) {
      composeBtn.addEventListener('click', function() { mailCompose.classList.add('open'); });
    }
    var composeClose = document.getElementById('mailComposeClose');
    if (composeClose) {
      composeClose.addEventListener('click', function() { mailCompose.classList.remove('open'); });
    }
    // CC toggle
    var ccToggle = document.getElementById('mailCcToggle');
    var ccField = document.getElementById('mailCcField');
    if (ccToggle && ccField) {
      ccToggle.addEventListener('click', function() {
        ccField.style.display = ccField.style.display === 'none' ? '' : 'none';
        ccToggle.classList.toggle('active');
      });
    }

    // Employee autocomplete for To field
    var mailToInput = document.getElementById('mailTo');
    if (mailToInput) {
      var acTimer = null;
      var acDropdown = null;
      mailToInput.addEventListener('input', function() {
        var q = this.value.trim();
        clearTimeout(acTimer);
        if (q.length < 2) { if (acDropdown) acDropdown.remove(); return; }
        acTimer = setTimeout(function() {
          fetch('/api/staff?search=' + encodeURIComponent(q) + '&limit=5', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var staff = data.staff || data.data || data || [];
            if (!staff.length) { if (acDropdown) acDropdown.remove(); return; }
            if (!acDropdown) {
              acDropdown = document.createElement('div');
              acDropdown.className = 'm-mail-autocomplete';
              mailToInput.parentNode.appendChild(acDropdown);
            }
            acDropdown.innerHTML = staff.map(function(s) {
              return '<div class="m-mail-ac-item" data-email="' + (s.email || '') + '">' +
                '<strong>' + (s.name || s.full_name || '') + '</strong>' +
                '<span>' + (s.email || '') + '</span></div>';
            }).join('');
            acDropdown.querySelectorAll('.m-mail-ac-item').forEach(function(item) {
              item.addEventListener('click', function() {
                mailToInput.value = this.dataset.email;
                acDropdown.remove();
                acDropdown = null;
              });
            });
          })
          .catch(function() {});
        }, 300);
      });
    }

    var composeSend = document.getElementById('mailComposeSend');
    if (composeSend) {
      composeSend.addEventListener('click', async function() {
        var to = document.getElementById('mailTo').value.trim();
        var subject = document.getElementById('mailSubject').value.trim();
        var bodyText = document.getElementById('mailBody').value.trim();
        if (!to) return;
        composeSend.disabled = true;
        composeSend.textContent = '\u041E\u0442\u043F\u0440\u0430\u0432\u043A\u0430...';
        try {
          await fetch('/api/my-mail/send', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify({ to: to, subject: subject, body: bodyText })
          });
          mailCompose.classList.remove('open');
          document.getElementById('mailTo').value = '';
          document.getElementById('mailSubject').value = '';
          document.getElementById('mailBody').value = '';
          if (M.showSuccess) M.showSuccess('\u041F\u0438\u0441\u044C\u043C\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043E');
        } catch(e) {
          if (M.showError) M.showError('\u041E\u0448\u0438\u0431\u043A\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043A\u0438');
        }
        composeSend.disabled = false;
        composeSend.textContent = '\u041E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C';
      });
    }

      // Rich text toolbar — format commands
      var mailBody = document.getElementById('mailBody');
      if (mailBody) {
        // Switch textarea to contenteditable div for rich text
        var richDiv = document.createElement('div');
        richDiv.id = 'mailBody';
        richDiv.className = 'm-mail-compose-textarea';
        richDiv.contentEditable = 'true';
        richDiv.setAttribute('placeholder', 'Текст письма...');
        richDiv.style.minHeight = '200px';
        richDiv.style.outline = 'none';
        richDiv.style.whiteSpace = 'pre-wrap';
        mailBody.parentNode.replaceChild(richDiv, mailBody);
        mailBody = richDiv;
      }
      document.querySelectorAll('.m-mail-tb-btn[data-cmd]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var cmd = btn.dataset.cmd;
          document.execCommand(cmd, false, null);
          btn.classList.toggle('active');
          if (mailBody) mailBody.focus();
        });
      });

    // Star toggle
    if (mailList) {
      mailList.addEventListener('click', function(e) {
        var star = e.target.closest('.m-mail-star');
        if (star) {
          e.stopPropagation();
          star.classList.toggle('active');
          star.textContent = star.classList.contains('active') ? '\u2605' : '\u2606';
          var mailId = star.dataset.mailStar;
          fetch('/api/my-mail/emails/' + mailId + '/star', {
            method: 'PUT',
            headers: { 'Authorization': 'Bearer ' + token }
          }).catch(function(){});
          return;
        }
      });
    }

    // Open email detail
    if (mailList) {
      mailList.addEventListener('click', async function(e) {
        if (e.target.closest('.m-mail-star')) return;
        var item = e.target.closest('.m-mail-item');
        if (!item) return;
        var wrap = item.closest('.m-mail-swipe-wrap');
        var emailId = wrap ? wrap.dataset.mailId : '';
        if (!emailId) return;

        // Mark as read
        try {
          await fetch('/api/my-mail/emails/' + emailId + '/read', {
            method: 'PUT', headers: { 'Authorization': 'Bearer ' + token }
          });
          item.classList.remove('unread');
        } catch(e) { console.warn('[MobileRender]', e.message || e); }

        // Fetch full email
        try {
          var r = await fetch('/api/my-mail/emails/' + emailId, { headers: { 'Authorization': 'Bearer ' + token } });
          if (!r.ok) throw new Error();
          var email = await r.json();

          var emailBody = '';
          if (email.body_html) {
            emailBody = '<iframe class="m-email-iframe" sandbox="allow-same-origin" srcdoc="' +
              email.body_html.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;') +
              '" frameborder="0"></iframe>';
          } else {
            emailBody = '<div class="m-mail-body-text">' + esc(email.body_text || email.body || '') + '</div>';
          }

          // Attachments
          var attachHtml = '';
          if (email.attachments && email.attachments.length) {
            attachHtml = '<div class="m-mail-attachments-section"><div class="m-mail-attachments-label">\u0412\u043B\u043E\u0436\u0435\u043D\u0438\u044F (' + email.attachments.length + ')</div>';
            email.attachments.forEach(function(att) {
              var icon = '\uD83D\uDCC4';
              if (/\.(jpg|jpeg|png|gif|webp)/i.test(att.name)) icon = '\uD83D\uDDBC';
              if (/\.pdf/i.test(att.name)) icon = '\uD83D\uDCC4';
              if (/\.(doc|docx)/i.test(att.name)) icon = '\uD83D\uDCC3';
              if (/\.(xls|xlsx)/i.test(att.name)) icon = '\uD83D\uDCCA';
              attachHtml += '<div class="m-mail-attachment">' +
                '<div class="m-mail-att-icon">' + icon + '</div>' +
                '<div class="m-mail-att-info"><div class="m-mail-att-name">' + esc(att.name) + '</div>' +
                '<div class="m-mail-att-size">' + (att.size ? (Math.round(att.size/1024) + ' KB') : '') + '</div></div>' +
              '</div>';
            });
            attachHtml += '</div>';
          }

          // Detail view
          mailMainView.style.display = 'none';
          mailDetailView.style.display = '';
          // Hide tabbar
          var tabbar = document.querySelector('.m-tabbar');
          if (tabbar) tabbar.style.display = 'none';
          var header = document.querySelector('.m-header');
          if (header) header.style.display = 'none';

          mailDetailView.innerHTML =
            '<div class="m-mail-detail-header">' +
              '<button class="m-chat-back-btn" id="mailDetailBack">\u2190</button>' +
              '<span class="m-mail-detail-subject">' + esc(email.subject || '\u0411\u0435\u0437 \u0442\u0435\u043C\u044B') + '</span>' +
            '</div>' +
            '<div class="m-mail-detail-meta">' +
              '<div class="m-mail-detail-from">' + esc(email.from_name || email.from_email || '') + '</div>' +
              '<div class="m-mail-detail-email">' + esc(email.from_email || '') + '</div>' +
              '<div class="m-mail-detail-to">\u041A\u043E\u043C\u0443: ' + esc(email.to || '') + ' \u2022 ' + fmtDate(email.date || email.created_at) + '</div>' +
            '</div>' +
            emailBody +
            attachHtml +
            '<div class="m-mail-detail-actions">' +
              '<button class="m-load-more-btn" id="mailReplyBtn">\u21A9 \u041E\u0442\u0432\u0435\u0442\u0438\u0442\u044C</button>' +
              '<button class="m-load-more-btn" id="mailReplyAllBtn">↩↩ Всем</button>' +
              '<button class="m-load-more-btn" id="mailForwardBtn">\u21AA \u041F\u0435\u0440\u0435\u0441\u043B\u0430\u0442\u044C</button>' +
            '</div>';

          // Back from detail
          document.getElementById('mailDetailBack').addEventListener('click', function() {
            mailDetailView.style.display = 'none';
            mailMainView.style.display = '';
            if (tabbar) tabbar.style.display = '';
            if (header) header.style.display = '';
          });

          // Reply
          var replyBtn = document.getElementById('mailReplyBtn');
          if (replyBtn) {
            replyBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailTo').value = email.from_email || email.from || '';
              document.getElementById('mailSubject').value = 'Re: ' + (email.subject || '');
            });

          // Reply All
          var replyAllBtn = document.getElementById('mailReplyAllBtn');
          if (replyAllBtn) {
            replyAllBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailTo').value = (email.from_email || '') + ', ' + (email.to || '');
              document.getElementById('mailSubject').value = 'Re: ' + (email.subject || '');
              document.getElementById('mailBody').value = '\n\n--- Оригинал ---\n' + (email.body_text || email.body || '');
            });
          }
          }
          // Forward
          var fwdBtn = document.getElementById('mailForwardBtn');
          if (fwdBtn) {
            fwdBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailSubject').value = 'Fwd: ' + (email.subject || '');
              document.getElementById('mailBody').value = '\n\n--- \u041F\u0435\u0440\u0435\u0441\u043B\u0430\u043D\u043D\u043E\u0435 \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 ---\n\u041E\u0442: ' + (email.from_name || email.from_email || '') + '\n\u0422\u0435\u043C\u0430: ' + (email.subject || '') + '\n\n' + (email.body_text || '');
            });
          }
        } catch(e) { if (M.showError) M.showError('\u041E\u0448\u0438\u0431\u043A\u0430 \u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0438 \u043F\u0438\u0441\u044C\u043C\u0430'); }
      });
    }

    // Swipe actions on mail items
    function initSwipe() {
      var items = mailList.querySelectorAll('.m-mail-swipe-wrap');
      items.forEach(function(wrap) {
        var mailItem = wrap.querySelector('.m-mail-item');
        if (!mailItem) return;
        var startX = 0, currentX = 0, swiping = false;
        mailItem.addEventListener('touchstart', function(e) {
          startX = e.touches[0].clientX;
          currentX = 0;
          swiping = true;
          mailItem.style.transition = 'none';
        });
        mailItem.addEventListener('touchmove', function(e) {
          if (!swiping) return;
          currentX = e.touches[0].clientX - startX;
          if (Math.abs(currentX) > 10) {
            mailItem.style.transform = 'translateX(' + currentX + 'px)';
          }
        });
        mailItem.addEventListener('touchend', function() {
          swiping = false;
          mailItem.style.transition = 'transform 0.3s ease';
          if (currentX > 100) {
            // Swipe right = archive
            mailItem.style.transform = 'translateX(100%)';
            setTimeout(function() { wrap.style.display = 'none'; }, 300);
            var mailId = wrap.dataset.mailId;
            fetch('/api/my-mail/emails/' + mailId + '/archive', {
              method: 'PUT', headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
          } else if (currentX < -100) {
            // Swipe left = delete
            mailItem.style.transform = 'translateX(-100%)';
            setTimeout(function() { wrap.style.display = 'none'; }, 300);
            var mailId2 = wrap.dataset.mailId;
            fetch('/api/my-mail/emails/' + mailId2, {
              method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
          } else {
            mailItem.style.transform = 'translateX(0)';
          }
        });
      });
    }
    initSwipe();

    // Deep link
    var params = new URLSearchParams(location.hash.split('?')[1] || '');
    var openId = params.get('id');
    if (openId) {
      var targetItem = mailList.querySelector('[data-mail-id="' + openId + '"] .m-mail-item');
      if (targetItem) targetItem.click();
    }
  });


