    if (!auth) { location.hash = '#/login'; return; }
    var customers = [];
    try { customers = await AsgardDB.all('customers') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    customers.sort(function(a, b) { return String(a.name || '').localeCompare(String(b.name || ''), 'ru'); });

    var body = M.mTablePage({
      stats: [{ label: 'Контрагентов', value: customers.length, icon: '🏢', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск: ИНН, название...' } },
      items: customers,
      renderCard: function(c) {
        return M.mCard({
          id: c.inn || c.id,
          title: esc(c.name || c.full_name || '—'),
          subtitle: 'ИНН: ' + esc(c.inn || '—'),
          fields: [
            { label: 'КПП', value: esc(c.kpp || '—') },
            { label: 'Телефон', value: esc(c.phone || '—') },
            { label: 'Email', value: esc(c.email || '—') },
            { label: 'Адрес', value: esc((c.address || '').substring(0, 40) || '—'), full: true }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Контрагенты' });

    var container = document.getElementById('mobileList');
    if (container) {
      container.addEventListener('click', function(e) {
        var card = e.target.closest('.m-card[data-id]');
        if (card) location.hash = '#/customer?inn=' + card.getAttribute('data-id');
      });
