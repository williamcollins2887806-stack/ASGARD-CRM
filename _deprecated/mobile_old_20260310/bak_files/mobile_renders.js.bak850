  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TASKS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardTasksPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var tasks = await AsgardDB.all('tasks') || [];
    tasks = tasks.filter(function(t) { return t.assignee_id === auth.user.id || t.created_by === auth.user.id; });
    tasks.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var pending = tasks.filter(function(t) { return norm(t.status) !== 'done' && norm(t.status) !== 'completed'; });

        // Monthly tasks chart
    var _tkMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _tkMonthData = new Array(12).fill(0);
    tasks.forEach(function(t) {
      var d = new Date(t.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _tkMonthData[d.getMonth()]++;
      }
    });
    var _tkCurM = new Date().getMonth();
    var tasksChartData = [];
    for (var _tki = Math.max(0, _tkCurM - 5); _tki <= _tkCurM; _tki++) {
      tasksChartData.push({ label: _tkMonths[_tki], value: _tkMonthData[_tki] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(tasks.length), label: 'Задачи', sub: myCount + ' моих / ' + overdueCount + ' просрочено', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>' }),
      chart: (tasksChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(tasksChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Всего', value: tasks.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--info)' },
        { label: 'Активных', value: pending.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск задач...' },
        actions: [
          { id: 'btnAddTask', label: 'Новая задача', icon: '+', cls: 'primary' }
        ]
      },
      items: tasks,
      renderCard: function(t) {
        var priority = t.priority || 'normal';
        var prColor = priority === 'high' ? 'var(--err)' : priority === 'low' ? 'var(--ok)' : undefined;
        return M.mCard({
          id: t.id,
          title: esc(t.title || t.subject || 'Задача'),
          subtitle: fmtDate(t.due_date || t.deadline),
          badge: t.status || '—',
          badgeColor: M.statusColor(t.status),
          accentColor: prColor,
          fields: [
            { label: 'Описание', value: esc((t.description || '—').substring(0, 60)), full: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Мои задачи' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    // v8.1.1 — Task detail view on card tap
    var taskContainer = document.getElementById('layout');
    if (taskContainer) {
      taskContainer.addEventListener('click', function(e) {
        var card = e.target.closest('.m-card[data-id]');
        if (!card) return;
        var taskId = Number(card.dataset.id);
        var t = tasks.find(function(x) { return x.id === taskId; });
        if (!t) return;

        if (navigator.vibrate) navigator.vibrate(10);

        var statusActions = '';
        var st = norm(t.status);
        if (st !== 'done' && st !== 'completed') {
          statusActions = M.mActionRow([
            { id: 'taskStart', label: 'Начать', icon: '▶', cls: 'primary', data: 'data-task-id="' + t.id + '"' },
            { id: 'taskDone', label: 'Завершить', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align:-2px"><polyline points="20 6 9 17 4 12"/></svg>', cls: 'ghost', data: 'data-task-id="' + t.id + '"' }
          ]);
        }

        var assigneeName = '—';
        if (t.assignee_name) assigneeName = t.assignee_name;

        M.showSheet(esc(t.title || t.subject || 'Задача'), M.mDetailFields([
          { label: 'Статус', html: M.mBadge(t.status || '—', M.statusColor(t.status)) },
          { label: 'Приоритет', value: (t.priority === 'high' ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--warn)" stroke-width="2" style="vertical-align:-1px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/></svg> Высокий' : t.priority === 'low' ? '↓ Низкий' : 'Обычный') },
          { label: 'Исполнитель', value: esc(assigneeName) },
          { label: 'Срок', value: fmtDate(t.due_date || t.deadline) || 'Без срока' },
          { label: 'Создано', value: timeAgo(t.created_at) },
          { label: 'Описание', value: esc(t.description || 'Нет описания'), full: true }
        ]) + statusActions);

        // Status change handlers
        var startBtn = document.getElementById('taskStart');
        if (startBtn) startBtn.addEventListener('click', function() {
          authFetch('/api/tasks/' + t.id, { method: 'PUT', body: JSON.stringify({ status: 'in_progress' }) })
            .then(function() {
              M.hideSheet();
              if (navigator.vibrate) navigator.vibrate(15);
              if (AsgardUI && AsgardUI.toast) AsgardUI.toast('Готово', 'Задача взята в работу');
              location.hash = location.hash; // refresh
            })
            .catch(function(err) {
              if (AsgardUI && AsgardUI.toast) AsgardUI.toast('Ошибка', err.message, 'err');
            });
        });
        var doneBtn = document.getElementById('taskDone');
        if (doneBtn) doneBtn.addEventListener('click', function() {
          authFetch('/api/tasks/' + t.id, { method: 'PUT', body: JSON.stringify({ status: 'done' }) })
            .then(function() {
              M.hideSheet();
              if (navigator.vibrate) navigator.vibrate(15);
              if (AsgardUI && AsgardUI.toast) AsgardUI.toast('Готово', 'Задача завершена');
              location.hash = location.hash;
            })
            .catch(function(err) {
              if (AsgardUI && AsgardUI.toast) AsgardUI.toast('Ошибка', err.message, 'err');
            });
        });
      });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  REMINDERS  ██████
