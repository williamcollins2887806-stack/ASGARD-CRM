  patchModule('AsgardInvoicesPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    // Load data via API
    var invoices = [], works = [], customers = [];
    try {
      var headers = { 'Authorization': 'Bearer ' + auth.token };
      var results = await Promise.all([
        fetch('/api/invoices', { headers }).then(function(r) { return r.json(); }),
        fetch('/api/works', { headers }).then(function(r) { return r.json(); }),
        fetch('/api/customers', { headers }).then(function(r) { return r.json(); })
      ]);
      invoices = (results[0].invoices || results[0] || []);
      works = (results[1].works || results[1] || []);
      customers = (results[2].customers || results[2] || []);
    } catch(e) {
      console.error('Load error:', e);
      showError('Не удалось загрузить счета');
    }

    // If data comes from IndexedDB instead
    if (!invoices.length) {
      try { invoices = await AsgardDB.all('invoices') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    }

    var STATUSES = {
      'pending': { label: 'Ожидает', color: 'warn' },
      'partial': { label: 'Частично', color: 'info' },
      'paid':    { label: 'Оплачен', color: 'ok' },
      'cancelled': { label: 'Отменён', color: 'err' }
    };

    // Stats
    var totalAmount = 0, paidAmount = 0, pendingCount = 0;
    invoices.forEach(function(inv) {
      totalAmount += Number(inv.amount || 0);
      paidAmount += Number(inv.paid_amount || 0);
      if (inv.status === 'pending') pendingCount++;
    });

    
    // Monthly invoice data for bar chart
    var invMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var invMonthData = new Array(12).fill(0);
    invoices.forEach(function(inv) {
      var d = new Date(inv.date || inv.created_at);
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        invMonthData[d.getMonth()] += Number(inv.amount || 0);
      }
    });
    var curM = new Date().getMonth();
    var invChartData = [];
    for (var im = Math.max(0, curM - 5); im <= curM; im++) {
      invChartData.push({ label: invMonths[im], value: invMonthData[im] });
    }

        // Sber-style filter pills
    var invFilterPills = M.mFilterPills([
      { label: 'Все', value: '' },
      { label: 'Ожидает', value: 'pending' },
      { label: 'Частично', value: 'partial' },
      { label: 'Оплачен', value: 'paid' }
    ], { id: 'invPills' });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: money(totalAmount), label: 'Общая сумма счетов', sub: paidAmount > 0 ? money(paidAmount) + ' оплачено · ' + invoices.length + ' шт' : invoices.length + ' счетов', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' }),

            chart: (invChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(invChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),
      pills: invFilterPills,
      stats: [
        { label: 'Всего', value: invoices.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>', color: 'var(--info)' },
        { label: 'Сумма', value: money(totalAmount), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--gold)' },
        { label: 'Оплачено', value: money(paidAmount), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' },
        { label: 'Ожидает', value: pendingCount, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', color: 'var(--warn)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск счёта...' },
        filters: [{
          id: 'mFilterStatus',
          options: [
            { value: '', text: 'Все статусы' },
            { value: 'pending', text: 'Ожидает' },
            { value: 'partial', text: 'Частично' },
            { value: 'paid', text: 'Оплачен' }
          ]
        }],
        actions: [
          { id: 'btnAddInvoice', label: 'Новый счёт', icon: '+', cls: 'primary' }
        ]
      },
      items: invoices,
      renderCard: function(inv) {
        var st = STATUSES[inv.status] || { label: inv.status || '—', color: 'draft' };
        var custName = inv.customer_name || '';
        if (!custName && inv.customer_id) {
          var cust = customers.find(function(c) { return c.id === inv.customer_id; });
          if (cust) custName = cust.name || cust.short_name || '';
        }
        return M.mCard({
          id: inv.id,
          title: '№ ' + esc(inv.number || inv.id),
          subtitle: esc(custName),
          badge: st.label,
          badgeColor: st.color,
          fields: [
            { label: 'Дата', value: fmtDate(inv.date || inv.created_at) },
            { label: 'Сумма', value: money(inv.amount), mono: true },
            { label: 'Оплачено', value: money(inv.paid_amount), mono: true },
            { label: 'Остаток', value: money((inv.amount || 0) - (inv.paid_amount || 0)), mono: true }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет счетов'
    });

    await layout(body, { title: title || 'Счета и оплаты' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    // Search
    var searchEl = document.getElementById('mSearch');
    var filterEl = document.getElementById('mFilterStatus');
    function applyFilters() {
      var q = norm(searchEl ? searchEl.value : '');
      var status = filterEl ? filterEl.value : '';
      document.querySelectorAll('.m-card').forEach(function(card) {
        var id = card.dataset.id;
        var inv = invoices.find(function(i) { return String(i.id) === id; });
        if (!inv) return;
        var haystack = norm((inv.number || '') + ' ' + (inv.customer_name || '') + ' ' + (inv.amount || ''));
        var matchQ = !q || haystack.indexOf(q) !== -1;
        var matchStatus = !status || inv.status === status;
        card.style.display = (matchQ && matchStatus) ? '' : 'none';
      });
    }
    if (searchEl) searchEl.addEventListener('input', applyFilters);
    if (filterEl) filterEl.addEventListener('change', applyFilters);
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TENDERS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardTendersPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var byId = {};
    users.forEach(function(u) { byId[u.id] = u; });

    var refsRec = await AsgardDB.get('settings', 'refs');
    var refs = refsRec ? JSON.parse(refsRec.value_json || '{}') : {};
    var tenderStatuses = refs.tender_statuses || [];

    var tenders = await AsgardDB.all('tenders') || [];
    tenders.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    // Stats
    var total = tenders.length;
    var won = tenders.filter(function(t) { return norm(t.tender_status) === 'выигран'; }).length;
    var inWork = tenders.filter(function(t) { return ['в работе', 'на согласовании', 'отправлен'].indexOf(norm(t.tender_status)) !== -1; }).length;
    var totalAmount = 0;
    tenders.forEach(function(t) { totalAmount += Number(t.tender_price || 0); });

    var statusFilters = [{ value: '', text: 'Все статусы' }];
    tenderStatuses.forEach(function(s) { statusFilters.push({ value: s, text: s }); });

    
    // Monthly tender data for bar chart
    var tendMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var tendMonthData = new Array(12).fill(0);
    tenders.forEach(function(t) {
      var d = new Date(t.created_at || t.docs_deadline);
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        tendMonthData[d.getMonth()] += Number(t.tender_price || 0);
      }
    });
    var tendCurM = new Date().getMonth();
    var tendChartData = [];
    for (var tm = Math.max(0, tendCurM - 5); tm <= tendCurM; tm++) {
      tendChartData.push({ label: tendMonths[tm], value: tendMonthData[tm] });
    }

        // Sber-style filter pills for tenders
    var tendFilterPills = M.mFilterPills([
      { label: 'Все', value: '' },
      { label: 'В работе', value: 'in_work' },
      { label: 'Выигран', value: 'won' },
      { label: 'На согласов.', value: 'approval' }
    ], { id: 'tendPills' });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: money(totalAmount), label: 'Портфель тендеров', sub: won + ' выиграно из ' + total, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>' }),
      chart: (tendChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(tendChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Всего', value: total, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' },
        { label: 'Выиграно', value: won, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>', color: 'var(--ok-t)' },
        { label: 'В работе', value: inWork, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--gold)' },
        { label: 'Сумма', value: money(totalAmount), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--purple-l)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Заказчик, тендер, тег...' },
        filters: [
          { id: 'mFilterStatus', options: statusFilters }
        ],
        actions: [
          { id: 'btnNew', label: 'Новый тендер', icon: '+', cls: 'primary' }
        ]
      },
      items: tenders,
      renderCard: function(t) {
        var pm = byId[t.responsible_pm_id] || {};
        var color = M.statusColor(t.tender_status);
        return M.mCard({
          id: t.id,
          title: esc(t.customer_name || ''),
          subtitle: esc(t.tender_title || ''),
          badge: t.tender_status || 'Черновик',
          badgeColor: color,
          fields: [
            { label: 'РП', value: esc(pm.name || '—') },
            { label: 'Тип', value: esc(t.tender_type || '—') },
            { label: 'Сумма', value: money(t.tender_price), mono: true },
            { label: 'Дедлайн', value: fmtDate(t.docs_deadline) },
            { label: 'Сроки', value: fmtDateShort(t.work_start_plan) + ' — ' + fmtDateShort(t.work_end_plan) },
            { label: 'Период', value: esc(t.period || '—') }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет тендеров'
    });

    await layout(body, { title: title || 'Сага Тендеров' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    // Search & filters
    var searchEl = document.getElementById('mSearch');
    var filterEl = document.getElementById('mFilterStatus');
    function applyFilters() {
      var q = norm(searchEl ? searchEl.value : '');
      var status = filterEl ? filterEl.value : '';
      document.querySelectorAll('.m-card').forEach(function(card) {
        var id = card.dataset.id;
        var t = tenders.find(function(x) { return String(x.id) === id; });
        if (!t) return;
        var hay = norm((t.customer_name || '') + ' ' + (t.tender_title || '') + ' ' + (t.group_tag || '') + ' ' + (t.purchase_url || ''));
        var matchQ = !q || hay.indexOf(q) !== -1;
        var matchStatus = !status || t.tender_status === status;
        card.style.display = (matchQ && matchStatus) ? '' : 'none';
      });
    }
    if (searchEl) searchEl.addEventListener('input', applyFilters);
    if (filterEl) filterEl.addEventListener('change', applyFilters);

    // Card click
    document.getElementById('mobileList')?.addEventListener('click', function(e) {
      var card = e.target.closest('.m-card[data-id]');
      if (!card) return;
      // Open tender detail in bottom sheet
      var tid = Number(card.dataset.id);
      var t = tenders.find(function(x) { return x.id === tid; });
      if (!t) return;
      var pm = byId[t.responsible_pm_id] || {};
      var createdBy = byId[t.created_by_user_id] || {};
      M.showSheet(esc(t.customer_name || 'Тендер'), M.mDetailFields([
        { label: 'Тендер', value: t.tender_title },
        { label: 'Статус', html: M.mBadge(t.tender_status, M.statusColor(t.tender_status)) },
        { label: 'Тип', value: t.tender_type },
        { label: 'Сумма', value: money(t.tender_price) },
        { label: 'РП', value: pm.name || '—' },
        { label: 'Период', value: t.period },
        { label: 'Дедлайн документов', value: fmtDate(t.docs_deadline) },
        { label: 'Сроки работ', value: fmtDate(t.work_start_plan) + ' — ' + fmtDate(t.work_end_plan) },
        { label: 'Внёс', value: createdBy.name || '—' },
        { label: 'Тег', value: t.group_tag || '—' },
        { label: 'Ссылка', value: t.purchase_url || '—', full: true },
        { label: 'Комментарий ТО', value: t.tender_comment_to || '—', full: true }
      ]) + M.mActionRow([
        { id: 'sheetEdit', label: 'Редактировать', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>', cls: 'ghost' },
        { id: 'sheetCalc', label: 'В просчёт', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>', cls: 'primary' }
      ]));
    });

    // New tender button
    var btnNew = document.getElementById('btnNew');
    if (btnNew) btnNew.addEventListener('click', function() { location.hash = '#/tenders?action=new'; });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  APPROVALS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardApprovalsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var byId = {};
    users.forEach(function(u) { byId[u.id] = u; });

    var tenders = await AsgardDB.all('tenders') || [];
    var tendById = {};
    tenders.forEach(function(t) { tendById[t.id] = t; });

    var estimates = await AsgardDB.all('estimates') || [];
    // Show items on approval by default
    var pending = estimates.filter(function(e) { return e.approval_status === 'sent'; });
    var approved = estimates.filter(function(e) { return e.approval_status === 'approved'; });
    var rework = estimates.filter(function(e) { return e.approval_status === 'rework'; });

        // Monthly approvals chart
    var _aMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _aMonthData = new Array(12).fill(0);
    items.forEach(function(a) {
      var d = new Date(a.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _aMonthData[d.getMonth()]++;
      }
    });
    var _aCurM = new Date().getMonth();
    var approvalsChartData = [];
    for (var _ai = Math.max(0, _aCurM - 5); _ai <= _aCurM; _ai++) {
      approvalsChartData.push({ label: _aMonths[_ai], value: _aMonthData[_ai] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(pendingCount || 0), label: 'Ожидают решения', sub: items.length + ' всего заявок', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' }),
      chart: (approvalsChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(approvalsChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'На согласовании', value: pending.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', color: 'var(--gold)' },
        { label: 'Согласовано', value: approved.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' },
        { label: 'На доработку', value: rework.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>', color: 'var(--warn)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Заказчик / тендер / РП...' },
        chips: [
          { id: 'sent', label: 'На согласовании', active: true },
          { id: 'all', label: 'Все решения' }
        ]
      },
      items: pending,
      renderCard: function(e) {
        var t = tendById[e.tender_id] || {};
        var pm = byId[e.pm_id] || {};
        var marginPct = (e.price_tkp && e.cost_plan) ? Math.round(((e.price_tkp - e.cost_plan) / e.price_tkp) * 100) : null;

        return M.mCard({
          id: e.id,
          title: esc(t.customer_name || ''),
          subtitle: esc(t.tender_title || ''),
          badge: e.approval_status === 'sent' ? 'На согласовании' : e.approval_status,
          badgeColor: e.approval_status === 'sent' ? 'warn' : M.statusColor(e.approval_status),
          accentColor: e.approval_status === 'sent' ? 'var(--gold)' : undefined,
          fields: [
            { label: 'РП', value: esc(pm.name || '—') },
            { label: 'Версия', value: 'v' + (e.version_no || 0) },
            { label: 'Цена ТКП', value: money(e.price_tkp), mono: true },
            { label: 'Себест.', value: money(e.cost_plan), mono: true },
            { label: 'Маржа', value: marginPct != null ? marginPct + '%' : '—' },
            { label: 'Отправлено', value: fmtDate(e.sent_for_approval_at) }
          ],
          footer: '<button class="m-action-btn m-btn-ok" data-act="approve"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#21bf73" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Согласовать</button>' +
                  '<button class="m-action-btn m-btn-err" data-act="rework"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg> Доработка</button>',
          onClick: true
        });
      },
      emptyText: 'Нет просчётов на согласовании'
    });

    await layout(body, { title: title || 'Согласование' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    // Chip filter
    document.querySelectorAll('.m-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        document.querySelectorAll('.m-chip').forEach(function(c) { c.classList.remove('active'); });
        chip.classList.add('active');
        var mode = chip.dataset.chip;
        var items = mode === 'all' ? estimates.filter(function(e) { return ['sent', 'approved', 'rework', 'question'].indexOf(e.approval_status) !== -1; }) : pending;
        var listEl = document.getElementById('mobileList');
        if (listEl) {
          listEl.innerHTML = items.length ? items.map(function(e) {
            var t = tendById[e.tender_id] || {};
            var pm = byId[e.pm_id] || {};
            var marginPct = (e.price_tkp && e.cost_plan) ? Math.round(((e.price_tkp - e.cost_plan) / e.price_tkp) * 100) : null;
            return M.mCard({
              id: e.id,
              title: esc(t.customer_name || ''),
              subtitle: esc(t.tender_title || ''),
              badge: e.approval_status || '',
              badgeColor: M.statusColor(e.approval_status),
              fields: [
                { label: 'РП', value: esc(pm.name || '—') },
                { label: 'Версия', value: 'v' + (e.version_no || 0) },
                { label: 'Цена', value: money(e.price_tkp), mono: true },
                { label: 'Маржа', value: marginPct != null ? marginPct + '%' : '—' }
              ],
              onClick: true
            });
          }).join('') : M.mEmpty('Нет данных');
        }
      });
    });

    // Search
    var searchEl = document.getElementById('mSearch');
    if (searchEl) {
      searchEl.addEventListener('input', function() {
        _debounce('search3', function() {
        var q = norm(searchEl.value);
        document.querySelectorAll('.m-card').forEach(function(card) {
          var id = Number(card.dataset.id);
          var e = estimates.find(function(x) { return x.id === id; });
          if (!e) return;
          var t = tendById[e.tender_id] || {};
          var pm = byId[e.pm_id] || {};
          var hay = norm((t.customer_name || '') + ' ' + (t.tender_title || '') + ' ' + (pm.name || ''));
          card.style.display = (!q || hay.indexOf(q) !== -1) ? '' : 'none';
        });
      }, 250);
        });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PM WORKS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardPmWorksPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var allWorks = await AsgardDB.all('works') || [];
    var works = (user.role === 'PM') ? allWorks.filter(function(w) { return w.pm_id === user.id; }) : allWorks;
    works.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var refsRec = await AsgardDB.get('settings', 'refs');
    var refs = refsRec ? JSON.parse(refsRec.value_json || '{}') : {};

    // KPI stats
    var totalWorks = works.length;
    var activeWorks = works.filter(function(w) { return ['в работе', 'монтаж', 'пуско-наладка'].indexOf(norm(w.work_status)) !== -1; }).length;
    var totalContract = 0, totalCost = 0;
    works.forEach(function(w) {
      totalContract += Number(w.contract_value || 0);
      totalCost += Number(w.cost_fact || w.cost_plan || 0);
    });

    var statusFilters = [{ value: '', text: 'Все статусы' }];
    (refs.work_statuses || []).forEach(function(s) { statusFilters.push({ value: s, text: s }); });

        // Monthly works chart
    var _wMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _wMonthData = new Array(12).fill(0);
    works.forEach(function(w) {
      var d = new Date(w.created_at || w.work_start || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _wMonthData[d.getMonth()] += Number(w.contract_value || 0);
      }
    });
    var _wCurM = new Date().getMonth();
    var worksChartData = [];
    for (var _wi = Math.max(0, _wCurM - 5); _wi <= _wCurM; _wi++) {
      worksChartData.push({ label: _wMonths[_wi], value: _wMonthData[_wi] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(works.length), label: 'Работы по объектам', sub: activeCount + ' активных', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>' }),
      chart: (worksChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(worksChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Работы', value: totalWorks, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' },
        { label: 'Активных', value: activeWorks, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>', color: 'var(--ok-t)' },
        { label: 'Контракты', value: money(totalContract), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--gold)' },
        { label: 'Себестоим.', value: money(totalCost), icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>', color: 'var(--purple-l)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Заказчик / работа...' },
        filters: [
          { id: 'mFilterStatus', options: statusFilters }
        ],
        actions: [
          { id: 'btnGantt', label: 'Гантт', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>', cls: 'ghost' }
        ]
      },
      items: works,
      renderCard: function(w) {
        // Progress calculation
        var progress = 0;
        if (w.start_in_work_date && w.end_plan) {
          var start = new Date(w.start_in_work_date).getTime();
          var end = new Date(w.end_plan).getTime();
          var now = Date.now();
          if (end > start) progress = Math.min(100, Math.max(0, Math.round((now - start) / (end - start) * 100)));
        }
        if (norm(w.work_status) === 'завершено' || norm(w.work_status) === 'закрыто') progress = 100;

        var progressHtml = M.mProgressBar(progress, progress === 100 ? 'var(--ok-t)' : progress > 80 ? 'var(--warn)' : 'var(--info-t)');

        return M.mCard({
          id: w.id,
          title: esc(w.customer_name || ''),
          subtitle: esc(w.work_title || w.tender_title || ''),
          badge: w.work_status || 'Новая',
          badgeColor: M.statusColor(w.work_status),
          fields: [
            { label: 'Контракт', value: money(w.contract_value), mono: true },
            { label: 'Себестоим.', value: money(w.cost_fact || w.cost_plan), mono: true },
            { label: 'Начало', value: fmtDateShort(w.start_in_work_date || w.start_plan) },
            { label: 'Окончание', value: fmtDateShort(w.end_plan) },
            { label: 'Прогресс', value: progressHtml, full: true }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет работ'
    });

    await layout(body, { title: title || 'Мои работы' });

    // Search & filter
    var searchEl = document.getElementById('mSearch');
    var filterEl = document.getElementById('mFilterStatus');
    function applyFilters() {
      var q = norm(searchEl ? searchEl.value : '');
      var status = filterEl ? filterEl.value : '';
      document.querySelectorAll('.m-card').forEach(function(card) {
        var id = Number(card.dataset.id);
        var w = works.find(function(x) { return x.id === id; });
        if (!w) return;
        var hay = norm((w.customer_name || '') + ' ' + (w.work_title || '') + ' ' + (w.tender_title || ''));
        var matchQ = !q || hay.indexOf(q) !== -1;
        var matchStatus = !status || w.work_status === status;
        card.style.display = (matchQ && matchStatus) ? '' : 'none';
      });
    }
    if (searchEl) searchEl.addEventListener('input', applyFilters);
    if (filterEl) filterEl.addEventListener('change', applyFilters);

    // Card click
    document.getElementById('mobileList')?.addEventListener('click', function(e) {
      var card = e.target.closest('.m-card[data-id]');
      if (card) {
        location.hash = '#/pm-works?id=' + card.dataset.id;
      }
    });

    // Gantt button
    var btnG = document.getElementById('btnGantt');
    if (btnG) btnG.addEventListener('click', function() { location.hash = '#/gantt-works'; });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  ALL WORKS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardAllWorksPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var works = await AsgardDB.all('works') || [];
    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var byId = {};
    users.forEach(function(u) { byId[u.id] = u; });

    works.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(works.length), label: 'Все работы', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>' }),

      stats: [
        { label: 'Всего', value: works.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск работ...' }
      },
      items: works,
      renderCard: function(w) {
        var pm = byId[w.pm_id] || {};
        return M.mCard({
          id: w.id,
          title: esc(w.customer_name || ''),
          subtitle: esc(w.work_title || ''),
          badge: w.work_status || '—',
          badgeColor: M.statusColor(w.work_status),
          fields: [
            { label: 'РП', value: esc(pm.name || '—') },
            { label: 'Контракт', value: money(w.contract_value), mono: true },
            { label: 'Начало', value: fmtDateShort(w.start_in_work_date) },
            { label: 'Окончание', value: fmtDateShort(w.end_plan) }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Свод Контрактов' });

    // Search
    var searchEl = document.getElementById('mSearch');
    if (searchEl) {
      searchEl.addEventListener('input', function() {
        _debounce('search2', function() {
        var q = norm(searchEl.value);
        document.querySelectorAll('.m-card').forEach(function(card) {
          var id = Number(card.dataset.id);
          var w = works.find(function(x) { return x.id === id; });
          if (!w) return;
          var hay = norm((w.customer_name || '') + ' ' + (w.work_title || ''));
          card.style.display = (!q || hay.indexOf(q) !== -1) ? '' : 'none';
        });
      }, 250);
        });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CONTRACTS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardContractsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var contracts = await AsgardDB.all('contracts') || [];
    contracts.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

        var contractTotalSum = 0; contracts.forEach(function(c) { contractTotalSum += Number(c.amount || c.contract_sum || 0); });
    // Monthly contracts chart
    var _cMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _cMonthData = new Array(12).fill(0);
    contracts.forEach(function(c) {
      var d = new Date(c.created_at || c.date || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _cMonthData[d.getMonth()] += Number(c.amount || c.contract_sum || 0);
      }
    });
    var _cCurM = new Date().getMonth();
    var contractsChartData = [];
    for (var _ci = Math.max(0, _cCurM - 5); _ci <= _cCurM; _ci++) {
      contractsChartData.push({ label: _cMonths[_ci], value: _cMonthData[_ci] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: money(contractTotalSum), label: 'Сумма договоров', sub: contracts.length + ' договоров', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' }),
      chart: (contractsChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(contractsChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Договоров', value: contracts.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>', color: 'var(--info)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск договоров...' }
      },
      items: contracts,
      renderCard: function(c) {
        return M.mCard({
          id: c.id,
          title: esc(c.number || c.name || 'Договор #' + c.id),
          subtitle: esc(c.counterparty || c.customer_name || ''),
          badge: c.status || '—',
          badgeColor: M.statusColor(c.status),
          fields: [
            { label: 'Дата', value: fmtDate(c.date || c.created_at) },
            { label: 'Сумма', value: money(c.amount), mono: true },
            { label: 'Срок', value: fmtDate(c.end_date) },
            { label: 'Тип', value: esc(c.type || '—') }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Реестр договоров' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  ACTS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardActsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var acts = await AsgardDB.all('acts') || [];
    acts.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

        // Monthly acts chart
    var _actMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _actMonthData = new Array(12).fill(0);
    items.forEach(function(a) {
      var d = new Date(a.date || a.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _actMonthData[d.getMonth()]++;
      }
    });
    var _actCurM = new Date().getMonth();
    var actsChartData = [];
    for (var _acti = Math.max(0, _actCurM - 5); _acti <= _actCurM; _acti++) {
      actsChartData.push({ label: _actMonths[_acti], value: _actMonthData[_acti] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Акты выполненных работ', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/></svg>' }),
      chart: (actsChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(actsChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Актов', value: acts.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>', color: 'var(--info)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск актов...' } },
      items: acts,
      renderCard: function(a) {
        return M.mCard({
          id: a.id,
          title: esc(a.number || 'Акт #' + a.id),
          subtitle: esc(a.customer_name || a.counterparty || ''),
          badge: a.status || '—',
          badgeColor: M.statusColor(a.status),
          fields: [
            { label: 'Дата', value: fmtDate(a.date || a.created_at) },
            { label: 'Сумма', value: money(a.amount), mono: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Акты' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CASH  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardCashPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var transactions = await AsgardDB.all('cash_transactions') || [];
    transactions.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    var totalIn = 0, totalOut = 0;
    transactions.forEach(function(t) {
      var amt = Number(t.amount || 0);
      if (t.type === 'income' || amt > 0) totalIn += Math.abs(amt);
      else totalOut += Math.abs(amt);
    });

        var cashTotalSum = 0; items.forEach(function(c) { cashTotalSum += Number(c.amount || 0); });

    // Monthly cash flow for bar chart
    var cashMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var cashMonthIn = new Array(12).fill(0);
    var cashMonthOut = new Array(12).fill(0);
    items.forEach(function(t) {
      var d = new Date(t.date || t.created_at);
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        var amt = Math.abs(Number(t.amount || 0));
        if (t.type === 'income' || Number(t.amount || 0) > 0) cashMonthIn[d.getMonth()] += amt;
        else cashMonthOut[d.getMonth()] += amt;
      }
    });
    var cashCurM = new Date().getMonth();
    var cashChartData = [];
    for (var cm = Math.max(0, cashCurM - 5); cm <= cashCurM; cm++) {
      cashChartData.push({ label: cashMonths[cm], value: cashMonthIn[cm] - cashMonthOut[cm] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: money(totalIn - totalOut), label: 'Баланс движения средств', sub: money(totalIn) + ' приход / ' + money(totalOut) + ' расход', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' }),
      chart: (cashChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(cashChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Операций', value: transactions.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>', color: 'var(--info)' },
        { label: 'Приход', value: money(totalIn), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>', color: 'var(--ok-t)' },
        { label: 'Расход', value: money(totalOut), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>', color: 'var(--err-t)' },
        { label: 'Баланс', value: money(totalIn - totalOut), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск операций...' },
        actions: [
          { id: 'btnAddCash', label: 'Новая операция', icon: '+', cls: 'primary' }
        ]
      },
      items: transactions,
      renderCard: function(t) {
        var isIncome = t.type === 'income' || Number(t.amount || 0) > 0;
        return M.mCard({
          id: t.id,
          title: esc(t.description || t.purpose || 'Операция'),
          subtitle: timeAgo(t.date || t.created_at),
          badge: isIncome ? 'Приход' : 'Расход',
          badgeColor: isIncome ? 'ok' : 'err',
          fields: [
            { label: 'Сумма', value: money(Math.abs(t.amount || 0)), mono: true },
            { label: 'Категория', value: esc(t.category || '—') }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Касса' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  HR REQUESTS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardHrRequestsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var requests = await AsgardDB.all('hr_requests') || [];
    requests.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

        // Monthly HR requests chart
    var _hrMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _hrMonthData = new Array(12).fill(0);
    items.forEach(function(h) {
      var d = new Date(h.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _hrMonthData[d.getMonth()]++;
      }
    });
    var _hrCurM = new Date().getMonth();
    var hrChartData = [];
    for (var _hri = Math.max(0, _hrCurM - 5); _hri <= _hrCurM; _hri++) {
      hrChartData.push({ label: _hrMonths[_hri], value: _hrMonthData[_hri] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'HR заявки', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>' }),
      chart: (hrChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(hrChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Заявок', value: requests.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>', color: 'var(--info)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск заявок...' } },
      items: requests,
      renderCard: function(r) {
        return M.mCard({
          id: r.id,
          title: esc(r.employee_name || r.fio || 'Заявка #' + r.id),
          subtitle: esc(r.type || r.request_type || ''),
          badge: r.status || '—',
          badgeColor: M.statusColor(r.status),
          fields: [
            { label: 'Дата', value: fmtDate(r.date || r.created_at) },
            { label: 'Комментарий', value: esc((r.comment || r.description || '—').substring(0, 50)), full: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Заявки персонала' });
  });


