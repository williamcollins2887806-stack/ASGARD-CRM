  patchModule('AsgardCashAdminPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var items = [];
    try { items = await AsgardDB.all('cash_transactions') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    items.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });
    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Финансовые операции', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' }),

      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(t) {
        var isIncome = t.type === 'income' || Number(t.amount || 0) > 0;
        return M.mCard({
          id: t.id, title: esc(t.description || t.purpose || 'Операция'),
          subtitle: timeAgo(t.date || t.created_at),
          badge: isIncome ? 'Приход' : 'Расход', badgeColor: isIncome ? 'ok' : 'err',
          fields: [
            { label: 'Сумма', value: money(Math.abs(t.amount || 0)), mono: true },
            { label: 'Статус', value: esc(t.status || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Касса (управление)' });
  });

  /* OFFICE SCHEDULE — мобильный вид графика офиса */
  patchModule('AsgardOfficeSchedulePage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    users.sort(function(a, b) { return String(a.name || '').localeCompare(String(b.name || ''), 'ru'); });

    var today = new Date();
    var dayNames = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб'];
    var currentDay = dayNames[today.getDay()];

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'График офиса', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>' }),

      stats: [
        { label: 'Сотрудников', value: users.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', color: 'var(--info)' },
        { label: 'Сегодня', value: currentDay + ', ' + today.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' }), icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск сотрудника...' } },
      items: users,
      renderCard: function(u) {
        var schedule = u.schedule || u.work_schedule || {};
        var todayKey = ['sun','mon','tue','wed','thu','fri','sat'][today.getDay()];
        var todayStatus = schedule[todayKey] || 'Офис';
        return M.mCard({
          id: u.id,
          title: esc(u.name || u.fio || '—'),
          subtitle: esc(u.position || u.role || ''),
          badge: todayStatus === 'off' ? 'Выходной' : todayStatus === 'remote' ? 'Удалённо' : 'Офис',
          badgeColor: todayStatus === 'off' ? 'draft' : todayStatus === 'remote' ? 'info' : 'ok',
          fields: [
            { label: 'Отдел', value: esc(u.department || '—') },
            { label: 'Телефон', value: esc(u.phone || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'График: Офис' });
  });

  /* STAFF SCHEDULE — мобильный вид графика рабочих */
  patchModule('AsgardStaffSchedulePage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var employees = [];
    try { employees = await AsgardDB.all('employees') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    employees.sort(function(a, b) { return String(a.fio || '').localeCompare(String(b.fio || ''), 'ru'); });

    var today = new Date();
    var working = employees.filter(function(e) {
      var s = (e.availability_status || '').toLowerCase();
      return s === 'на объекте' || s === 'свободен' || s === 'в дороге';
    });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'График сотрудников', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>' }),

      stats: [
        { label: 'Всего', value: employees.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>', color: 'var(--info)' },
        { label: 'На смене', value: working.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--ok-t)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: employees,
      renderCard: function(e) {
        var status = e.availability_status || '—';
        var statusColor = status.toLowerCase() === 'свободен' ? 'ok' : status.toLowerCase() === 'на объекте' ? 'info' : status.toLowerCase() === 'в дороге' ? 'warn' : 'draft';
        return M.mCard({
          id: e.id,
          title: esc(e.fio || '—'),
          subtitle: esc(e.specialization || e.role_tag || ''),
          badge: status, badgeColor: statusColor,
          fields: [
            { label: 'Разряд', value: esc(e.grade || '—') },
            { label: 'Город', value: esc(e.city || '—') },
            { label: 'Объект', value: esc(e.current_object || '—') },
            { label: 'Телефон', value: esc(e.phone || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'График: Рабочие' });
  });

  /* Equipment */
  patchModule('AsgardEquipmentPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var items = [];
    try { items = await AsgardDB.all('equipment') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Оборудование', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="8" x="5" y="2" rx="2"/><rect width="20" height="8" x="2" y="14" rx="2"/><path d="M6 18h2"/><path d="M12 18h6"/></svg>' }),

      stats: [{ label: 'Единиц', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(e) {
        return M.mCard({
          id: e.id, title: esc(e.name || e.title || ''),
          subtitle: esc(e.category || ''),
          badge: e.status || '—', badgeColor: M.statusColor(e.status),
          fields: [
            { label: 'Инв. №', value: esc(e.inv_number || e.serial || '—') },
            { label: 'Расположение', value: esc(e.location || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Моё оборудование' });
  });

  /* Funnel — Sber-style воронка продаж */
  patchModule('AsgardFunnelPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var tenders = await AsgardDB.all('tenders') || [];
    var stages = {};
    tenders.forEach(function(t) {
      var st = t.tender_status || 'Черновик';
      if (!stages[st]) stages[st] = [];
      stages[st].push(t);
    });
    var stageList = Object.keys(stages);
    var totalSum = 0;
    tenders.forEach(function(t) { totalSum += Number(t.tender_price || 0); });
    var won = tenders.filter(function(t) { return norm(t.tender_status) === 'выигран'; });
    var wonSum = 0;
    won.forEach(function(t) { wonSum += Number(t.tender_price || 0); });
    var convPct = tenders.length > 0 ? Math.round((won.length / tenders.length) * 100) : 0;

    var body = '';

    // Big number — total pipeline
    body += M.mBigNumber({ value: money(totalSum), subtitle: tenders.length + ' тендеров в воронке' });

    // Widget grid: won + conversion
    body += M.mWidgetGrid([
      { title: 'Выиграно', value: money(wonSum), icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t)" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>', subtitle: won.length + ' тендеров' },
      { title: 'Конверсия', value: convPct + '%', icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>', subtitle: won.length + ' из ' + tenders.length }
    ]);

    // Funnel stages as category items (Sber-style)
    var stageColors = ['rgba(33,191,115,0.15)', 'rgba(88,166,255,0.15)', 'rgba(255,193,7,0.15)', 'rgba(156,120,255,0.15)', 'rgba(239,68,68,0.15)'];
    var stageContent = '';
    stageList.forEach(function(st, i) {
      var stageSum = 0;
      stages[st].forEach(function(t) { stageSum += Number(t.tender_price || 0); });
      stageContent += M.mCategoryItem({
        name: st,
        amount: stages[st].length + ' тендеров',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
        iconBg: stageColors[i % stageColors.length],
        right: { value: money(stageSum), sub: totalSum > 0 ? Math.round((stageSum / totalSum) * 100) + '%' : '0%' }
      });
    });
    body += M.mSection('Этапы воронки', stageContent);

    // Detailed lists per stage (collapsible)
    stageList.forEach(function(st) {
      body += M.mSection(st + ' (' + stages[st].length + ')', M.mList(stages[st].slice(0, 5), function(t) {
        return M.mCard({
          id: t.id, title: esc(t.customer_name || ''),
          subtitle: esc(t.tender_title || ''),
          fields: [
            { label: 'Сумма', value: money(t.tender_price), mono: true }
          ], onClick: true
        });
      }), { collapsible: true, collapsed: true });
    });

    await layout(body, { title: title || 'Воронка продаж' });
  });

  /* TMC Requests */
  patchModule('AsgardTmcRequestsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var items = [];
    try { items = await AsgardDB.all('tmc_requests') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    items.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });
    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Заявки на ТМЦ', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>' }),

      stats: [{ label: 'Заявок', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(r) {
        return M.mCard({
          id: r.id, title: esc(r.title || r.name || 'Заявка #' + r.id),
          subtitle: esc(r.requester || ''),
          badge: r.status || '—', badgeColor: M.statusColor(r.status),
          fields: [
            { label: 'Дата', value: fmtDate(r.created_at) },
            { label: 'Сумма', value: money(r.amount), mono: true }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Заявки на ТМЦ' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     TIER 5 — SKIP / DESKTOP-ONLY (redirect or simple placeholder)
     Backup, Diag, Sync, Mango — admin tools, Gantt/Calendar — complex
     ═══════════════════════════════════════════════════════════════════════════ */
  /* Backup и Diag — единственные модули, где "desktop-only" допустим (admin tools) */
  ['AsgardBackupPage', 'AsgardDiagPage'].forEach(function(name) {
    patchModule(name, async function({ layout, title }) {
      var auth = await AsgardAuth.requireUser();
      if (!auth) { location.hash = '#/login'; return; }
      var body = M.mTablePage({
        content: M.mEmpty('Администрирование доступно на компьютере', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>')
      });
      await layout(body, { title: title || name.replace('Asgard', '').replace('Page', '') });
    });
  });

  /* CALENDAR — мобильный Agenda View (события по дням) */
  patchModule('AsgardCalendarPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var events = [];
    try { events = await AsgardDB.all('calendar_events') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var userMap = {};
    users.forEach(function(u) { userMap[u.id] = u; });

    // Сортируем по дате/времени
    events.sort(function(a, b) {
      var da = a.date || a.created_at || '';
      var db = b.date || b.created_at || '';
      return String(da).localeCompare(String(db)) || String(a.time || '').localeCompare(String(b.time || ''));
    });

    // Группируем по дню
    var today = new Date(); today.setHours(0,0,0,0);
    var upcoming = events.filter(function(e) {
      try { return new Date(e.date) >= today; } catch(x) { return true; }
    });
    if (upcoming.length === 0) upcoming = events.slice(-20).reverse();

    var grouped = {};
    upcoming.forEach(function(ev) {
      var day = ev.date ? ev.date.substring(0, 10) : 'Без даты';
      if (!grouped[day]) grouped[day] = [];
      grouped[day].push(ev);
    });

    var TYPE_ICONS = { meeting: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>', call: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>', visit: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>', deadline: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', reminder: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>', other: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/></svg>' };
    var TYPE_COLORS = { meeting: 'info', call: 'ok', visit: 'gold', deadline: 'err', reminder: 'warn', other: 'draft' };

    var sectionsHtml = '';
    Object.keys(grouped).forEach(function(day) {
      var dayLabel = day;
      try {
        var d = new Date(day);
        var todayStr = today.toISOString().substring(0,10);
        var tomorrowStr = new Date(today.getTime() + 86400000).toISOString().substring(0,10);
        if (day === todayStr) dayLabel = 'Сегодня';
        else if (day === tomorrowStr) dayLabel = 'Завтра';
        else dayLabel = d.toLocaleDateString('ru-RU', { weekday: 'short', day: 'numeric', month: 'long' });
      } catch(x) {}

      var cardsHtml = grouped[day].map(function(ev) {
        var icon = TYPE_ICONS[ev.type] || '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/></svg>';
        var pNames = '';
        if (Array.isArray(ev.participants)) {
          pNames = ev.participants.map(function(pid) { return (userMap[pid] || {}).name || pid; }).join(', ');
        }
        return M.mCard({
          id: ev.id,
          title: icon + ' ' + esc(ev.title || 'Событие'),
          subtitle: ev.time ? ev.time.substring(0, 5) : '',
          badge: ev.type || '', badgeColor: TYPE_COLORS[ev.type] || 'draft',
          fields: [
            { label: 'Описание', value: esc((ev.description || '').substring(0, 80)), full: ev.description },
            pNames ? { label: 'Участники', value: esc(pNames) } : null
          ].filter(Boolean),
          onClick: true
        });
      }).join('');
      sectionsHtml += M.mSection(dayLabel, cardsHtml);
    });

    if (!sectionsHtml) sectionsHtml = M.mEmpty('Нет предстоящих событий', '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>');

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mStats([
        { label: 'Всего', value: events.length, icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>', color: 'var(--info)' },
        { label: 'Сегодня', value: (grouped[today.toISOString().substring(0,10)] || []).length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/></svg>', color: 'var(--gold)' }
      ]) +
      M.mToolbar({ search: { id: 'mSearch', placeholder: 'Поиск событий...' } }) +
      sectionsHtml +
    '</div>';
    await layout(body, { title: title || 'Календарь' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     TIER 3 — FORMS (Settings, Integrations, Mail Settings, PM Calcs, etc.)
     ═══════════════════════════════════════════════════════════════════════════ */

  /* SETTINGS — полноценная мобильная версия настроек */
  patchModule('AsgardSettingsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    // Загружаем основные настройки
    var appSettings = {};
    try { appSettings = await AsgardDB.get('settings', 'app') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var companySettings = {};
    try { companySettings = await AsgardDB.get('settings', 'company') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var uiSettings = {};
    try { uiSettings = await AsgardDB.get('settings', 'ui') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var companySection = M.mSection('Компания', M.mForm([
      { label: 'Название компании', id: 'sCompanyName', type: 'text', value: companySettings.name || '', placeholder: 'ООО «Название»' },
      { label: 'ИНН', id: 'sINN', type: 'text', value: companySettings.inn || '', placeholder: '1234567890' },
      { label: 'Email компании', id: 'sEmail', type: 'email', value: companySettings.email || '', placeholder: 'info@company.ru' },
      { label: 'Телефон', id: 'sPhone', type: 'tel', value: companySettings.phone || '', placeholder: '+7 (999) 123-45-67' }
    ], { submitLabel: 'Сохранить', submitId: 'btnSaveCompany' }));

    var uiSection = M.mSection('Интерфейс', '<div class="m-card">' +
      '<div class="m-card-fields">' +
        '<div class="m-field"><span class="m-field-label">Тема</span><span class="m-field-value">' + esc(uiSettings.theme || 'dark') + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Язык</span><span class="m-field-value">' + esc(uiSettings.language || 'ru') + '</span></div>' +
      '</div></div>');

    var linksSection = M.mSection('Быстрые ссылки',
      M.mCard({ title: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Telegram-бот', subtitle: 'Настройка уведомлений', onClick: true, id: 'link-telegram' }) +
      M.mCard({ title: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Синхронизация', subtitle: 'PostgreSQL', onClick: true, id: 'link-sync' }) +
      M.mCard({ title: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Телефония', subtitle: 'Mango Office', onClick: true, id: 'link-mango' })
    );

    var body = '<div class="m-page" data-mobile-native="1">' + companySection + uiSection + linksSection + '</div>';
    await layout(body, { title: title || 'Настройки' });

    // Обработчики ссылок
    document.getElementById('link-telegram')?.addEventListener('click', function() { location.hash = '#/telegram'; });
    document.getElementById('link-sync')?.addEventListener('click', function() { location.hash = '#/sync'; });
    document.getElementById('link-mango')?.addEventListener('click', function() { location.hash = '#/mango'; });

    // Сохранение компании
    document.getElementById('btnSaveCompany')?.addEventListener('click', async function() {
      try {
        var obj = {
          key: 'company',
          name: document.getElementById('sCompanyName')?.value || '',
          inn: document.getElementById('sINN')?.value || '',
          email: document.getElementById('sEmail')?.value || '',
          phone: document.getElementById('sPhone')?.value || ''
        };
        await AsgardDB.put('settings', obj);
        if (M.showToast) M.showToast('Сохранено', 'ok');
        else if (window.AsgardUI) AsgardUI.toast('Сохранено', '', 'ok');
      } catch(e) {
        if (window.AsgardUI) AsgardUI.toast('Ошибка', e.message || '', 'err');
      }
    });
  });

  /* INTEGRATIONS — мобильная версия с API */
  patchModule('AsgardIntegrationsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var integrations = [];
    try {
      var resp = await fetch('/api/integrations', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); integrations = d.items || d.integrations || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(integrations)) integrations = [];

    var TABS = [
      { id: 'bank', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg> Банк/1С' },
      { id: 'platforms', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/></svg> Площадки' },
      { id: 'erp', label: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg> ERP' }
    ];

    var tabsHtml = '<div class="m-tabs-scroll">' + TABS.map(function(t) {
      return '<button class="m-tab-btn" data-tab="' + t.id + '">' + t.label + '</button>';
    }).join('') + '</div>';

    var cardsHtml = integrations.length > 0 ? M.mList(integrations, function(intg) {
      return M.mCard({
        id: intg.id,
        title: esc(intg.name || intg.title || 'Интеграция'),
        subtitle: esc(intg.description || intg.type || ''),
        badge: intg.status === 'active' ? 'Активна' : intg.status === 'error' ? 'Ошибка' : intg.status || '—',
        badgeColor: intg.status === 'active' ? 'ok' : intg.status === 'error' ? 'err' : 'draft',
        fields: [
          { label: 'Тип', value: esc(intg.type || intg.category || '—') },
          { label: 'Обновлено', value: fmtDate(intg.updated_at || intg.last_sync) }
        ],
        onClick: true
      });
    }) : M.mEmpty('Интеграции не настроены', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>');

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mStats([
        { label: 'Всего', value: integrations.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>', color: 'var(--info)' },
        { label: 'Активных', value: integrations.filter(function(i) { return i.status === 'active'; }).length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' }
      ]) +
      tabsHtml + cardsHtml +
    '</div>';
    await layout(body, { title: title || 'Интеграции' });
  });

  /* MAIL SETTINGS — мобильная версия */
  patchModule('AsgardMailSettingsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');

    // Загружаем аккаунты почты
    var accounts = [];
    try {
      var resp = await fetch('/api/mail-settings/accounts', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); accounts = d.accounts || d.items || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(accounts)) accounts = [];

    var accountsSection = M.mSection('Почтовые аккаунты', accounts.length > 0 ?
      M.mList(accounts, function(acc) {
        return M.mCard({
          id: acc.id,
          title: esc(acc.email || acc.name || '—'),
          subtitle: esc(acc.imap_host || acc.provider || ''),
          badge: acc.is_active ? 'Активен' : 'Отключён',
          badgeColor: acc.is_active ? 'ok' : 'draft',
          fields: [
            { label: 'Протокол', value: esc(acc.protocol || 'IMAP') },
            { label: 'Последняя синхр.', value: fmtDate(acc.last_sync) }
          ],
          onClick: true
        });
      }) : M.mEmpty('Нет настроенных аккаунтов', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>')
    );

    var addForm = M.mSection('Добавить аккаунт', M.mForm([
      { label: 'Email', id: 'msEmail', type: 'email', placeholder: 'user@domain.ru', required: true },
      { label: 'Пароль / App Password', id: 'msPass', type: 'password', placeholder: '••••••••', required: true },
      { label: 'IMAP сервер', id: 'msImap', type: 'text', placeholder: 'imap.domain.ru' },
      { label: 'SMTP сервер', id: 'msSmtp', type: 'text', placeholder: 'smtp.domain.ru' }
    ], { submitLabel: 'Подключить', submitId: 'btnAddMail' }));

    var body = '<div class="m-page" data-mobile-native="1">' + accountsSection + addForm + '</div>';
    await layout(body, { title: title || 'Настройки почты' });
  });

  /* Mailbox */
  patchModule('AsgardMailboxPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var items = [];
    try { items = await AsgardDB.all('emails') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    items.sort(function(a, b) { return String(b.date || b.created_at || '').localeCompare(String(a.date || a.created_at || '')); });
    var body = M.mTablePage({
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск писем...' } },
      items: items,
      renderCard: function(e) {
        return M.mCard({
          id: e.id, title: esc(e.subject || 'Без темы'),
          subtitle: esc(e.from || e.sender || ''),
          badge: e.is_read ? '' : 'Новое', badgeColor: 'gold',
          fields: [
            { label: 'Дата', value: fmtDate(e.date || e.created_at) },
            { label: 'Текст', value: esc((e.body || e.preview || '').substring(0, 60)), full: true }
          ], onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Почта' });
  });

  /* Telephony */
  patchModule('AsgardTelephonyPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var calls = [];
    try { calls = await AsgardDB.all('calls') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    calls.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });
    var body = M.mTablePage({
      stats: [{ label: 'Звонков', value: calls.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: calls,
      renderCard: function(c) {
        var isIncoming = c.direction === 'incoming' || c.type === 'incoming';
        return M.mCard({
          id: c.id, title: esc(c.caller_name || c.phone || 'Звонок'),
          subtitle: timeAgo(c.created_at),
          badge: isIncoming ? 'Входящий' : 'Исходящий', badgeColor: isIncoming ? 'info' : 'ok',
          fields: [
            { label: 'Длительность', value: esc(c.duration || '—') },
            { label: 'Статус', value: esc(c.status || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Телефония' });
  });

  /* PM Calcs */
  patchModule('AsgardPmCalcsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var estimates = await AsgardDB.all('estimates') || [];
    var tenders = await AsgardDB.all('tenders') || [];
    var tendById = {}; tenders.forEach(function(t) { tendById[t.id] = t; });

    if (auth.user.role === 'PM') {
      estimates = estimates.filter(function(e) { return e.pm_id === auth.user.id; });
    }
    estimates.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var body = M.mTablePage({
      stats: [
        { label: 'Просчётов', value: estimates.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>', color: 'var(--info)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: estimates,
      renderCard: function(e) {
        var t = tendById[e.tender_id] || {};
        return M.mCard({
          id: e.id, title: esc(t.customer_name || 'Просчёт #' + e.id),
          subtitle: esc(t.tender_title || ''),
          badge: e.approval_status || e.status || '—',
          badgeColor: M.statusColor(e.approval_status || e.status),
          fields: [
            { label: 'Версия', value: 'v' + (e.version_no || 0) },
            { label: 'Цена', value: money(e.price_tkp), mono: true },
            { label: 'Себест.', value: money(e.cost_plan), mono: true },
            { label: 'Дата', value: fmtDate(e.created_at) }
          ], onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Просчёты' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  EMPLOYEE DETAIL PAGE  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardEmployeePage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    /* Parse ?id= from hash */
    var hash = (location.hash || '').replace(/^#/, '');
    var qs = hash.split('?')[1] || '';
    var empId = 0;
    qs.split('&').forEach(function(kv) {
      var parts = kv.split('=');
      if (parts[0] === 'id') empId = Number(parts[1] || 0);
    });
    if (!empId) { location.hash = '#/personnel'; return; }

    var emp = await AsgardDB.get('employees', empId);
    if (!emp) { location.hash = '#/personnel'; return; }

    var works = await AsgardDB.all('works') || [];
    var workMap = {};
    works.forEach(function(w) { workMap[w.id] = w; });
    var assigns = [];
    try { assigns = (await AsgardDB.byIndex('employee_assignments', 'employee_id', empId)) || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    assigns.sort(function(a, b) { return String(b.date_from || '').localeCompare(String(a.date_from || '')); });
    var revs = [];
    try { revs = (await AsgardDB.byIndex('employee_reviews', 'employee_id', empId)) || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    revs.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    var todayStr = new Date().toISOString().slice(0, 10);
    var currentAssigns = assigns.filter(function(a) { return !a.date_to || a.date_to.slice(0, 10) >= todayStr; });
    var pastAssigns = assigns.filter(function(a) { return a.date_to && a.date_to.slice(0, 10) < todayStr; });

    /* Header card */
    var ratingStr = emp.rating_avg != null ? Number(emp.rating_avg).toFixed(1) : '—';
    var ratingStars = '';
    if (emp.rating_avg != null) {
      var r = Math.round(Number(emp.rating_avg));
      for (var s = 0; s < 10; s++) ratingStars += s < r ? '★' : '☆';
    }
    var headerCard = '<div class="m-card m-card-accent m-profile-card">' +
      '<div class="m-avatar">' + esc((emp.fio || '?')[0].toUpperCase()) + '</div>' +
      '<div class="m-card-title m-profile-name">' + esc(emp.fio || '—') + '</div>' +
      '<div class="m-card-subtitle m-profile-role">' +
        esc(emp.role_tag || '—') + ' · Разряд ' + esc(emp.grade || '—') +
      '</div>' +
      '<div class="m-card-fields m-profile-fields">' +
        '<div class="m-field"><span class="m-field-label">Рейтинг</span><span class="m-field-value">' + ratingStr + '/10</span></div>' +
        '<div class="m-field"><span class="m-field-label">Статус</span><span class="m-field-value">' + esc(emp.availability_status || '—') + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Телефон</span><span class="m-field-value">' + esc(emp.phone || '—') + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Город</span><span class="m-field-value">' + esc(emp.city || '—') + '</span></div>' +
      '</div>' +
      (ratingStars ? '<div class="m-rating-stars">' + ratingStars + '</div>' : '') +
    '</div>';

    /* Current assignments */
    var currentHtml = '';
    if (currentAssigns.length > 0) {
      currentHtml = M.mSection('Текущие назначения', M.mList(currentAssigns, function(a) {
        var w = workMap[a.work_id] || {};
        return M.mCard({
          title: esc(w.work_title || w.work_name || 'Работа #' + a.work_id),
          subtitle: esc(w.customer_name || ''),
          badge: 'Активно', badgeColor: 'ok',
          fields: [
            { label: 'С', value: fmtDate(a.date_from) },
            { label: 'По', value: a.date_to ? fmtDate(a.date_to) : 'Бессрочно' },
            { label: 'Роль', value: esc(a.role || a.role_on_work || '—') },
            { label: 'Город', value: esc(w.city || '—') }
          ]
        });
      }));
    }

    /* Past assignments */
    var pastHtml = '';
    if (pastAssigns.length > 0) {
      pastHtml = M.mSection('История назначений (' + pastAssigns.length + ')', M.mList(pastAssigns, function(a) {
        var w = workMap[a.work_id] || {};
        return M.mCard({
          title: esc(w.work_title || w.work_name || 'Работа #' + a.work_id),
          subtitle: esc(w.customer_name || ''),
          badge: w.work_status || 'Завершено', badgeColor: M.statusColor(w.work_status || 'Завершено'),
          fields: [
            { label: 'С', value: fmtDate(a.date_from) },
            { label: 'По', value: fmtDate(a.date_to) },
            { label: 'Роль', value: esc(a.role || a.role_on_work || '—') }
          ]
        });
      }));
    }

    /* Reviews */
    var reviewsHtml = '';
    if (revs.length > 0) {
      reviewsHtml = M.mSection('Отзывы (' + revs.length + ')', M.mList(revs, function(r) {
        var w = workMap[r.work_id] || {};
        var score = Number(r.score_1_10 || 0);
        var color = score >= 7 ? 'ok' : score >= 4 ? 'warn' : 'err';
        return M.mCard({
          title: esc(w.work_title || 'Работа'),
          subtitle: esc(r.comment || ''),
          badge: score + '/10', badgeColor: color,
          fields: [
            { label: 'Дата', value: fmtDate(r.created_at) },
            { label: 'Оценка', value: score + '/10' }
          ]
        });
      }));
    } else {
      reviewsHtml = M.mSection('Отзывы', M.mEmpty('Пока нет оценок', '<svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold, #f59e0b)" stroke="var(--gold, #f59e0b)" stroke-width="1" style="vertical-align:-2px"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'));
    }

    /* Permits */
    var permitsHtml = '';
    var empPermits = Array.isArray(emp.permits) ? emp.permits : [];
    if (empPermits.length > 0) {
      var permBadges = empPermits.map(function(p) { return M.mBadge(esc(p), 'info'); }).join(' ');
      permitsHtml = M.mSection('Допуски', '<div class="m-badge-group">' + permBadges + '</div>');
    }

    var body = '<div class="m-page m-detail-page" data-mobile-native="1">' +
      '<div class="m-back-wrap"><a href="#/personnel" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Персонал</a></div>' +
      headerCard + permitsHtml + currentHtml + pastHtml + reviewsHtml +
    '</div>';

    await layout(body, { title: title || esc(emp.fio || 'Сотрудник') });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PM CONSENTS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardPmConsentsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var cons = [];
    try { cons = await AsgardDB.all('pm_consents') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    cons = cons.filter(function(c) {
      return Number(c.pm_id) === Number(user.id) || user.role === 'ADMIN';
    });
    cons.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    var pending = cons.filter(function(c) { return c.status === 'pending'; }).length;

    var body = M.mTablePage({
      stats: [
        { label: 'Запросов', value: cons.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' },
        { label: 'Ожидают', value: pending, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', color: 'var(--warn-t)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: cons,
      renderCard: function(c) {
        var isPending = c.status === 'pending' && Number(c.pm_id) === Number(user.id);
        var footer = isPending ?
          '<div class="m-action-row">' +
            '<button class="m-approve-btn" data-act="approve" data-id="' + c.id + '">Согласен</button>' +
            '<button class="m-decline-btn" data-act="decline" data-id="' + c.id + '">Отклонить</button>' +
          '</div>' : '';
        return M.mCard({
          id: c.id,
          title: esc(c.type || 'Запрос согласия'),
          subtitle: timeAgo(c.created_at),
          badge: c.status || '—',
          badgeColor: M.statusColor(c.status),
          fields: [
            { label: 'Тип', value: esc(c.type || '—') },
            { label: 'Дата', value: fmtDate(c.created_at) }
          ],
          footer: footer
        });
      }
    });

    await layout(body, { title: title || 'Согласия РП' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    /* Handle approve/decline */
    var container = document.getElementById('mobileList');
    if (container) {
      container.addEventListener('click', async function(e) {
        var btn = e.target.closest('[data-act]');
        if (!btn) return;
        var act = btn.getAttribute('data-act');
        var id = Number(btn.getAttribute('data-id') || 0);
        if (!id) return;
        var c = await AsgardDB.get('pm_consents', id);
        if (!c || c.status !== 'pending') return;
        c.status = act === 'approve' ? 'approved' : 'declined';
        c.decided_at = new Date().toISOString();
        c.decided_by_user_id = user.id;
        await AsgardDB.put('pm_consents', c);
        if (act === 'approve') {
          M.showSuccessAnimation(card);
        }
        if (typeof AsgardUI !== 'undefined' && AsgardUI.toast) {
          AsgardUI.toast('Согласие', act === 'approve' ? 'Согласовано' : 'Отклонено');
        }
        /* Re-render */
        setTimeout(function() { location.hash = location.hash; }, act === 'approve' ? 600 : 100);
      });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TASKS CRUD  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardTasksCrudPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var userMap = {};
    users.forEach(function(u) { userMap[u.id] = u; });

    var tasks = [];
    try {
      var token = localStorage.getItem('asgard_token');
      var resp = await fetch('/api/tasks?limit=500', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (resp.ok) {
        var data = await resp.json();
        tasks = data.tasks || [];
      }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var PRIORITIES = { high: '<span class="m-dot m-dot-red"></span> Высокий', medium: '<span class="m-dot m-dot-yellow"></span> Средний', low: '<span class="m-dot m-dot-green"></span> Низкий' };
    var statusNew = tasks.filter(function(t) { return t.status === 'Новая'; }).length;
    var statusWork = tasks.filter(function(t) { return t.status === 'В работе'; }).length;
    var statusDone = tasks.filter(function(t) { return t.status === 'Выполнена'; }).length;

    var body = M.mTablePage({
      stats: [
        { label: 'Все', value: tasks.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' },
        { label: 'Новые', value: statusNew, icon: '🆕', color: 'var(--purple-l)' },
        { label: 'В работе', value: statusWork, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="var(--amber, #f59e0b)" stroke="none" style="vertical-align:-2px"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>', color: 'var(--amber)' },
        { label: 'Выполнено', value: statusDone, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск задач...' },
        actions: [
          { id: 'btnNewTask', label: 'Создать', icon: '+', cls: 'primary' }
        ]
      },
      items: tasks,
      renderCard: function(t) {
        var assignee = userMap[t.assigned_to] || {};
        var overdue = t.due_date && new Date(t.due_date) < new Date() && t.status !== 'Закрыта' && t.status !== 'Выполнена';
        var prioLabel = PRIORITIES[t.priority] || '<span class="m-dot m-dot-yellow"></span> Средний';

        var actionBtn = '';
        if (t.status === 'Новая') actionBtn = '<button class="m-info-btn" data-action="В работе" data-tid="' + t.id + '">▶ В работу</button>';
        if (t.status === 'В работе') actionBtn = '<button class="m-approve-btn" data-action="Выполнена" data-tid="' + t.id + '"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align:-1px"><polyline points="20 6 9 17 4 12"/></svg> Выполнена</button>';
        if (t.status === 'Выполнена') actionBtn = '<button class="m-skip-btn" data-action="Закрыта" data-tid="' + t.id + '"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Закрыть</button>';

        return M.mCard({
          id: t.id,
          title: esc(t.title || 'Без названия'),
          subtitle: esc(assignee.name || '— Не назначен'),
          badge: t.status || '—',
          badgeColor: M.statusColor(t.status),
          accentColor: overdue ? 'var(--err-t)' : undefined,
          fields: [
            { label: 'Приоритет', value: prioLabel },
            { label: 'Дедлайн', value: (t.due_date ? fmtDate(t.due_date) : '—') + (overdue ? ' <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--warn, #f59e0b)" stroke-width="2" style="vertical-align:-2px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>' : '') },
            { label: 'Автор', value: esc((userMap[t.created_by] || {}).name || '—') },
            { label: 'Исполнитель', value: esc(assignee.name || '—') }
          ],
          footer: actionBtn ? '<div class="m-card-actions">' + actionBtn + '</div>' : '',
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Задачи' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    /* Status change handler */
    var container = document.getElementById('mobileList');
    if (container) {
      container.addEventListener('click', async function(e) {
        var btn = e.target.closest('[data-action]');
        if (!btn) return;
        e.stopPropagation();
        var newStatus = btn.getAttribute('data-action');
        var tid = parseInt(btn.getAttribute('data-tid'));
        if (!tid || !newStatus) return;
        try {
          var token = localStorage.getItem('asgard_token');
          var resp = await fetch('/api/tasks/' + tid + '/status', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify({ status: newStatus })
          });
          if (!resp.ok) throw new Error('Ошибка');
          var card = btn.closest('.m-card');
          if (newStatus === 'Выполнена' || newStatus === 'Закрыта') M.showSuccessAnimation(card);
          if (typeof AsgardUI !== 'undefined' && AsgardUI.toast) AsgardUI.toast('Готово', 'Статус: ' + newStatus);
          setTimeout(function() { location.hash = location.hash; }, 500);
        } catch(er) {
          if (typeof AsgardUI !== 'undefined' && AsgardUI.toast) AsgardUI.toast('Ошибка', er.message, 'err');
        }
      });
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  MY MAIL (Mobile Email Client)  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardMyMailPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = auth.token || localStorage.getItem('asgard_token');

    /* v8.0.0 — Yandex Mail level */
    var configured = false;
    try {
      var resp = await fetch('/api/my-mail/account', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var acc = await resp.json(); configured = !!acc.email; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    if (!configured) {
      var body = '<div class="m-page" data-mobile-native="1">' +
        M.mEmpty('Почта не настроена. Настройте подключение в \xABНастройки почты\xBB.', '\uD83D\uDCE7') +
      '</div>';
      await layout(body, { title: title || 'Моя почта' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');

      return;
    }

    var currentFolder = 'inbox';
    var emails = [];
    var folders = [
      { id: 'inbox', label: 'Входящие', count: 0, active: true },
      { id: 'sent', label: 'Отправленные', count: 0 },
      { id: 'drafts', label: 'Черновики', count: 0 },
      { id: 'spam', label: 'Спам', count: 0 },
      { id: 'trash', label: 'Корзина', count: 0 }
    ];

    async function fetchEmails(folder) {
      try {
        var resp = await fetch('/api/my-mail/emails?limit=50&folder=' + folder, {
          headers: { 'Authorization': 'Bearer ' + token }
        });
        if (resp.ok) {
          var data = await resp.json();
          emails = data.emails || [];
          if (data.stats) {
            folders[0].count = data.stats.inbox_unread || 0;
            folders[2].count = data.stats.drafts || 0;
          }
        }
      } catch(e) { emails = []; }
    }

    await fetchEmails('inbox');

    function renderMailList() {
      if (!emails.length) return M.mEmpty('Нет писем', '\uD83D\uDCEB');
      return emails.map(function(e) {
        return M.mMailItem({
          id: e.id,
          from: e.from_name || e.from_email || e.from || '',
          subject: e.subject || '',
          snippet: (e.body_text || e.preview || '').replace(/<[^>]+>/g, '').substring(0, 60),
          time: fmtDateShort(e.date || e.created_at),
          unread: !e.is_read,
          starred: e.is_starred,
          hasAttachment: e.has_attachment || (e.attachments && e.attachments.length > 0)
        });
      }).join('');
    }

    var folderTitle = 'Входящие';
    var unreadCount = emails.filter(function(e) { return !e.is_read; }).length;

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mMailFolders(folders) +
      M.mMailCompose() +
      '<div id="mailMainView">' +
        '<div class="m-mail-toolbar">' +
          '<button class="m-chat-back-btn m-mail-burger-icon" id="mailBurgerBtn">\u2630</button>' +
          '<span id="mailFolderTitle" class="m-mail-toolbar-title">' + folderTitle + (unreadCount ? ' (' + unreadCount + ')' : '') + '</span>' +
          '<button class="m-chat-back-btn" id="mailSearchToggle">\uD83D\uDD0D</button>' +
          '<button class="m-chat-back-btn m-mail-compose-icon" id="mailComposeBtn">\u270F</button>' +
        '</div>' +
        '<input class="m-search-input m-mail-search-field" id="mailSearch" placeholder="\u041F\u043E\u0438\u0441\u043A \u043F\u0438\u0441\u0435\u043C...">' +
        '<div id="mailList">' + renderMailList() + '</div>' +
      '</div>' +
      '<div id="mailDetailView" style="display:none"></div>' +
    '</div>';

    await layout(body, { title: title || 'Моя почта' });

    var mailList = document.getElementById('mailList');
    var mailMainView = document.getElementById('mailMainView');
    var mailDetailView = document.getElementById('mailDetailView');
    var mailDrawer = document.getElementById('mailDrawer');
    var mailDrawerOverlay = document.getElementById('mailDrawerOverlay');
    var mailCompose = document.getElementById('mailCompose');

    // Burger -> open folder drawer
    var burgerBtn = document.getElementById('mailBurgerBtn');
    if (burgerBtn) {
      burgerBtn.addEventListener('click', function() {
        mailDrawer.classList.add('open');
        mailDrawerOverlay.classList.add('open');
      });
    }
    if (mailDrawerOverlay) {
      mailDrawerOverlay.addEventListener('click', function() {
        mailDrawer.classList.remove('open');
        mailDrawerOverlay.classList.remove('open');
      });
    }

    // Folder selection
    if (mailDrawer) {
      mailDrawer.addEventListener('click', async function(e) {
        var item = e.target.closest('.m-mail-folder-item');
        if (!item) return;
        var folderId = item.dataset.folder;
        currentFolder = folderId;
        // Update active state
        mailDrawer.querySelectorAll('.m-mail-folder-item').forEach(function(i) { i.classList.remove('active'); });
        item.classList.add('active');
        // Close drawer
        mailDrawer.classList.remove('open');
        mailDrawerOverlay.classList.remove('open');
        // Reload emails
        mailList.innerHTML = '<div class="m-chat-skel">' +
        '<div class="m-skel-row" style="justify-content:flex-start;gap:8px;margin:12px 16px">' +
          '<div class="m-skel-circle" style="width:32px;height:32px;border-radius:50%;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
          '<div class="m-skel-text" style="width:55%;height:36px;border-radius:18px 18px 18px 4px;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
        '</div>' +
        '<div class="m-skel-row" style="justify-content:flex-end;margin:8px 16px">' +
          '<div class="m-skel-text" style="width:45%;height:36px;border-radius:18px 18px 4px 18px;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
        '</div>' +
        '<div class="m-skel-row" style="justify-content:flex-start;gap:8px;margin:8px 16px">' +
          '<div class="m-skel-circle" style="width:32px;height:32px;border-radius:50%;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
          '<div class="m-skel-text" style="width:65%;height:48px;border-radius:18px 18px 18px 4px;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
        '</div>' +
        '<div class="m-skel-row" style="justify-content:flex-end;margin:8px 16px">' +
          '<div class="m-skel-text" style="width:40%;height:28px;border-radius:18px 18px 4px 18px;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
        '</div>' +
        '<div class="m-skel-row" style="justify-content:flex-start;gap:8px;margin:8px 16px">' +
          '<div class="m-skel-circle" style="width:32px;height:32px;border-radius:50%;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
          '<div class="m-skel-text" style="width:50%;height:36px;border-radius:18px 18px 18px 4px;background:var(--bg3);animation:m-shimmer 1.5s infinite"></div>' +
        '</div>' +
      '</div>';
        await fetchEmails(folderId);
        mailList.innerHTML = renderMailList();
        initSwipe();
        // Update title
        var folderLabel = folders.find(function(f) { return f.id === folderId; });
        document.getElementById('mailFolderTitle').textContent = folderLabel ? folderLabel.label : folderId;
      });
    }

    // Search toggle
    var searchToggle = document.getElementById('mailSearchToggle');
    var searchInput = document.getElementById('mailSearch');
    if (searchToggle && searchInput) {
      searchToggle.addEventListener('click', function() {
        searchInput.classList.toggle('open');
        if (searchInput.classList.contains('open')) searchInput.focus();
      });
      searchInput.addEventListener('input', function() {
        _debounce('search1', function() {
        var q = this.value.toLowerCase();
        var items = mailList.querySelectorAll('.m-mail-swipe-wrap');
        items.forEach(function(item) {
          var sender = (item.querySelector('.m-mail-sender') || {}).textContent || '';
          var subject = (item.querySelector('.m-mail-subject') || {}).textContent || '';
          item.style.display = (sender.toLowerCase().includes(q) || subject.toLowerCase().includes(q)) ? '' : 'none';
        });
      }, 250);
        });
    }


    // Pull-to-Refresh for mail
    (function initMailPTR() {
      var ml = document.getElementById('mailList');
      if (!ml) return;
      var startY = 0, pulling = false, ptrEl = null;
      ml.addEventListener('touchstart', function(e) {
        if (ml.scrollTop <= 0) { startY = e.touches[0].clientY; pulling = true; }
      }, { passive: true });
      ml.addEventListener('touchmove', function(e) {
        if (!pulling) return;
        var dy = e.touches[0].clientY - startY;
        if (dy > 0 && dy < 150) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435...</span>';
            ml.parentNode.insertBefore(ptrEl, ml);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      ml.addEventListener('touchend', function() {
        if (!pulling) return;
        pulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          fetchEmails(currentFolder).then(function() {
              mailList.innerHTML = renderMailList();
              initSwipe();
              if (ptrEl) { ptrEl.remove(); ptrEl = null; }
            }).catch(function() {
              if (ptrEl) { ptrEl.remove(); ptrEl = null; }
            });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Compose button
    var composeBtn = document.getElementById('mailComposeBtn');
    if (composeBtn && mailCompose) {
      composeBtn.addEventListener('click', function() { mailCompose.classList.add('open'); });
    }
    var composeClose = document.getElementById('mailComposeClose');
    if (composeClose) {
      composeClose.addEventListener('click', function() { mailCompose.classList.remove('open'); });
    }
    // CC toggle
    var ccToggle = document.getElementById('mailCcToggle');
    var ccField = document.getElementById('mailCcField');
    if (ccToggle && ccField) {
      ccToggle.addEventListener('click', function() {
        ccField.style.display = ccField.style.display === 'none' ? '' : 'none';
        ccToggle.classList.toggle('active');
      });
    }

    // Employee autocomplete for To field
    var mailToInput = document.getElementById('mailTo');
    if (mailToInput) {
      var acTimer = null;
      var acDropdown = null;
      mailToInput.addEventListener('input', function() {
        var q = this.value.trim();
        clearTimeout(acTimer);
        if (q.length < 2) { if (acDropdown) acDropdown.remove(); return; }
        acTimer = setTimeout(function() {
          fetch('/api/staff?search=' + encodeURIComponent(q) + '&limit=5', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var staff = data.staff || data.data || data || [];
            if (!staff.length) { if (acDropdown) acDropdown.remove(); return; }
            if (!acDropdown) {
              acDropdown = document.createElement('div');
              acDropdown.className = 'm-mail-autocomplete';
              mailToInput.parentNode.appendChild(acDropdown);
            }
            acDropdown.innerHTML = staff.map(function(s) {
              return '<div class="m-mail-ac-item" data-email="' + (s.email || '') + '">' +
                '<strong>' + (s.name || s.full_name || '') + '</strong>' +
                '<span>' + (s.email || '') + '</span></div>';
            }).join('');
            acDropdown.querySelectorAll('.m-mail-ac-item').forEach(function(item) {
              item.addEventListener('click', function() {
                mailToInput.value = this.dataset.email;
                acDropdown.remove();
                acDropdown = null;
              });
            });
          })
          .catch(function() {});
        }, 300);
      });
    }

    var composeSend = document.getElementById('mailComposeSend');
    if (composeSend) {
      composeSend.addEventListener('click', async function() {
        var to = document.getElementById('mailTo').value.trim();
        var subject = document.getElementById('mailSubject').value.trim();
        var mailBodyEl = document.getElementById('mailBody');
        var bodyText = (mailBodyEl.contentEditable === 'true' ? (mailBodyEl.innerHTML || mailBodyEl.innerText || '') : (mailBodyEl.value || '')).trim();
        if (!to) return;
        composeSend.disabled = true;
        composeSend.textContent = '\u041E\u0442\u043F\u0440\u0430\u0432\u043A\u0430...';
        try {
          await fetch('/api/my-mail/send', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify({ to: to, subject: subject, body: bodyText })
          });
          mailCompose.classList.remove('open');
          document.getElementById('mailTo').value = '';
          document.getElementById('mailSubject').value = '';
          var clrBody = document.getElementById('mailBody');
          if (clrBody.contentEditable === 'true') clrBody.innerHTML = ''; else clrBody.value = '';
          if (M.showSuccess) M.showSuccess('\u041F\u0438\u0441\u044C\u043C\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043E');
        } catch(e) {
          if (M.showError) M.showError('\u041E\u0448\u0438\u0431\u043A\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043A\u0438');
        }
        composeSend.disabled = false;
        composeSend.textContent = '\u041E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C';
      });
    }

      // Rich text toolbar — format commands
      var mailBody = document.getElementById('mailBody');
      if (mailBody) {
        // Switch textarea to contenteditable div for rich text
        var richDiv = document.createElement('div');
        richDiv.id = 'mailBody';
        richDiv.className = 'm-mail-compose-textarea';
        richDiv.contentEditable = 'true';
        richDiv.setAttribute('placeholder', 'Текст письма...');
        richDiv.style.minHeight = '200px';
        richDiv.style.outline = 'none';
        richDiv.style.whiteSpace = 'pre-wrap';
        mailBody.parentNode.replaceChild(richDiv, mailBody);
        mailBody = richDiv;
      }
      document.querySelectorAll('.m-mail-tb-btn[data-cmd]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var cmd = btn.dataset.cmd;
          document.execCommand(cmd, false, null);
          btn.classList.toggle('active');
          if (mailBody) mailBody.focus();
        });
      });

    // Attachment button handler
    var mailAttachBtn = document.getElementById('mailAttachBtn');
    if (mailAttachBtn) {
      var _fileInput = document.createElement('input');
      _fileInput.type = 'file';
      _fileInput.multiple = true;
      _fileInput.style.display = 'none';
      _fileInput.accept = '.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.zip,.rar';
      document.body.appendChild(_fileInput);
      mailAttachBtn.addEventListener('click', function() { _fileInput.click(); });
      _fileInput.addEventListener('change', function() {
        if (!_fileInput.files.length) return;
        var names = Array.prototype.map.call(_fileInput.files, function(f) { return f.name; });
        var label = mailAttachBtn.parentNode.querySelector('.m-mail-attach-label');
        if (!label) {
          label = document.createElement('span');
          label.className = 'm-mail-attach-label';
          label.style.cssText = 'font-size:12px;color:var(--primary);margin-left:8px';
          mailAttachBtn.parentNode.appendChild(label);
        }
        label.textContent = names.join(', ');
        // Store files for sending
        window._mailAttachFiles = _fileInput.files;
      });
    }

    // Star toggle
    if (mailList) {
      mailList.addEventListener('click', function(e) {
        var star = e.target.closest('.m-mail-star');
        if (star) {
          e.stopPropagation();
          star.classList.toggle('active');
          star.textContent = star.classList.contains('active') ? '\u2605' : '\u2606';
          var mailId = star.dataset.mailStar;
          fetch('/api/my-mail/emails/' + mailId + '/star', {
            method: 'PUT',
            headers: { 'Authorization': 'Bearer ' + token }
          }).catch(function(){});
          return;
        }
      });
    }

    // Open email detail
    if (mailList) {
      mailList.addEventListener('click', async function(e) {
        if (e.target.closest('.m-mail-star')) return;
        var item = e.target.closest('.m-mail-item');
        if (!item) return;
        var wrap = item.closest('.m-mail-swipe-wrap');
        var emailId = wrap ? wrap.dataset.mailId : '';
        if (!emailId) return;

        // Mark as read
        try {
          await fetch('/api/my-mail/emails/' + emailId + '/read', {
            method: 'PUT', headers: { 'Authorization': 'Bearer ' + token }
          });
          item.classList.remove('unread');
        } catch(e) { console.warn('[MobileRender]', e.message || e); }

        // Fetch full email
        try {
          var r = await fetch('/api/my-mail/emails/' + emailId, { headers: { 'Authorization': 'Bearer ' + token } });
          if (!r.ok) throw new Error();
          var email = await r.json();

          var emailBody = '';
          if (email.body_html) {
            emailBody = '<iframe class="m-email-iframe" sandbox="allow-same-origin" srcdoc="' +
              email.body_html.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;') +
              '" frameborder="0"></iframe>';
          } else {
            emailBody = '<div class="m-mail-body-text">' + esc(email.body_text || email.body || '') + '</div>';
          }

          // Attachments
          var attachHtml = '';
          if (email.attachments && email.attachments.length) {
            attachHtml = '<div class="m-mail-attachments-section"><div class="m-mail-attachments-label">\u0412\u043B\u043E\u0436\u0435\u043D\u0438\u044F (' + email.attachments.length + ')</div>';
            email.attachments.forEach(function(att) {
              var icon = '\uD83D\uDCC4';
              if (/\.(jpg|jpeg|png|gif|webp)/i.test(att.name)) icon = '\uD83D\uDDBC';
              if (/\.pdf/i.test(att.name)) icon = '\uD83D\uDCC4';
              if (/\.(doc|docx)/i.test(att.name)) icon = '\uD83D\uDCC3';
              if (/\.(xls|xlsx)/i.test(att.name)) icon = '\uD83D\uDCCA';
              attachHtml += '<div class="m-mail-attachment">' +
                '<div class="m-mail-att-icon">' + icon + '</div>' +
                '<div class="m-mail-att-info"><div class="m-mail-att-name">' + esc(att.name) + '</div>' +
                '<div class="m-mail-att-size">' + (att.size ? (Math.round(att.size/1024) + ' KB') : '') + '</div></div>' +
              '</div>';
            });
            attachHtml += '</div>';
          }

          // Detail view
          mailMainView.style.display = 'none';
          mailDetailView.style.display = '';
          // Hide tabbar
          var tabbar = document.querySelector('.m-tabbar');
          if (tabbar) tabbar.style.display = 'none';
          var header = document.querySelector('.m-header');
          if (header) header.style.display = 'none';

          mailDetailView.innerHTML =
            '<div class="m-mail-detail-header">' +
              '<button class="m-chat-back-btn" id="mailDetailBack">\u2190</button>' +
              '<span class="m-mail-detail-subject">' + esc(email.subject || '\u0411\u0435\u0437 \u0442\u0435\u043C\u044B') + '</span>' +
            '</div>' +
            '<div class="m-mail-detail-meta">' +
              '<div class="m-mail-detail-from">' + esc(email.from_name || email.from_email || '') + '</div>' +
              '<div class="m-mail-detail-email">' + esc(email.from_email || '') + '</div>' +
              '<div class="m-mail-detail-to">\u041A\u043E\u043C\u0443: ' + esc(email.to || '') + ' \u2022 ' + fmtDate(email.date || email.created_at) + '</div>' +
            '</div>' +
            emailBody +
            attachHtml +
            '<div class="m-mail-detail-actions">' +
              '<button class="m-load-more-btn" id="mailReplyBtn">\u21A9 \u041E\u0442\u0432\u0435\u0442\u0438\u0442\u044C</button>' +
              '<button class="m-load-more-btn" id="mailReplyAllBtn">↩↩ Всем</button>' +
              '<button class="m-load-more-btn" id="mailForwardBtn">\u21AA \u041F\u0435\u0440\u0435\u0441\u043B\u0430\u0442\u044C</button>' +
            '</div>';

          // Back from detail
          document.getElementById('mailDetailBack').addEventListener('click', function() {
            mailDetailView.style.display = 'none';
            mailMainView.style.display = '';
            if (tabbar) tabbar.style.display = '';
            if (header) header.style.display = '';
          });

          // Reply
          var replyBtn = document.getElementById('mailReplyBtn');
          if (replyBtn) {
            replyBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailTo').value = email.from_email || email.from || '';
              document.getElementById('mailSubject').value = 'Re: ' + (email.subject || '');
            });

          // Reply All
          var replyAllBtn = document.getElementById('mailReplyAllBtn');
          if (replyAllBtn) {
            replyAllBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailTo').value = (email.from_email || '') + ', ' + (email.to || '');
              document.getElementById('mailSubject').value = 'Re: ' + (email.subject || '');
              var _replyBody = document.getElementById('mailBody');
              var _quoted = '\n\n--- Оригинал ---\n' + (email.body_text || email.body || '');
              if (_replyBody.contentEditable === 'true') _replyBody.innerHTML = '<br><br><hr><div style="color:var(--muted,#8B949E)">' + esc(_quoted) + '</div>';
              else _replyBody.value = _quoted;
            });
          }
          }
          // Forward
          var fwdBtn = document.getElementById('mailForwardBtn');
          if (fwdBtn) {
            fwdBtn.addEventListener('click', function() {
              mailCompose.classList.add('open');
              document.getElementById('mailSubject').value = 'Fwd: ' + (email.subject || '');
              document.getElementById('mailBody').value = '\n\n--- \u041F\u0435\u0440\u0435\u0441\u043B\u0430\u043D\u043D\u043E\u0435 \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 ---\n\u041E\u0442: ' + (email.from_name || email.from_email || '') + '\n\u0422\u0435\u043C\u0430: ' + (email.subject || '') + '\n\n' + (email.body_text || '');
            });
          }
        } catch(e) { if (M.showError) M.showError('\u041E\u0448\u0438\u0431\u043A\u0430 \u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0438 \u043F\u0438\u0441\u044C\u043C\u0430'); }
      });
    }

    // Swipe actions on mail items
    function initSwipe() {
      var items = mailList.querySelectorAll('.m-mail-swipe-wrap');
      items.forEach(function(wrap) {
        var mailItem = wrap.querySelector('.m-mail-item');
        if (!mailItem) return;
        var startX = 0, currentX = 0, swiping = false;
        mailItem.addEventListener('touchstart', function(e) {
          startX = e.touches[0].clientX;
          currentX = 0;
          swiping = true;
          mailItem.style.transition = 'none';
        });
        mailItem.addEventListener('touchmove', function(e) {
          if (!swiping) return;
          currentX = e.touches[0].clientX - startX;
          if (Math.abs(currentX) > 10) {
            mailItem.style.transform = 'translateX(' + currentX + 'px)';
          }
        });
        mailItem.addEventListener('touchend', function() {
          swiping = false;
          mailItem.style.transition = 'transform 0.3s ease';
          if (currentX > 100) {
            // Swipe right = archive
            mailItem.style.transform = 'translateX(100%)';
            setTimeout(function() { wrap.style.display = 'none'; }, 300);
            var mailId = wrap.dataset.mailId;
            fetch('/api/my-mail/emails/' + mailId + '/archive', {
              method: 'PUT', headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
          } else if (currentX < -100) {
            // Swipe left = delete
            mailItem.style.transform = 'translateX(-100%)';
            setTimeout(function() { wrap.style.display = 'none'; }, 300);
            var mailId2 = wrap.dataset.mailId;
            fetch('/api/my-mail/emails/' + mailId2, {
              method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
          } else {
            mailItem.style.transform = 'translateX(0)';
          }
        });
      });
    }
    initSwipe();

    // Deep link
    var params = new URLSearchParams(location.hash.split('?')[1] || '');
    var openId = params.get('id');
    if (openId) {
      var targetItem = mailList.querySelector('[data-mail-id="' + openId + '"] .m-mail-item');
      if (targetItem) targetItem.click();
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CUSTOMERS — renderList + renderCard  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchMethod('AsgardCustomersPage', 'renderList', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var customers = [];
    try { customers = await AsgardDB.all('customers') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    customers.sort(function(a, b) { return String(a.name || '').localeCompare(String(b.name || ''), 'ru'); });

    var body = M.mTablePage({
      stats: [{ label: 'Контрагентов', value: customers.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск: ИНН, название...' } },
      items: customers,
      renderCard: function(c) {
        return M.mCard({
          id: c.inn || c.id,
          title: esc(c.name || c.full_name || '—'),
          subtitle: 'ИНН: ' + esc(c.inn || '—'),
          fields: [
            { label: 'КПП', value: esc(c.kpp || '—') },
            { label: 'Телефон', value: esc(c.phone || '—') },
            { label: 'Email', value: esc(c.email || '—') },
            { label: 'Адрес', value: esc((c.address || '').substring(0, 40) || '—'), full: true }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Контрагенты' });

    var container = document.getElementById('mobileList');
    if (container) {
      container.addEventListener('click', function(e) {
        var card = e.target.closest('.m-card[data-id]');
        if (card) location.hash = '#/customer?inn=' + card.getAttribute('data-id');
      });
    }
  });

  patchMethod('AsgardCustomersPage', 'renderCard', async function({ layout, title, query }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var inn = query && query.inn;
    var isNew = query && query.new;

    if (isNew) {
      /* New customer form */
      var formHtml = M.mForm([
        { label: 'ИНН', id: 'fInn', type: 'text', placeholder: '10-12 цифр', required: true },
        { label: 'Название', id: 'fName', type: 'text', placeholder: 'Полное название организации', required: true },
        { label: 'КПП', id: 'fKpp', type: 'text', placeholder: 'КПП' },
        { label: 'ОГРН', id: 'fOgrn', type: 'text', placeholder: 'ОГРН' },
        { label: 'Адрес', id: 'fAddr', type: 'textarea', placeholder: 'Юридический адрес' },
        { label: 'Телефон', id: 'fPhone', type: 'tel', placeholder: '+7 ...' },
        { label: 'Email', id: 'fEmail', type: 'email', placeholder: 'email@company.ru' },
        { label: 'Комментарий', id: 'fComment', type: 'textarea', placeholder: 'Заметки' }
      ], { submitLabel: 'Сохранить', cancelLabel: 'Отмена' });
      var body = '<div class="m-page" data-mobile-native="1">' +
        '<div class="m-back-wrap"><a href="#/customers" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Контрагенты</a></div>' +
        M.mSection('Новый контрагент', formHtml) +
      '</div>';
      await layout(body, { title: title || 'Новый контрагент' });
      return;
    }

    if (!inn) { location.hash = '#/customers'; return; }
    var c = null;
    try { c = await AsgardDB.get('customers', inn); } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!c) { location.hash = '#/customers'; return; }

    var body = '<div class="m-page" data-mobile-native="1">' +
      '<div class="m-back-wrap"><a href="#/customers" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Контрагенты</a></div>' +
      '<div class="m-card m-card-accent">' +
        '<div class="m-card-title m-title-lg">' + esc(c.name || c.full_name || '—') + '</div>' +
        '<div class="m-card-fields m-mt-12">' +
          '<div class="m-field"><span class="m-field-label">ИНН</span><span class="m-field-value m-field-mono">' + esc(c.inn || '—') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">КПП</span><span class="m-field-value">' + esc(c.kpp || '—') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">ОГРН</span><span class="m-field-value">' + esc(c.ogrn || '—') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">Телефон</span><span class="m-field-value">' + esc(c.phone || '—') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">Email</span><span class="m-field-value">' + esc(c.email || '—') + '</span></div>' +
          '<div class="m-field m-field-full"><span class="m-field-label">Адрес</span><span class="m-field-value">' + esc(c.address || '—') + '</span></div>' +
          (c.comment ? '<div class="m-field m-field-full"><span class="m-field-label">Комментарий</span><span class="m-field-value">' + esc(c.comment) + '</span></div>' : '') +
        '</div>' +
      '</div>' +
    '</div>';
    await layout(body, { title: title || esc(c.name || 'Контрагент') });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PAYROLL — renderSheet, renderSelfEmployed, renderOneTimePay  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchMethod('AsgardPayrollPage', 'renderSheet', async function({ layout, title, query }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    /* Parse sheet id */
    var sheetId = (query && query.id) || 0;
    if (!sheetId) {
      var h = (location.hash || '').split('?')[1] || '';
      h.split('&').forEach(function(kv) { var p = kv.split('='); if (p[0] === 'id' || p[0] === 'work_id') sheetId = p[1]; });
    }
    /* Load sheet data from API */
    var token = localStorage.getItem('asgard_token');
    var sheet = null;
    try {
      var resp = await fetch('/api/payroll/sheets/' + sheetId, { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) sheet = await resp.json();
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    if (!sheet) {
      /* Fallback — show basic info card */
      var body = M.mTablePage({
        content: '<div class="m-back-wrap"><a href="#/payroll" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> К начислениям</a></div>' +
          M.mCard({
            id: sheetId,
            title: 'Ведомость #' + esc(sheetId || '—'),
            subtitle: 'Данные ведомости не найдены',
            badge: '—', badgeColor: 'var(--t3)',
            fields: []
          })
      });
      await layout(body, { title: title || 'Ведомость' });
      return;
    }

    var employees = (sheet.employees || sheet.items || sheet.rows || []);
    var totalSum = employees.reduce(function(s, e) { return s + (parseFloat(e.total || e.amount || e.sum || 0)); }, 0);

    var body = M.mTablePage({
      content: '<div class="m-back-wrap"><a href="#/payroll" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> К начислениям</a></div>',
      stats: [
        { label: 'Сотрудников', value: employees.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', color: 'var(--info)' },
        { label: 'Итого', value: fmtMoney(totalSum), icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--ok-t)' }
      ],
      items: employees,
      renderCard: function(e) {
        return M.mCard({
          title: esc(e.name || e.employee_name || 'Сотрудник'),
          subtitle: esc(e.position || e.role || ''),
          fields: [
            { label: 'Оклад', value: fmtMoney(e.salary || e.base || 0), mono: true },
            { label: 'Бонус', value: fmtMoney(e.bonus || 0), mono: true },
            { label: 'Удержания', value: fmtMoney(e.deductions || e.penalty || 0), mono: true },
            { label: 'Итого', value: fmtMoney(e.total || e.amount || e.sum || 0), mono: true }
          ]
        });
      },
      emptyIcon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>',
      emptyText: 'Нет записей в ведомости'
    });
    await layout(body, { title: title || 'Ведомость #' + esc(sheetId || '') });
  });

  patchMethod('AsgardPayrollPage', 'renderSelfEmployed', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var items = [];
    try {
      var resp = await fetch('/api/payroll/self-employed', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); items = d.items || d.data || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(items)) items = [];

    var body = M.mTablePage({
      stats: [{ label: 'Самозанятых', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(se) {
        return M.mCard({
          id: se.id, title: esc(se.full_name || se.name || '—'),
          subtitle: 'ИНН: ' + esc(se.inn || '—'),
          badge: se.npd_status || '—', badgeColor: M.statusColor(se.npd_status),
          fields: [
            { label: 'Телефон', value: esc(se.phone || '—') },
            { label: 'Банк', value: esc(se.bank_name || '—') },
            { label: 'Договор', value: esc(se.contract_number || '—') },
            { label: 'Дата дог.', value: fmtDate(se.contract_date) }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Самозанятые' });
  });

  patchMethod('AsgardPayrollPage', 'renderOneTimePay', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var items = [];
    try {
      var resp = await fetch('/api/payroll/one-time-pay', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); items = d.items || d.data || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(items)) items = [];

    var body = M.mTablePage({
      stats: [{ label: 'Выплат', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>', color: 'var(--gold)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(p) {
        return M.mCard({
          id: p.id, title: esc(p.employee_name || '—'),
          subtitle: esc(p.payment_type || '—'),
          badge: p.status || '—', badgeColor: M.statusColor(p.status),
          fields: [
            { label: 'Сумма', value: money(p.amount), mono: true },
            { label: 'Статус', value: esc(p.status || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Разовые выплаты' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  GANTT — renderCalcs, renderWorks, renderCombined (desktop-only) ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  /* GANTT — мобильная версия: список задач/работ/просчётов с датами */
  patchMethod('AsgardGanttFullPage', 'renderCalcs', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var estimates = [];
    try { estimates = await AsgardDB.all('estimates') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    estimates.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    var body = M.mTablePage({
      stats: [
        { label: 'Просчётов', value: estimates.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>', color: 'var(--info)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск просчёта...' } },
      items: estimates,
      renderCard: function(e) {
        return M.mCard({
          id: e.id, title: esc(e.tender_title || e.title || 'Просчёт #' + e.id),
          subtitle: esc(e.customer_name || ''),
          badge: e.approval_status || e.status || '—',
          badgeColor: M.statusColor(e.approval_status || e.status),
          fields: [
            { label: 'Начало', value: fmtDate(e.start_date || e.created_at) },
            { label: 'Окончание', value: fmtDate(e.end_date) },
            { label: 'Сумма', value: money(e.total || e.amount), mono: true }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Гантт: Просчёты' });
  });

  patchMethod('AsgardGanttFullPage', 'renderWorks', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var works = [];
    try { works = await AsgardDB.all('works') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    works.sort(function(a, b) { return String(b.start_date || b.created_at || '').localeCompare(String(a.start_date || a.created_at || '')); });

    var body = M.mTablePage({
      stats: [
        { label: 'Работ', value: works.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' },
        { label: 'Активных', value: works.filter(function(w) { return ['в работе','монтаж','пуско-наладка'].indexOf(norm(w.work_status)) !== -1; }).length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск работы...' } },
      items: works,
      renderCard: function(w) {
        // Прогресс-бар
        var pct = Number(w.progress || 0);
        var progressBar = '<div class="m-progress-inline"><div class="m-progress-inline-fill" style="width:' + Math.min(100, pct) + '%"></div></div>';
        return M.mCard({
          id: w.id, title: esc(w.short_title || w.object_name || 'Работа #' + w.id),
          subtitle: esc(w.customer_name || ''),
          badge: w.work_status || '—', badgeColor: M.statusColor(w.work_status),
          fields: [
            { label: 'Начало', value: fmtDate(w.start_date) },
            { label: 'Окончание', value: fmtDate(w.end_date) },
            { label: 'Контракт', value: money(w.contract_value), mono: true },
            { label: 'Прогресс', value: pct + '%' + progressBar, full: true }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Гантт: Работы' });
  });

  patchMethod('AsgardGanttFullPage', 'renderCombined', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var works = [];
    try { works = await AsgardDB.all('works') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var estimates = [];
    try { estimates = await AsgardDB.all('estimates') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var activeWorks = works.filter(function(w) { return ['в работе','монтаж','пуско-наладка'].indexOf(norm(w.work_status)) !== -1; });
    var pendingCalcs = estimates.filter(function(e) { return e.approval_status === 'sent' || !e.approval_status; });

    // Tabs: Работы | Просчёты
    var tabsHtml = '<div class="m-tabs-scroll">' +
      '<button class="m-tab-btn m-tab-active" data-tab="works"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Работы (' + activeWorks.length + ')</button>' +
      '<button class="m-tab-btn" data-tab="calcs"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg> Просчёты (' + pendingCalcs.length + ')</button>' +
    '</div>';

    var worksHtml = '<div id="tab-works">' + (activeWorks.length > 0 ? M.mList(activeWorks, function(w) {
      var pct = Number(w.progress || 0);
      return M.mCard({
        id: w.id, title: esc(w.short_title || w.object_name || ''),
        badge: w.work_status || '—', badgeColor: M.statusColor(w.work_status),
        fields: [
          { label: 'Сроки', value: fmtDate(w.start_date) + ' — ' + fmtDate(w.end_date) },
          { label: 'Прогресс', value: pct + '%' }
        ], onClick: true
      });
    }) : M.mEmpty('Нет активных работ')) + '</div>';

    var calcsHtml = '<div id="tab-calcs" class="m-hidden">' + (pendingCalcs.length > 0 ? M.mList(pendingCalcs, function(e) {
      return M.mCard({
        id: e.id, title: esc(e.tender_title || e.title || ''),
        badge: e.approval_status || '—', badgeColor: M.statusColor(e.approval_status),
        fields: [
          { label: 'Сумма', value: money(e.total), mono: true },
          { label: 'Создано', value: fmtDate(e.created_at) }
        ], onClick: true
      });
    }) : M.mEmpty('Нет просчётов')) + '</div>';

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mStats([
        { label: 'Работ', value: works.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' },
        { label: 'Просчётов', value: estimates.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>', color: 'var(--gold)' }
      ]) + tabsHtml + worksHtml + calcsHtml + '</div>';
    await layout(body, { title: title || 'Гантт' });

    // Tab switching
    document.querySelectorAll('.m-tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.m-tab-btn').forEach(function(b) { b.classList.remove('m-tab-active'); });
        btn.classList.add('m-tab-active');
        var tab = btn.dataset.tab;
        var tw = document.getElementById('tab-works');
        var tc = document.getElementById('tab-calcs');
        if (tw) tw.classList.toggle('m-hidden', tab !== 'works');
        if (tc) tc.classList.toggle('m-hidden', tab !== 'calcs');
      });
    });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PERMIT APPLICATIONS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchMethod('AsgardPermitApplications', 'render', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var emps = [];
    try { emps = await AsgardDB.all('employees') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    emps.sort(function(a, b) { return String(a.fio || '').localeCompare(String(b.fio || ''), 'ru'); });

    var body = M.mTablePage({
      stats: [{ label: 'Сотрудников', value: emps.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', color: 'var(--info)' }],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск сотрудника...' },
        actions: [{ id: 'btnNewApp', label: 'Новая заявка', icon: '+', cls: 'primary' }]
      },
      items: emps,
      renderCard: function(e) {
        var permits = Array.isArray(e.permits) ? e.permits : [];
        var badgesHtml = permits.slice(0, 4).map(function(p) { return M.mBadge(esc(p), 'info'); }).join(' ');
        return M.mCard({
          id: e.id, title: esc(e.fio || '—'),
          subtitle: esc(e.role_tag || '—'),
          fields: [
            { label: 'Допуски', value: permits.length ? badgesHtml : '—', full: true }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Заявки на разрешения' });

    document.getElementById('btnNewApp')?.addEventListener('click', function() {
      location.hash = '#/permit-application-form';
    });
  });

  patchMethod('AsgardPermitApplications', 'renderForm', async function({ layout, title, query }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var formHtml = M.mForm([
      { label: 'Подрядчик', id: 'fContractor', type: 'text', placeholder: 'Название организации', required: true },
      { label: 'Email подрядчика', id: 'fEmail', type: 'email', placeholder: 'email@company.ru' },
      { label: 'Тема заявки', id: 'fTitle', type: 'text', placeholder: 'Оформление допуска', required: true },
      { label: 'Сопроводительное письмо', id: 'fCover', type: 'textarea', placeholder: 'Описание...' }
    ], { submitLabel: 'Отправить заявку', cancelLabel: 'Отмена' });

    var body = '<div class="m-page" data-mobile-native="1">' +
      '<div class="m-back-wrap"><a href="#/permit-applications" class="m-back-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> К заявкам</a></div>' +
      M.mSection(query && query.id ? 'Редактирование заявки' : 'Новая заявка', formHtml) +
    '</div>';
    await layout(body, { title: title || 'Заявка на разрешение' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CHAT  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardChat', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;
    var messages = [];
    try { messages = await AsgardDB.all('chat_messages') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    messages.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    /* Group by chat */
    var chats = {};
    messages.forEach(function(m) {
      var key = m.chat_type === 'direct' ? 'dm_' + [m.user_id, m.to_user_id].sort().join('_') :
                m.entity_id ? m.chat_type + '_' + m.entity_id : 'general';
      if (!chats[key]) chats[key] = { key: key, title: m.entity_title || m.chat_type || 'Общий', lastMsg: m, messages: [], unread: 0 };
      chats[key].messages.push(m);
      if (!m.is_read && m.user_id !== user.id) chats[key].unread++;
    });
    var chatList = Object.values(chats);
    chatList.sort(function(a, b) { return String(b.lastMsg.created_at || '').localeCompare(String(a.lastMsg.created_at || '')); });

    var body = M.mTablePage({
      stats: [
        { label: 'Чатов', value: chatList.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>', color: 'var(--info)' },
        { label: 'Сообщений', value: messages.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: chatList,
      renderCard: function(chat) {
        var last = chat.lastMsg;
        var preview = (last.text || '').substring(0, 60);
        return M.mCard({
          title: esc(chat.title || 'Чат'),
          subtitle: esc(last.user_name || '') + ': ' + esc(preview),
          badge: chat.unread > 0 ? chat.unread + '' : '', badgeColor: 'gold',
          fields: [
            { label: 'Последнее', value: fmtDateShort(last.created_at) },
            { label: 'Сообщений', value: chat.messages.length }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Чат' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');

  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  EMPLOYEE COLLECTIONS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardEmployeeCollections', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var collections = [];
    try {
      var resp = await fetch('/api/employee-collections', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); collections = d.collections || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(collections)) collections = [];

    var body = M.mTablePage({
      stats: [{ label: 'Подборок', value: collections.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: collections,
      renderCard: function(c) {
        return M.mCard({
          id: c.id, title: esc(c.name || '—'),
          subtitle: esc(c.description || ''),
          fields: [
            { label: 'Сотрудников', value: c.employee_count || 0 },
            { label: 'Создал', value: esc(c.created_by_name || '—') },
            { label: 'Обновлено', value: fmtDate(c.updated_at) }
          ],
          onClick: true
        });
      }
    });
    await layout(body, { title: title || 'Подборки' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  ENGINEER DASHBOARD  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardEngineerDashboard', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var stats = {}, byPm = [];
    try {
      var r1 = await fetch('/api/equipment/stats/summary', { headers: { 'Authorization': 'Bearer ' + token } });
      if (r1.ok) stats = await r1.json();
      var r2 = await fetch('/api/equipment/analytics/by-pm', { headers: { 'Authorization': 'Bearer ' + token } });
      if (r2.ok) { var d = await r2.json(); byPm = d.data || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(byPm)) byPm = [];

    var total = stats.total || 0;
    var onWh = stats.on_warehouse || 0;
    var issued = stats.issued || 0;
    var inRep = stats.in_repair || 0;
    var body = '';

    // Sber-style big number
    body += M.mBigNumber({ value: String(total), suffix: 'ед.', subtitle: 'Всего оборудования' });

    // Widget grid: key metrics
    body += M.mWidgetGrid([
      { title: 'На складе', value: String(onWh), icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t)" stroke-width="2"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>', subtitle: total > 0 ? Math.round((onWh / total) * 100) + '%' : '0%' },
      { title: 'Выдано', value: String(issued), icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', subtitle: total > 0 ? Math.round((issued / total) * 100) + '%' : '0%' }
    ]);

    // Category breakdown (Sber-style)
    body += M.mSection('По категориям',
      M.mCategoryItem({ name: 'На объектах', amount: String(issued) + ' ед.', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', iconBg: 'rgba(255,193,7,0.15)', right: { value: String(issued), sub: total > 0 ? Math.round((issued/total)*100)+'%' : '0%' } }) +
      M.mCategoryItem({ name: 'На складе', amount: String(onWh) + ' ед.', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>', iconBg: 'rgba(33,191,115,0.15)', right: { value: String(onWh), sub: total > 0 ? Math.round((onWh/total)*100)+'%' : '0%' } }) +
      M.mCategoryItem({ name: 'В ремонте', amount: String(inRep) + ' ед.', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>', iconBg: 'rgba(239,68,68,0.15)', right: { value: String(inRep), sub: total > 0 ? Math.round((inRep/total)*100)+'%' : '0%' } })
    );

    // PM list with collapse
    body += M.mSection('По руководителям', M.mList(byPm, function(pm) {
      return M.mCard({
        id: pm.pm_id || pm.id,
        title: esc(pm.pm_name || pm.name || '\u2014'),
        subtitle: (pm.equipment_count || 0) + ' ед. техники',
        fields: [
          { label: 'На объектах', value: pm.on_objects || 0 },
          { label: 'На складе', value: pm.on_warehouse || 0 },
          { label: 'В ремонте', value: pm.in_repair || 0 }
        ]
      });
    }), { collapsible: true });

    await layout(body, { title: title || 'Дашборд ГИ' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  MY EQUIPMENT  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardMyEquipment', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var items = [];
    try {
      var resp = await fetch('/api/equipment/by-holder/' + auth.user.id, { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); items = d.items || d.data || d || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }
    if (!Array.isArray(items)) items = [];

    var CONDITIONS = { 'new': '<span class="m-dot m-dot-green"></span> Новое', 'good': '<span class="m-dot m-dot-green"></span> Хорошее', 'satisfactory': '<span class="m-dot m-dot-yellow"></span> Удовл.', 'poor': '<span class="m-dot m-dot-orange"></span> Плохое', 'broken': '<span class="m-dot m-dot-red"></span> Сломано' };

    var body = M.mTablePage({
      stats: [{ label: 'Оборудования', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' }],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(eq) {
        return M.mCard({
          id: eq.id, title: esc(eq.name || '—'),
          subtitle: (eq.category_icon || '') + ' ' + esc(eq.category_name || ''),
          badge: esc(eq.condition || '—'), badgeColor: (eq.condition === 'good' || eq.condition === 'new') ? 'ok' : eq.condition === 'poor' || eq.condition === 'broken' ? 'err' : 'warn',
          fields: [
            { label: 'Инв. №', value: esc(eq.inventory_number || '—'), mono: true },
            { label: 'Серийный', value: esc(eq.serial_number || '—'), mono: true },
            { label: 'Объект', value: esc(eq.object_name || '—') },
            { label: 'Состояние', value: CONDITIONS[eq.condition] || esc(eq.condition || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Моё оборудование' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  OBJECT MAP  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardObjectMap', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    /* Map is Leaflet-based, Leaflet is already responsive. Fallback to desktop render */
    throw new Error('PASSTHROUGH');
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PM ANALYTICS + TO ANALYTICS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  function renderAnalyticsMobile(moduleName, apiUrl, titleDefault, columns) {
    patchModule(moduleName, async function({ layout, title }) {
      var auth = await AsgardAuth.requireUser();
      if (!auth) { location.hash = '#/login'; return; }
      var token = localStorage.getItem('asgard_token');
      var data = [];
      try {
        var resp = await fetch(apiUrl, { headers: { 'Authorization': 'Bearer ' + token } });
        if (resp.ok) { var d = await resp.json(); data = d.team || d.data || d || []; }
      } catch(e) { console.warn('[MobileRender]', e.message || e); }
      if (!Array.isArray(data)) data = [];

      var body = '';

      // Sber big number - team size
      body += M.mBigNumber({ value: String(data.length), suffix: 'чел.', subtitle: 'Аналитика по сотрудникам' });

      // Build mini chart from first money column if available
      var moneyCol = columns.find(function(c) { return c.money; });
      if (moneyCol && data.length > 0) {
        var chartData = data.slice(0, 8).map(function(item) {
          return { label: (item.name || item.employee_name || '').split(' ')[0], value: Number(item[moneyCol.key] || 0) };
        });
        body += '<div class="m-chart-container">';
        body += M.mMiniChart(chartData, { height: 70, barWidth: 20, barGap: 6, accentColor: 'var(--ok-t, #21bf73)' });
        body += '<div class="m-chart-labels">';
        chartData.forEach(function(d) {
          body += '<span class="m-chart-label">' + esc(d.label) + '</span>';
        });
        body += '</div></div>';
      }

      // Category items for top performers (Sber-style)
      if (data.length > 0 && moneyCol) {
        var sorted = data.slice().sort(function(a, b) { return Number(b[moneyCol.key] || 0) - Number(a[moneyCol.key] || 0); });
        var topContent = '';
        sorted.slice(0, 5).forEach(function(item, i) {
          var colors = ['rgba(33,191,115,0.15)', 'rgba(88,166,255,0.15)', 'rgba(255,193,7,0.15)', 'rgba(156,120,255,0.15)', 'rgba(239,68,68,0.15)'];
          topContent += M.mCategoryItem({
            name: (i + 1) + '. ' + (item.name || item.employee_name || '—'),
            amount: moneyCol.money ? money(item[moneyCol.key]) : String(item[moneyCol.key] || 0),
            icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
            iconBg: colors[i % colors.length]
          });
        });
        body += M.mSection('Топ по ' + moneyCol.label.toLowerCase(), topContent);
      }

      // Full list (collapsible)
      body += M.mSection('Все сотрудники', M.mList(data, function(item) {
        return M.mCard({
          title: esc(item.name || item.employee_name || '—'),
          fields: columns.map(function(col) {
            return { label: col.label, value: col.money ? money(item[col.key]) : String(item[col.key] || 0), mono: !!col.money };
          })
        });
      }), { collapsible: true, action: data.length + ' чел.' });

      await layout(body, { title: title || titleDefault });
    });
  }

  renderAnalyticsMobile('AsgardPMAnalytics', '/api/pm-analytics', 'Аналитика РП', [
    { label: 'Работ', key: 'total_works' },
    { label: 'Активных', key: 'active' },
    { label: 'Завершено', key: 'completed' },
    { label: 'Контракты', key: 'contracts_sum', money: true },
    { label: 'Прибыль', key: 'profit', money: true }
  ]);

  renderAnalyticsMobile('AsgardTOAnalytics', '/api/to-analytics', 'Аналитика ТО', [
    { label: 'Тендеров', key: 'total' },
    { label: 'Выиграно', key: 'won' },
    { label: 'Проиграно', key: 'lost' },
    { label: 'Сумма побед', key: 'sum_won', money: true },
    { label: 'Конверсия', key: 'conversion' }
  ]);


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  ADMIN SETTINGS (Telegram, Mango, Sync) — desktop-only  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  /* TELEGRAM — мобильные настройки бота */
  patchMethod('AsgardTelegram', 'renderSettings', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var tgSettings = {};
    try { tgSettings = await AsgardDB.get('settings', 'telegram') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mSection('Telegram Bot', M.mForm([
        { label: 'Bot Token', id: 'tgToken', type: 'text', value: tgSettings.bot_token || '', placeholder: '123456:ABC-DEF...' },
        { label: 'Chat ID (основной)', id: 'tgChatId', type: 'text', value: tgSettings.chat_id || '', placeholder: '-1001234567890' },
        { label: 'Webhook URL', id: 'tgWebhook', type: 'url', value: tgSettings.webhook_url || '', placeholder: 'https://...' }
      ], { submitLabel: 'Сохранить', submitId: 'btnSaveTg' })) +
      M.mSection('Уведомления',
        '<div class="m-card"><div class="m-card-fields">' +
          '<div class="m-field"><span class="m-field-label">Тендеры</span><span class="m-field-value">' + (tgSettings.notify_tenders !== false ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Вкл' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--err-t, #ef4444)" stroke-width="2" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg> Выкл') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">Задачи</span><span class="m-field-value">' + (tgSettings.notify_tasks !== false ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Вкл' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--err-t, #ef4444)" stroke-width="2" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg> Выкл') + '</span></div>' +
          '<div class="m-field"><span class="m-field-label">Согласования</span><span class="m-field-value">' + (tgSettings.notify_approvals !== false ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Вкл' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--err-t, #ef4444)" stroke-width="2" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg> Выкл') + '</span></div>' +
        '</div></div>'
      ) +
    '</div>';
    await layout(body, { title: title || 'Telegram' });
  });

  /* MANGO — настройки телефонии */
  patchMethod('AsgardMango', 'renderSettings', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var mangoSettings = {};
    try { mangoSettings = await AsgardDB.get('settings', 'mango') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mSection('Mango Office', M.mForm([
        { label: 'API Key', id: 'mangoKey', type: 'text', value: mangoSettings.api_key || '', placeholder: 'Ваш API ключ' },
        { label: 'API Salt', id: 'mangoSalt', type: 'password', value: mangoSettings.api_salt ? '••••••' : '', placeholder: 'Salt' },
        { label: 'Vpbx API URL', id: 'mangoUrl', type: 'url', value: mangoSettings.api_url || 'https://app.mango-office.ru/vpbx/', placeholder: 'https://...' }
      ], { submitLabel: 'Сохранить', submitId: 'btnSaveMango' })) +
      M.mSection('Статус', '<div class="m-card"><div class="m-card-fields">' +
        '<div class="m-field"><span class="m-field-label">Подключение</span><span class="m-field-value">' + (mangoSettings.connected ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Подключено' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--warn, #f59e0b)" stroke-width="2" style="vertical-align:-2px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg> Не подключено') + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Последний звонок</span><span class="m-field-value">' + fmtDate(mangoSettings.last_call_at) + '</span></div>' +
      '</div></div>') +
    '</div>';
    await layout(body, { title: title || 'Телефония' });
  });

  /* SYNC — настройки PostgreSQL синхронизации */
  patchMethod('AsgardSync', 'renderSettings', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var syncSettings = {};
    try { syncSettings = await AsgardDB.get('settings', 'sync') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mSection('PostgreSQL Sync', M.mForm([
        { label: 'Host', id: 'syncHost', type: 'text', value: syncSettings.pg_host || '', placeholder: 'localhost' },
        { label: 'Port', id: 'syncPort', type: 'text', value: syncSettings.pg_port || '5432', placeholder: '5432' },
        { label: 'Database', id: 'syncDb', type: 'text', value: syncSettings.pg_database || '', placeholder: 'asgard_crm' },
        { label: 'User', id: 'syncUser', type: 'text', value: syncSettings.pg_user || '', placeholder: 'postgres' },
        { label: 'Password', id: 'syncPass', type: 'password', value: syncSettings.pg_password ? '••••••' : '', placeholder: '••••••' }
      ], { submitLabel: 'Сохранить', submitId: 'btnSaveSync' })) +
      M.mSection('Статус синхронизации', '<div class="m-card"><div class="m-card-fields">' +
        '<div class="m-field"><span class="m-field-label">Статус</span><span class="m-field-value">' + (syncSettings.is_active ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Активна' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="4" height="16" x="6" y="4"/><rect width="4" height="16" x="14" y="4"/></svg> Остановлена') + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Последняя синхр.</span><span class="m-field-value">' + fmtDate(syncSettings.last_sync_at) + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Записей</span><span class="m-field-value">' + (syncSettings.records_count || '—') + '</span></div>' +
      '</div></div>') +
    '</div>';
    await layout(body, { title: title || 'PostgreSQL Sync' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  BIG SCREEN — redirect to /home on mobile  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardBigScreen', async function({ layout, title }) {
    location.hash = '#/home';
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  KANBAN  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardKanban', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var token = localStorage.getItem('asgard_token');
    var tasks = [];
    try {
      var resp = await fetch('/api/tasks?limit=500', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); tasks = d.tasks || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var users = [];
    try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var userMap = {};
    users.forEach(function(u) { userMap[u.id] = u; });

    var STATUSES = ['Новая', 'В работе', 'Выполнена', 'Закрыта'];
    var statusCards = STATUSES.map(function(status) {
      var filtered = tasks.filter(function(t) { return t.status === status; });
      return M.mSection(status + ' (' + filtered.length + ')', filtered.length > 0 ?
        M.mList(filtered, function(t) {
          var assignee = userMap[t.assigned_to] || {};
          return M.mCard({
            id: t.id, title: esc(t.title || 'Без названия'),
            subtitle: esc(assignee.name || '— Не назначен'),
            badge: t.priority === 'high' ? '<span class="m-dot m-dot-red"></span>' : t.priority === 'low' ? '<span class="m-dot m-dot-green"></span>' : '<span class="m-dot m-dot-yellow"></span>',
            badgeColor: t.priority === 'high' ? 'err' : t.priority === 'low' ? 'ok' : 'warn',
            fields: [
              { label: 'Дедлайн', value: t.due_date ? fmtDate(t.due_date) : '—' },
              { label: 'Исполнитель', value: esc(assignee.name || '—') }
            ],
            onClick: true
          });
        }) : M.mEmpty('Нет задач')
      );
    });

    var body = '<div class="m-page" data-mobile-native="1">' +
      M.mStats([
        { label: 'Все', value: tasks.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' },
        { label: 'Новые', value: tasks.filter(function(t) { return t.status === 'Новая'; }).length, icon: '🆕', color: 'var(--purple-l)' },
        { label: 'В работе', value: tasks.filter(function(t) { return t.status === 'В работе'; }).length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="var(--amber, #f59e0b)" stroke="none" style="vertical-align:-2px"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>', color: 'var(--amber)' }
      ]) +
      statusCards.join('') +
    '</div>';
    await layout(body, { title: title || 'Канбан' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CUSTOM DASHBOARD (/home)  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardCustomDashboard', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    /* Load key data for dashboard */
    var tenders = [], works = [], tasks = [], notifications = [];
    try { tenders = await AsgardDB.all('tenders') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    try { works = await AsgardDB.all('works') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    try { notifications = await AsgardDB.all('notifications') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    try {
      var token = localStorage.getItem('asgard_token');
      var resp = await fetch('/api/tasks?limit=20&status=В работе', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); tasks = d.tasks || []; }
    } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var activeTenders = tenders.filter(function(t) { return norm(t.status) !== 'закрыт' && norm(t.status) !== 'проигран'; }).length;
    var activeWorks = works.filter(function(w) { return norm(w.work_status) !== 'завершено' && norm(w.work_status) !== 'закрыто'; }).length;
    var unreadNotifs = notifications.filter(function(n) { return !n.is_read; }).length;

    /* Time-aware greeting with animated icon */
    var greet = M.getTimeGreeting();

    var statsHtml = M.mStats([
      { label: 'Тендеры', value: activeTenders, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--gold)' },
      { label: 'Работы', value: activeWorks, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' },
      { label: 'Задачи', value: tasks.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' },
      { label: 'Уведомления', value: unreadNotifs, icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>', color: unreadNotifs > 0 ? 'var(--err-t)' : 'var(--t3)' }
    ]);

    /* My tasks widget */
    var tasksWidget = '';
    if (tasks.length > 0) {
      tasksWidget = M.mSection('Мои задачи', M.mList(tasks.slice(0, 5), function(t) {
        return M.mCard({
          id: t.id, title: esc(t.title || 'Без названия'),
          badge: t.status || '', badgeColor: M.statusColor(t.status),
          fields: [
            { label: 'Дедлайн', value: t.due_date ? fmtDate(t.due_date) : '—' },
            { label: 'Приоритет', value: t.priority === 'high' ? '<span class="m-dot m-dot-red"></span> Высокий' : t.priority === 'low' ? '<span class="m-dot m-dot-green"></span> Низкий' : '<span class="m-dot m-dot-yellow"></span> Средний' }
          ],
          onClick: true
        });
      }));
    }

    /* Recent notifications */
    var notifsWidget = '';
    var recentNotifs = notifications.filter(function(n) { return !n.is_read; }).slice(0, 3);
    if (recentNotifs.length > 0) {
      notifsWidget = M.mSection('Непрочитанные', M.mList(recentNotifs, function(n) {
        return M.mCard({
          id: n.id,
          title: esc(n.title || n.message || '—'),
          subtitle: timeAgo(n.created_at),
          badge: n.type || '', badgeColor: M.statusColor(n.type)
        });
      }));
    }

    var body = '<div class="m-page" data-mobile-native="1">' +
      '<div class="m-card m-card-accent m-greeting-card">' +
        '<div class="m-greeting-icon">' + greet.icon + '</div>' +
        '<div class="m-greeting-text">' + greet.text + ',</div>' +
        '<div class="m-greeting-name">' + esc(user.name || user.login || '') + '</div>' +
      '</div>' +
      statsHtml + tasksWidget + notifsWidget +
    '</div>';

    await layout(body, { title: title || 'Главная' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  WAREHOUSE (API-based, different from WarehousePage)  ██████
     Важно: AsgardWarehouse = AsgardEquipmentPage (алиас)
     patchModule('AsgardWarehouse') уже сделан выше через IndexedDB,
     но реальный модуль использует REST API. Перезаписываем.
     ═══════════════════════════════════════════════════════════════════════════ */
  (function() {
    var mod = window.AsgardWarehouse;
    if (!mod) return;
    var orig = mod.render;
    mod.render = async function(opts) {
      if (!M.isMobile()) return orig.call(mod, opts);
      try {
        var auth = await AsgardAuth.requireUser();
        if (!auth) { location.hash = '#/login'; return; }
        var token = localStorage.getItem('asgard_token');
        var items = [], stats = {};
        try {
          var r1 = await fetch('/api/equipment', { headers: { 'Authorization': 'Bearer ' + token } });
          if (r1.ok) { var d = await r1.json(); items = d.items || d.data || d || []; }
          var r2 = await fetch('/api/equipment/stats/summary', { headers: { 'Authorization': 'Bearer ' + token } });
          if (r2.ok) stats = await r2.json();
        } catch(e) { console.warn('[MobileRender]', e.message || e); }
        if (!Array.isArray(items)) items = [];

        var STATUSES = { on_warehouse: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg> На складе', issued: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Выдано', in_repair: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--warn, #f59e0b)" stroke-width="2" style="vertical-align:-2px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg> В ремонте', decommissioned: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--err-t, #ef4444)" stroke-width="2" style="vertical-align:-2px"><circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/></svg> Списано' };

        var body = M.mTablePage({
          stats: [
            { label: 'Всего', value: stats.total || items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/></svg>', color: 'var(--info)' },
            { label: 'На складе', value: stats.on_warehouse || 0, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>', color: 'var(--ok-t)' },
            { label: 'Выдано', value: stats.issued || 0, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--warn-t)' },
            { label: 'В ремонте', value: stats.in_repair || 0, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--warn, #f59e0b)" stroke-width="2" style="vertical-align:-2px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>', color: 'var(--err-t)' }
          ],
          toolbar: { search: { id: 'mSearch', placeholder: 'Поиск оборудования...' } },
          items: items,
          renderCard: function(eq) {
            return M.mCard({
              id: eq.id, title: esc(eq.name || '—'),
              subtitle: (eq.category_icon || '') + ' ' + esc(eq.category_name || ''),
              badge: STATUSES[eq.status] || esc(eq.status || '—'),
              badgeColor: eq.status === 'on_warehouse' ? 'ok' : eq.status === 'issued' ? 'warn' : eq.status === 'in_repair' ? 'err' : 'draft',
              fields: [
                { label: 'Инв. №', value: esc(eq.inventory_number || '—'), mono: true },
                { label: 'Серийный', value: esc(eq.serial_number || '—'), mono: true },
                { label: 'Объект', value: esc(eq.object_name || eq.warehouse_name || '—') },
                { label: 'Балансовая', value: eq.book_value ? money(eq.book_value) : '—', mono: true }
              ],
              onClick: true
            });
          }
        });
        await opts.layout(body, { title: opts.title || 'Склад ТМЦ' });
      } catch(e) {
        console.error('[MobileRenders] AsgardWarehouse error:', e);
        return orig.call(mod, opts);
      }
    };
    _patchCount++;
  })();


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CHAT GROUPS / MESSENGER  ██████
     Роутер: /messenger → AsgardChatGroups.render({layout})
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardChatGroups', async function(opts) {
    var layoutFn = opts && opts.layout;
    if (!layoutFn) return;
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;
    var token = localStorage.getItem('asgard_token');

    // v8.0.0 — Telegram-level chat
    var chats = [];
    try {
      var resp = await fetch('/api/chat-groups', { headers: { 'Authorization': 'Bearer ' + token } });
      if (resp.ok) { var d = await resp.json(); chats = d.chats || d.groups || d || []; }
    } catch(e) { M.showError && M.showError('Ошибка загрузки чатов'); }
    if (!Array.isArray(chats)) chats = [];
    chats.sort(function(a, b) {
      return String(b.last_message_at || b.created_at || '').localeCompare(String(a.last_message_at || a.created_at || ''));
    });

    // Check if we need to open a specific chat (deep link)
    var params = new URLSearchParams(location.hash.split('?')[1] || '');
    var openChatId = params.get('id');

    // Render chat list (Telegram-style)
    // Group chats by type
    var directChats = chats.filter(function(c) { return !c.is_group && !c.project_id; });
    var groupChats = chats.filter(function(c) { return c.is_group && !c.project_id; });
    var projectChats = chats.filter(function(c) { return !!c.project_id; });

    function formatChatItem(c) {
      var chatName = c.is_group ? (c.name || 'Группа') : (c.direct_user_name || 'Чат');
      var lastMsg = c.last_message ? c.last_message.substring(0, 50) : '';
      var timeStr = '';
      if (c.last_message_at) {
        var d = new Date(c.last_message_at);
        var now = new Date();
        timeStr = d.toDateString() === now.toDateString() ? d.toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : d.toLocaleDateString('ru', {day:'numeric',month:'short'});
      }
      return M.mChatListItem({ id: c.id, name: chatName, avatar: c.avatar_url || '', lastMessage: lastMsg, time: timeStr, unread: c.unread_count || 0, online: (c.last_seen && (Date.now() - new Date(c.last_seen).getTime()) < 300000) || false });
    }

    function chatSection(title, items) {
      if (!items.length) return '';
      return '<div class="m-chat-section-title">' + title + '</div>' + items.map(formatChatItem).join('');
    }

    var chatListHtml = chats.length > 0
      ? (chatSection('Личные', directChats) + chatSection('Групповые', groupChats) + chatSection('По объектам', projectChats)) || chats.map(formatChatItem).join('')
      : M.mEmpty('Нет чатов. Начните переписку!', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>');

    var searchBar = '<div class="m-chat-search-wrap">' +
      '<input class="m-search-input m-chat-search-field" id="mChatSearch" placeholder="Поиск чатов...">' +
      '</div>';

    var body = '<div class="m-page" data-mobile-native="1">' +
      '<div id="chatListView">' + searchBar +
        '<div id="chatListContainer">' + chatListHtml + '</div>' +
      '</div>' +
      '<div id="chatConvView" style="display:none">' +
        '<div id="chatConvHeader"></div>' +
        '<div class="m-chat-messages" id="chatMessages"></div>' +
        M.mTypingIndicator('') +
        M.mChatInput() +
        '<button class="m-chat-scroll-down" id="chatScrollDown">\u2193</button>' +
      '</div>' +
      M.mChatContextMenu() +
    '</div>';
    await layoutFn(body, { title: 'Мессенджер' });

    // === Chat list interactions ===
    var chatListContainer = document.getElementById('chatListContainer');
    var chatListView = document.getElementById('chatListView');
    var chatConvView = document.getElementById('chatConvView');
    var chatMessages = document.getElementById('chatMessages');
    var chatInput = document.getElementById('chatInput');
    var chatSendBtn = document.getElementById('chatSendBtn');
    var chatVoiceBtn = document.getElementById('chatVoiceBtn');
    var chatScrollDown = document.getElementById('chatScrollDown');
    var chatReplyBar = document.getElementById('chatReplyBar');
    var chatCtxMenu = document.getElementById('chatCtxMenu');
    var currentChatId = null;
    var currentChatName = '';
    var replyToMsg = null;

    // Search
    var searchInput = document.getElementById('mChatSearch');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        _debounce('search0', function() {
        var q = this.value.toLowerCase();
        var items = chatListContainer.querySelectorAll('.m-chat-list-item');
        items.forEach(function(item) {
          var name = (item.querySelector('.m-chat-name') || {}).textContent || '';
          var preview = (item.querySelector('.m-chat-preview') || {}).textContent || '';
          item.style.display = (name.toLowerCase().includes(q) || preview.toLowerCase().includes(q)) ? '' : 'none';
        });
      }, 250);
        });
    }


    // Pull-to-Refresh for chat list
    (function initChatPTR() {
      var cl = document.getElementById('chatListContainer');
      if (!cl) return;
      var startY = 0, pulling = false, ptrEl = null;
      cl.addEventListener('touchstart', function(e) {
        if (cl.scrollTop <= 0) { startY = e.touches[0].clientY; pulling = true; }
      }, { passive: true });
      cl.addEventListener('touchmove', function(e) {
        if (!pulling) return;
        var dy = e.touches[0].clientY - startY;
        if (dy > 0 && dy < 150) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>\u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435...</span>';
            cl.parentNode.insertBefore(ptrEl, cl);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      cl.addEventListener('touchend', function() {
        if (!pulling) return;
        pulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          fetch('/api/chat-groups', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var chats = data.data || data || [];
            var container = document.getElementById('chatListContainer');
            if (container) {
              container.innerHTML = chats.length
                ? chats.map(function(c) {
                    return M.mChatListItem({
                      id: c.id,
                      name: c.name || c.title || '\u0427\u0430\u0442',
                      lastMessage: c.last_message || '',
                      time: c.last_message_at || '',
                      unread: c.unread_count || 0,
                      online: (c.last_seen && (Date.now() - new Date(c.last_seen).getTime()) < 300000) || false
                    });
                  }).join('')
                : M.mEmpty('\u041D\u0435\u0442 \u0447\u0430\u0442\u043E\u0432', '\uD83D\uDCAC');
            }
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          })
          .catch(function() {
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Open chat
    function openChat(chatId) {
      currentChatId = chatId;
      var chatData = chats.find(function(c) { return String(c.id) === String(chatId); });
      currentChatName = chatData ? (chatData.is_group ? (chatData.name || 'Группа') : (chatData.direct_user_name || 'Чат')) : 'Чат';

      // Render conversation header
      var headerEl = document.getElementById('chatConvHeader');
      headerEl.innerHTML = M.mChatHeader({
        name: currentChatName,
        online: chatData && chatData.last_seen && (Date.now() - new Date(chatData.last_seen).getTime() < 300000),
        lastSeen: chatData && chatData.last_seen ? 'был(a) ' + new Date(chatData.last_seen).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : ''
      });

      // Switch views
      chatListView.style.display = 'none';
      chatConvView.style.display = '';
      // Hide tabbar
      var tabbar = document.querySelector('.m-tabbar');
      if (tabbar) tabbar.style.display = 'none';
      // Hide header
      var header = document.querySelector('.m-header');
      if (header) header.style.display = 'none';

      // Load messages
      loadMessages(chatId);
      // Start typing indicator poll
      if (typeof startTypingPoll === 'function') startTypingPoll();
      if (typeof startMessagePoll === 'function') startMessagePoll();

      // Back button
      var backBtn = document.getElementById('chatBackBtn');
      if (backBtn) {
        backBtn.onclick = function() {
          chatConvView.style.display = 'none';
          chatListView.style.display = '';
          currentChatId = null;
          if (typingPollInterval) clearInterval(typingPollInterval);
          if (tabbar) tabbar.style.display = '';
          if (header) header.style.display = '';
        };
      }
    }

    // Load messages
    async function loadMessages(chatId) {
      chatMessages.innerHTML = M.mSkeleton('card', 5);
      try {
        var resp = await fetch('/api/chat-groups/' + chatId + '/messages?limit=50', {
          headers: { 'Authorization': 'Bearer ' + token }
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        var data = await resp.json();
        var msgs = data.messages || data || [];

        // Group by date
        var lastDate = '';
        var html = '';
        msgs.forEach(function(msg) {
          var msgDate = msg.created_at ? new Date(msg.created_at).toLocaleDateString('ru') : '';
          if (msgDate !== lastDate) {
            var today = new Date().toLocaleDateString('ru');
            var yesterday = new Date(Date.now() - 86400000).toLocaleDateString('ru');
            var dateLabel = msgDate === today ? 'Сегодня' : (msgDate === yesterday ? 'Вчера' : msgDate);
            html += M.mChatDateSep(dateLabel);
            lastDate = msgDate;
          }
          var time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : '';
          html += M.mChatBubble({
            id: msg.id,
            text: msg.text || msg.message || '',
            time: time,
            isMine: String(msg.user_id) === String(user.id),
            senderName: msg.user_name || '',
            status: msg.is_read ? 'read' : 'sent',
            replyTo: msg.reply_to ? { name: msg.reply_to_name || '', text: msg.reply_to_text || '' } : null
          });
        });

        chatMessages.innerHTML = html || M.mEmpty('Нет сообщений. Напишите первое!', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>');
        // Scroll to bottom
        chatMessages.scrollTop = chatMessages.scrollHeight;
      } catch(e) {
        chatMessages.innerHTML = M.mEmpty('Ошибка загрузки сообщений', '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--warn, #f59e0b)" stroke-width="2" style="vertical-align:-2px"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>');
      }
    }

    // Send message
    async function sendMessage() {
      var text = chatInput.value.trim();
      if (!text || !currentChatId) return;
      chatInput.value = '';
      chatInput.style.height = 'auto';
      chatSendBtn.classList.remove('visible');
      chatVoiceBtn.style.display = '';

      // Optimistic UI
      var tempId = 'temp_' + Date.now();
      var now = new Date();
      var bubble = M.mChatBubble({
        id: tempId,
        text: text,
        time: now.toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}),
        isMine: true,
        status: 'sent',
        replyTo: replyToMsg
      });
      chatMessages.insertAdjacentHTML('beforeend', bubble);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      // Extract reply ID BEFORE clearing
      var replyId = replyToMsg ? replyToMsg.id : null;

      // Clear reply
      if (replyToMsg) {
        replyToMsg = null;
        chatReplyBar.style.display = 'none';
      }

      // Send to server
      try {
        var payload = { text: text, chat_group_id: currentChatId };
        if (replyId) payload.reply_to_id = replyId;
        await fetch('/api/chat-groups/' + currentChatId + '/messages', {
          method: 'POST',
          headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
      } catch(e) { console.warn('[Chat] send failed:', e.message || e); }
    }

    // Input interactions
    if (chatInput) {
      chatInput.addEventListener('input', function() {
        // Auto-grow
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        // Toggle send/voice
        if (this.value.trim()) {
          chatSendBtn.classList.add('visible');
          chatVoiceBtn.style.display = 'none';
        } else {
          chatSendBtn.classList.remove('visible');
          chatVoiceBtn.style.display = '';
        }
      });
      chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });

      // Typing indicator — send typing event every 3 seconds
      var typingTimer = null;
      var lastTypingSent = 0;
      chatInput.addEventListener('input', function() {
        var now = Date.now();
        if (currentChatId && now - lastTypingSent > 3000) {
          lastTypingSent = now;
          fetch('/api/chat-groups/' + currentChatId + '/typing', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token }
          }).catch(function() {});
        }
        clearTimeout(typingTimer);
        typingTimer = setTimeout(function() { lastTypingSent = 0; }, 5000);
      });

      // Poll for typing indicator from others
      var chatTypingEl = document.getElementById('chatTyping');
      var typingPollInterval = null;
      function startTypingPoll() {
        if (typingPollInterval) clearInterval(typingPollInterval);
        typingPollInterval = setInterval(function() {
          if (!currentChatId) return;
          fetch('/api/chat-groups/' + currentChatId + '/typing', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var typers = data.typing || [];
            var others = typers.filter(function(t) { return String(t.user_id) !== String(user.id); });
            if (chatTypingEl) {
              if (others.length > 0) {
                var names = others.map(function(t) { return t.name || 'Кто-то'; }).join(', ');
                chatTypingEl.querySelector('.m-chat-typing-name').textContent = names + ' печатает...';
                chatTypingEl.style.display = '';
              } else {
                chatTypingEl.style.display = 'none';
              }
            }
          })
          .catch(function() {});
        }, 3000);
      }
    }

    // ── New message polling (Telegram-level real-time) ──
    var lastMsgId = 0;
    var msgPollInterval = null;
    function startMessagePoll() {
      // Determine last message ID from DOM
      var allBubbles = chatMessages.querySelectorAll('.m-chat-bubble[data-id]');
      if (allBubbles.length) {
        var ids = Array.prototype.map.call(allBubbles, function(b) { return parseInt(b.dataset.id) || 0; });
        lastMsgId = Math.max.apply(null, ids);
      }
      if (msgPollInterval) clearInterval(msgPollInterval);
      msgPollInterval = setInterval(async function() {
        if (!currentChatId) return;
        try {
          var url = '/api/chat-groups/' + currentChatId + '/messages?limit=50';
          if (lastMsgId) url += '&after=' + lastMsgId;
          var resp = await fetch(url, { headers: { 'Authorization': 'Bearer ' + token } });
          if (!resp.ok) return;
          var data = await resp.json();
          var msgs = data.messages || data || [];
          if (!msgs.length) return;
          msgs.forEach(function(msg) {
            var msgId = parseInt(msg.id) || 0;
            if (msgId <= lastMsgId) return;
            // Skip own messages (already shown as optimistic)
            if (String(msg.user_id) === String(user.id) && chatMessages.querySelector('[data-id="temp_"]')) return;
            var time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : '';
            var bubble = M.mChatBubble({
              id: msg.id,
              text: msg.text || msg.message || '',
              time: time,
              isMine: String(msg.user_id) === String(user.id),
              senderName: msg.user_name || '',
              status: msg.is_read ? 'read' : 'sent',
              replyTo: msg.reply_to ? { name: msg.reply_to_name || '', text: msg.reply_to_text || '' } : null
            });
            chatMessages.insertAdjacentHTML('beforeend', bubble);
            lastMsgId = Math.max(lastMsgId, msgId);
          });
          // Auto-scroll if user is near bottom
          var atBottom = chatMessages.scrollHeight - chatMessages.scrollTop - chatMessages.clientHeight < 150;
          if (atBottom) chatMessages.scrollTop = chatMessages.scrollHeight;
        } catch(e) { /* silent */ }
      }, 3000);
    }

    // ── Page cleanup registry ──
    var _chatCleanup = [];
    function registerCleanup(fn) { _chatCleanup.push(fn); }
    function cleanupChat() {
      _chatCleanup.forEach(function(fn) { try { fn(); } catch(e) {} });
      _chatCleanup = [];
      if (typingPollInterval) { clearInterval(typingPollInterval); typingPollInterval = null; }
      if (msgPollInterval) { clearInterval(msgPollInterval); msgPollInterval = null; }
    }
    // Cleanup on hash change (navigation away from chat)
    window.addEventListener('hashchange', function chatHashCleanup() {
      if (location.hash.indexOf('#/messenger') === -1 && location.hash.indexOf('#/chat') === -1) {
        cleanupChat();
        window.removeEventListener('hashchange', chatHashCleanup);
      }
    });

    if (chatSendBtn) chatSendBtn.addEventListener('click', function() {
      if (typeof haptic === 'function') haptic('light');
      sendMessage();
    });

    // Reply close
    var replyClose = document.getElementById('chatReplyClose');
    if (replyClose) {
      replyClose.addEventListener('click', function() {
        replyToMsg = null;
        chatReplyBar.style.display = 'none';
      });
    }

    // Swipe-to-reply on chat bubbles
    (function initSwipeReply() {
      if (!chatMessages) return;
      var swStartX = 0, swStartY = 0, swBubble = null;
      chatMessages.addEventListener('touchstart', function(e) {
        var bubble = e.target.closest('.m-chat-bubble.other');
        if (!bubble) return;
        swStartX = e.touches[0].clientX;
        swStartY = e.touches[0].clientY;
        swBubble = bubble;
      }, { passive: true });
      chatMessages.addEventListener('touchmove', function(e) {
        if (!swBubble) return;
        var dx = e.touches[0].clientX - swStartX;
        var dy = Math.abs(e.touches[0].clientY - swStartY);
        if (dy > 30) { swBubble.style.transform = ''; swBubble = null; return; }
        if (dx > 0 && dx < 80) {
          swBubble.style.transform = 'translateX(' + dx + 'px)';
          swBubble.style.transition = 'none';
        }
      }, { passive: true });
      chatMessages.addEventListener('touchend', function(e) {
        if (!swBubble) return;
        var dx = e.changedTouches ? e.changedTouches[0].clientX - swStartX : 0;
        swBubble.style.transition = 'transform 0.2s ease';
        swBubble.style.transform = '';
        if (dx > 60 && chatReplyBar) {
          var msgText = (swBubble.querySelector('.m-chat-bubble-text') || {}).textContent || '';
          var sender = (swBubble.querySelector('.m-chat-bubble-sender') || {}).textContent || '';
          haptic('light');
          replyToMsg = { id: swBubble.dataset.msgId, name: sender, text: msgText };
          document.getElementById('chatReplyName').textContent = sender || 'Сообщение';
          document.getElementById('chatReplyText').textContent = msgText.substring(0, 80);
          chatReplyBar.style.display = '';
          if (chatInput) chatInput.focus();
        }
        swBubble = null;
      }, { passive: true });
    })();

    // Scroll-to-bottom button
    if (chatMessages && chatScrollDown) {
      chatMessages.addEventListener('scroll', function() {
        var atBottom = chatMessages.scrollHeight - chatMessages.scrollTop - chatMessages.clientHeight < 100;
        chatScrollDown.classList.toggle('visible', !atBottom);
      });
      chatScrollDown.addEventListener('click', function() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      });
    }

    // Pull-to-refresh for older messages in chat
    (function initChatPTR() {
      if (!chatMessages) return;
      var ptrStartY = 0, ptrPulling = false, ptrEl = null;
      chatMessages.addEventListener('touchstart', function(e) {
        if (chatMessages.scrollTop <= 0) { ptrStartY = e.touches[0].clientY; ptrPulling = true; }
      }, { passive: true });
      chatMessages.addEventListener('touchmove', function(e) {
        if (!ptrPulling) return;
        var dy = e.touches[0].clientY - ptrStartY;
        if (dy < 0) { ptrPulling = false; return; }
        if (dy > 10) {
          if (!ptrEl) {
            ptrEl = document.createElement('div');
            ptrEl.className = 'm-ptr-indicator';
            ptrEl.innerHTML = '<div class="m-ptr-spinner"></div><span>Загрузка сообщений...</span>';
            chatMessages.insertBefore(ptrEl, chatMessages.firstChild);
          }
          ptrEl.style.height = Math.round(dy * 0.5) + 'px';
          ptrEl.style.opacity = String(Math.min(dy / 80, 1));
        }
      }, { passive: true });
      chatMessages.addEventListener('touchend', function() {
        ptrPulling = false;
        if (ptrEl && parseFloat(ptrEl.style.opacity || '0') >= 1) {
          ptrEl.classList.add('refreshing');
          // Load older messages
          var oldestMsg = chatMessages.querySelector('.m-chat-bubble');
          var oldestId = oldestMsg ? oldestMsg.dataset.msgId : null;
          fetch('/api/chat-groups/' + currentChatId + '/messages?before=' + (oldestId || '') + '&limit=20', {
            headers: { 'Authorization': 'Bearer ' + token }
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var msgs = data.messages || data || [];
            if (msgs.length > 0) {
              var oldScrollH = chatMessages.scrollHeight;
              var html = '';
              msgs.reverse().forEach(function(m) {
                html += M.mChatBubble({
                  id: m.id,
                  text: m.content || m.text || '',
                  time: m.created_at ? new Date(m.created_at).toLocaleTimeString('ru', {hour:'2-digit',minute:'2-digit'}) : '',
                  isMine: String(m.user_id) === String(user.id),
                  senderName: m.user_name || '',
                  status: m.read_by ? 'read' : 'sent'
                });
              });
              if (ptrEl) ptrEl.insertAdjacentHTML('afterend', html);
              // Preserve scroll position
              chatMessages.scrollTop = chatMessages.scrollHeight - oldScrollH;
            }
            if (ptrEl) { ptrEl.remove(); ptrEl = null; }
          })
          .catch(function() { if (ptrEl) { ptrEl.remove(); ptrEl = null; } });
        } else {
          if (ptrEl) { ptrEl.remove(); ptrEl = null; }
        }
      }, { passive: true });
    })();

    // Long-press context menu on bubbles
    var longPressTimer = null;
    var targetBubble = null;
    if (chatMessages) {
      chatMessages.addEventListener('touchstart', function(e) {
        var bubble = e.target.closest('.m-chat-bubble');
        if (!bubble) return;
        targetBubble = bubble;
        longPressTimer = setTimeout(function() {
          // Show context menu
          var rect = bubble.getBoundingClientRect();
          chatCtxMenu.style.top = Math.min(rect.bottom, window.innerHeight - 200) + 'px';
          chatCtxMenu.style.left = (bubble.classList.contains('mine') ? rect.left - 180 : rect.right) + 'px';
          chatCtxMenu.classList.add('visible');
          // Haptic
          if (navigator.vibrate) navigator.vibrate(10);
        }, 500);
      });
      chatMessages.addEventListener('touchend', function() { clearTimeout(longPressTimer); });
      chatMessages.addEventListener('touchmove', function() { clearTimeout(longPressTimer); });
    }

    // Context menu actions
    if (chatCtxMenu) {
      chatCtxMenu.addEventListener('click', function(e) {
        var item = e.target.closest('.m-chat-ctx-item');
        if (!item || !targetBubble) return;
        var action = item.dataset.action;
        var msgId = targetBubble.dataset.msgId;
        var msgText = (targetBubble.querySelector('.m-chat-bubble-text') || {}).textContent || '';

        switch(action) {
          case 'reply':
            replyToMsg = { id: msgId, name: (targetBubble.querySelector('.m-chat-bubble-sender') || {}).textContent || '', text: msgText };
            document.getElementById('chatReplyName').textContent = replyToMsg.name || 'Сообщение';
            document.getElementById('chatReplyText').textContent = msgText.substring(0, 80);
            chatReplyBar.style.display = '';
            chatInput.focus();
            break;
          case 'copy':
            navigator.clipboard.writeText(msgText).then(function() {
              if (M.showSuccess) M.showSuccess('Скопировано');
            });
            break;
          case 'forward':
            // Forward picker — show modal with chat list
            (function() {
              var fwdOverlay = document.createElement('div');
              fwdOverlay.className = 'm-forward-overlay';
              fwdOverlay.innerHTML =
                '<div class="m-forward-picker">' +
                  '<div class="m-forward-picker-header">' +
                    '<span class="m-forward-picker-title">Переслать в...</span>' +
                    '<button class="m-forward-close" id="fwdClose"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button>' +
                  '</div>' +
                  '<input class="m-search-input m-forward-search" id="fwdSearch" placeholder="Поиск чата...">' +
                  '<div class="m-forward-list" id="fwdList">' +
                    '<div class="m-loading-dots"><span></span><span></span><span></span></div>' +
                  '</div>' +
                '</div>';
              document.body.appendChild(fwdOverlay);
              requestAnimationFrame(function() { fwdOverlay.classList.add('visible'); });

              // Load chats
              fetch('/api/chat-groups', {
                headers: { 'Authorization': 'Bearer ' + token }
              })
              .then(function(r) { return r.json(); })
              .then(function(data) {
                var chats = data.data || data || [];
                var fwdList = document.getElementById('fwdList');
                if (!chats.length) {
                  fwdList.innerHTML = '<div class="m-search-empty">Нет доступных чатов</div>';
                  return;
                }
                fwdList.innerHTML = chats.map(function(c) {
                  var name = c.name || c.title || 'Чат';
                  var avatar = (name[0] || '?').toUpperCase();
                  return '<div class="m-forward-item" data-chat-id="' + c.id + '">' +
                    '<div class="m-chat-avatar"><span>' + avatar + '</span></div>' +
                    '<div class="m-forward-item-name">' + name + '</div>' +
                  '</div>';
                }).join('');

                // Search filter
                document.getElementById('fwdSearch').addEventListener('input', function(e) {
                  var q = e.target.value.toLowerCase();
                  fwdList.querySelectorAll('.m-forward-item').forEach(function(item) {
                    var name = item.querySelector('.m-forward-item-name').textContent.toLowerCase();
                    item.style.display = name.indexOf(q) >= 0 ? '' : 'none';
                  });
                });

                // Click to forward
                fwdList.addEventListener('click', function(e) {
                  var item = e.target.closest('.m-forward-item');
                  if (!item) return;
                  var targetChatId = item.dataset.chatId;
                  // Send forwarded message
                  fetch('/api/chat-groups/' + targetChatId + '/messages', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify({
                      text: '↪ Пересланное сообщение:\n' + msgText
                    })
                  })
                  .then(function() {
                    if (M.showSuccess) M.showSuccess('Сообщение переслано');
                    closeFwd();
                  })
                  .catch(function(err) {
                    console.warn('[Chat] forward failed:', err.message || err);
                    if (M.showSuccess) M.showSuccess('Ошибка пересылки');
                    closeFwd();
                  });
                });
              })
              .catch(function(err) {
                console.warn('[Chat] load chats for forward:', err.message || err);
                document.getElementById('fwdList').innerHTML = '<div class="m-search-empty">Ошибка загрузки</div>';
              });

              function closeFwd() {
                fwdOverlay.classList.remove('visible');
                setTimeout(function() { fwdOverlay.remove(); }, 300);
              }

              document.getElementById('fwdClose').addEventListener('click', closeFwd);
              fwdOverlay.addEventListener('click', function(e) {
                if (e.target === fwdOverlay) closeFwd();
              });
            })();
            break;
          case 'delete':
            targetBubble.remove();
            fetch('/api/chat-groups/' + currentChatId + '/messages/' + msgId, {
              method: 'DELETE',
              headers: { 'Authorization': 'Bearer ' + token }
            }).catch(function(){});
            break;
        }
        chatCtxMenu.classList.remove('visible');
      });

      // Close ctx menu on outside click
      document.addEventListener('click', function(e) {
        if (!chatCtxMenu.contains(e.target)) chatCtxMenu.classList.remove('visible');
      });
    }

    // Click on chat list item
    if (chatListContainer) {
      chatListContainer.addEventListener('click', function(e) {
        var item = e.target.closest('.m-chat-list-item');
        if (item && item.dataset.chatId) {
          openChat(item.dataset.chatId);
        }
      });
    }

    // Voice message (basic implementation)
    var mediaRecorder = null;
    var audioChunks = [];
    if (chatVoiceBtn) {
      chatVoiceBtn.addEventListener('click', async function() {
        if (mediaRecorder && mediaRecorder.state === 'recording') {
          mediaRecorder.stop();
          chatVoiceBtn.classList.remove('recording');
                chatVoiceBtn.title = '';
                if (typeof _recTimer !== 'undefined') clearInterval(_recTimer);
          return;
        }
        try {
          var stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];
          mediaRecorder.ondataavailable = function(e) { audioChunks.push(e.data); };
          mediaRecorder.onstop = async function() {
            stream.getTracks().forEach(function(t) { t.stop(); });
            var blob = new Blob(audioChunks, { type: 'audio/webm' });
            // Send voice message
            var formData = new FormData();
            formData.append('audio', blob, 'voice.webm');
            formData.append('chat_group_id', currentChatId);
            formData.append('type', 'voice');
            try {
              await fetch('/api/chat-groups/' + currentChatId + '/messages', {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + token },
                body: formData
              });
              await loadMessages(currentChatId);
            } catch(e) { console.warn('[MobileRender]', e.message || e); }
          };
          mediaRecorder.start();
          chatVoiceBtn.classList.add('recording');
                // Show recording timer
                var _recStart = Date.now();
                var _recTimer = setInterval(function() {
                  var elapsed = Math.floor((Date.now() - _recStart) / 1000);
                  var mm = Math.floor(elapsed / 60);
                  var ss = elapsed % 60;
                  chatVoiceBtn.title = mm + ':' + (ss < 10 ? '0' : '') + ss;
                }, 1000);
          if (navigator.vibrate) navigator.vibrate(10);
        } catch(e) {
          if (M.showError) M.showError('Нет доступа к микрофону');
        }
      });
    }

    // Deep link - open specific chat
    // Update unread badge on Chat tab
    var totalUnread = chats.reduce(function(sum, c) { return sum + (c.unread_count || 0); }, 0);
    if (totalUnread > 0) {
      var chatTab = document.querySelector('.m-tab-item[data-tab="chat"]');
      if (chatTab) {
        var badge = chatTab.querySelector('.m-tab-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'm-tab-badge';
          chatTab.style.position = 'relative';
          chatTab.appendChild(badge);
        }
        badge.textContent = totalUnread > 99 ? '99+' : String(totalUnread);
        badge.style.display = '';
      }
    }

        if (openChatId) {
      setTimeout(function() { openChat(openChatId); }, 100);
    }
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  CALCULATOR V2  ██████
     Роутер: /calculator → layout + AsgardCalcV2.renderPage(container)
     ═══════════════════════════════════════════════════════════════════════════ */
  patchMethod('AsgardCalcV2', 'renderPage', async function(opts) {
    // opts может быть DOM element или {layout, title, container}
    var container = (opts instanceof HTMLElement) ? opts : (opts && opts.container);
    if (!container) return;
    container.setAttribute('data-mobile-native', '1');

    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var settings = {};
    try { settings = await AsgardDB.get('settings', 'app') || {}; } catch(e) { console.warn('[MobileRender]', e.message || e); }

    var TABS = [
      { id: 'object', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg> Объект' },
      { id: 'params', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg> Параметры' },
      { id: 'crew', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Бригада' },
      { id: 'time', label: '⏱ Сроки' },
      { id: 'totals', label: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg> Итого' }
    ];

    var tabsHtml = '<div class="m-tabs-scroll">' + TABS.map(function(t, i) {
      return '<button class="m-tab-btn' + (i === 0 ? ' m-tab-active' : '') + '" data-calc-tab="' + t.id + '">' + t.label + '</button>';
    }).join('') + '</div>';

    var objectTab = '<div class="m-calc-tab" id="calc-tab-object">' +
      M.mForm([
        { label: 'Заказчик', id: 'cCustomer', type: 'text', placeholder: 'Название заказчика' },
        { label: 'Название тендера', id: 'cTender', type: 'text', placeholder: 'Наименование' },
        { label: 'Тип работ', id: 'cWorkType', type: 'select', options: [
          { value: '', label: 'Выберите тип' },
          { value: 'chem_cleaning', label: 'Химическая чистка' },
          { value: 'hydro_cleaning', label: 'Гидрочистка' },
          { value: 'insulation', label: 'Теплоизоляция' },
          { value: 'scaffolding', label: 'Леса/подмости' },
          { value: 'other', label: 'Другое' }
        ]},
        { label: 'Город', id: 'cCity', type: 'text', placeholder: 'Москва' },
        { label: 'Расстояние (км)', id: 'cDistance', type: 'number', placeholder: '0' }
      ]) + '</div>';

    var paramsTab = '<div class="m-calc-tab m-hidden" id="calc-tab-params">' +
      M.mForm([
        { label: 'Объём работ', id: 'cVolume', type: 'number', placeholder: '0' },
        { label: 'Единица измерения', id: 'cUnit', type: 'select', options: [
          { value: 'm2', label: 'м²' }, { value: 'm3', label: 'м³' },
          { value: 'ton', label: 'тонн' }, { value: 'unit', label: 'шт.' }
        ]},
        { label: 'Условия работы', id: 'cConditions', type: 'select', options: [
          { value: 'normal', label: 'Нормальные' }, { value: 'height', label: 'Высотные' },
          { value: 'confined', label: 'Замкнутое пространство' }, { value: 'hazardous', label: 'Опасная среда' }
        ]},
        { label: 'Наценка (%)', id: 'cMargin', type: 'number', value: '20', placeholder: '20' }
      ]) + '</div>';

    var crewTab = '<div class="m-calc-tab m-hidden" id="calc-tab-crew">' +
      M.mForm([
        { label: 'Рабочих', id: 'cCrewSize', type: 'number', placeholder: '4' },
        { label: 'Бригадир', id: 'cForeman', type: 'number', value: '1', placeholder: '1' },
        { label: 'Ставка рабочего (₽/день)', id: 'cRate', type: 'number', value: settings.worker_rate || '3000', placeholder: '3000' },
        { label: 'Ставка бригадира (₽/день)', id: 'cForemanRate', type: 'number', value: settings.foreman_rate || '4500', placeholder: '4500' }
      ]) + '</div>';

    var timeTab = '<div class="m-calc-tab m-hidden" id="calc-tab-time">' +
      M.mForm([
        { label: 'Дни подготовки', id: 'cPrepDays', type: 'number', value: '2', placeholder: '2' },
        { label: 'Дни работы', id: 'cWorkDays', type: 'number', placeholder: '10' },
        { label: 'Дни демобилизации', id: 'cDemobDays', type: 'number', value: '1', placeholder: '1' }
      ]) + '</div>';

    var totalsTab = '<div class="m-calc-tab m-hidden" id="calc-tab-totals">' +
      '<div class="m-card">' +
        '<div class="m-card-title m-title-md">Результаты расчёта</div>' +
        '<div class="m-card-fields" id="calcResults">' +
          '<div class="m-field"><span class="m-field-label">Заполните все вкладки</span></div>' +
        '</div>' +
        '<div class="m-card-actions m-flex-stretch">' +
          '<button class="m-action-btn m-btn-primary" id="btnCalcCompute">Рассчитать</button>' +
        '</div>' +
      '</div></div>';

    container.innerHTML = '<div class="m-page" data-mobile-native="1">' +
      tabsHtml + objectTab + paramsTab + crewTab + timeTab + totalsTab + '</div>';

    // Tab switching
    container.querySelectorAll('.m-tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        container.querySelectorAll('.m-tab-btn').forEach(function(b) { b.classList.remove('m-tab-active'); });
        btn.classList.add('m-tab-active');
        TABS.forEach(function(t) {
          var el = document.getElementById('calc-tab-' + t.id);
          if (el) el.classList.toggle('m-hidden', t.id !== btn.dataset.calcTab);
        });
      });
    });

    // Расчёт
    document.getElementById('btnCalcCompute')?.addEventListener('click', function() {
      var crewSize = Number(document.getElementById('cCrewSize')?.value || 4);
      var foreman = Number(document.getElementById('cForeman')?.value || 1);
      var rate = Number(document.getElementById('cRate')?.value || 3000);
      var foremanRate = Number(document.getElementById('cForemanRate')?.value || 4500);
      var prepDays = Number(document.getElementById('cPrepDays')?.value || 2);
      var workDays = Number(document.getElementById('cWorkDays')?.value || 10);
      var demobDays = Number(document.getElementById('cDemobDays')?.value || 1);
      var margin = Number(document.getElementById('cMargin')?.value || 20);

      var totalDays = prepDays + workDays + demobDays;
      var laborCost = (crewSize * rate + foreman * foremanRate) * totalDays;
      var total = laborCost * (1 + margin / 100);

      document.getElementById('calcResults').innerHTML =
        '<div class="m-field"><span class="m-field-label">Всего дней</span><span class="m-field-value">' + totalDays + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">ФОТ</span><span class="m-field-value m-mono">' + money(laborCost) + '</span></div>' +
        '<div class="m-field"><span class="m-field-label">Наценка ' + margin + '%</span><span class="m-field-value m-mono">' + money(total - laborCost) + '</span></div>' +
        '<div class="m-field m-calc-total"><span class="m-field-label">ИТОГО</span><span class="m-field-value">' + money(total) + '</span></div>';
    });
  });


  console.info('[MobileRenders] v8.0.0 — ' + _patchCount + ' methods patched across all modules');
})();
