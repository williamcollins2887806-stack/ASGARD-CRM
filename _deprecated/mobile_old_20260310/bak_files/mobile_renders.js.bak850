      stats: [
        { label: 'Всего задач', value: tasks.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--info)' }
      ],
      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск задач...' } },
      items: tasks,
      renderCard: function(t) {
        return M.mCard({
          id: t.id, title: esc(t.title || t.subject || 'Задача'),
          subtitle: esc(t.assignee_name || ''),
          badge: t.status || '—', badgeColor: M.statusColor(t.status),
          fields: [
