  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PAYROLL  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardPayrollPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var payroll = await AsgardDB.all('payroll') || [];
    payroll.sort(function(a, b) { return String(b.period || '').localeCompare(String(a.period || '')); });

        // Monthly payroll chart
    var _prMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _prMonthData = new Array(12).fill(0);
    items.forEach(function(p) {
      var d = new Date(p.date || p.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _prMonthData[d.getMonth()] += Number(p.amount || 0);
      }
    });
    var _prCurM = new Date().getMonth();
    var payrollChartData = [];
    for (var _pri = Math.max(0, _prCurM - 5); _pri <= _prCurM; _pri++) {
      payrollChartData.push({ label: _prMonths[_pri], value: _prMonthData[_pri] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Ведомость', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>' }),
      chart: (payrollChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(payrollChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск начислений...' } },
      items: payroll,
      renderCard: function(p) {
        return M.mCard({
          id: p.id,
          title: esc(p.employee_name || p.fio || 'Начисление'),
          subtitle: esc(p.period || ''),
          badge: p.status || '—',
          badgeColor: M.statusColor(p.status),
          fields: [
            { label: 'Сумма', value: money(p.amount || p.total), mono: true },
            { label: 'Объект', value: esc(p.work_title || p.object || '—') }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Расчёты с рабочими' });
  });


