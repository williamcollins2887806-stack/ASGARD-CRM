/**
 * ASGARD CRM — Mobile Native Renders v3.0
 * Патчит ВСЕ методы (render, renderList, renderCard, renderSettings и др.)
 * ВСЕХ page-модулей, добавляя мобильную ветку.
 *
 * Загружается ПОСЛЕ всех page-модулей, ПЕРЕД app.js.
 * Не трогает существующий код — только оборачивает.
 */
;(function() {
  var PAGE_SIZE = 20;

  'use strict';

  // v8.1 — Debounce helper for search inputs
  var _debounceTimers = {};
  function _debounce(key, fn, delay) {
    if (_debounceTimers[key]) clearTimeout(_debounceTimers[key]);
    _debounceTimers[key] = setTimeout(fn, delay || 300);
  }

  // v8.1.1 — Relative time display (Telegram/Sber style)
  function timeAgo(dateStr) {
    if (!dateStr) return '';
    var date = new Date(dateStr);
    if (isNaN(date.getTime())) return String(dateStr);
    var now = new Date();
    var diff = Math.floor((now - date) / 1000);
    if (diff < 60) return 'только что';
    if (diff < 3600) return Math.floor(diff / 60) + ' мин назад';
    if (diff < 86400) return Math.floor(diff / 3600) + ' ч назад';
    if (diff < 172800) return 'вчера';
    if (diff < 604800) return Math.floor(diff / 86400) + ' дн назад';
    return date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
  }

  // v8.1.1 — Network error retry + offline indicator
  function showRetryBanner(message, retryFn) {
    var existing = document.querySelector('.m-retry-banner');
    if (existing) existing.remove();
    var banner = document.createElement('div');
    banner.className = 'm-retry-banner'; banner.setAttribute('role', 'alert');
    banner.innerHTML = '<span>' + esc(message) + '</span><button class="m-retry-btn">Повторить</button>';
    document.body.appendChild(banner);
    if (navigator.vibrate) navigator.vibrate(20);
    banner.querySelector('.m-retry-btn').addEventListener('click', function() {
      banner.remove();
      if (typeof retryFn === 'function') retryFn();
    });
    return banner;
  }

  function showOfflineBanner() {
    if (document.querySelector('.m-offline-banner')) return;
    var banner = document.createElement('div');
    banner.className = 'm-offline-banner'; banner.setAttribute('role', 'alert');
    banner.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg> Нет подключения';
    document.body.appendChild(banner);
  }

  function hideOfflineBanner() {
    var banner = document.querySelector('.m-offline-banner');
    if (banner) banner.remove();
  }

  // Listen for online/offline events
  window.addEventListener('offline', showOfflineBanner);
  window.addEventListener('online', function() {
    hideOfflineBanner();
    if (navigator.vibrate) navigator.vibrate(10);
  });
  // Check on load
  if (!navigator.onLine) showOfflineBanner();

  // v8.1.1 — Generic Pull-to-Refresh for all data pages
  function initGenericPTR() {
    if (window._genericPTRInit) return;
    window._genericPTRInit = true;

    var content = document.querySelector('.m-content');
    if (!content) return;

    var startY = 0, pulling = false, indicator = null;
    var threshold = 80;

  // v8.1.1 — Scroll position save/restore on navigation
  var _scrollPositions = {};
  window.addEventListener('hashchange', function() {
    // Save current scroll position
    var content = document.querySelector('.m-content');
    if (content && window._lastHash) {
      _scrollPositions[window._lastHash] = content.scrollTop;
    }
    window._lastHash = location.hash;

    // Restore scroll position after render (next tick)
    setTimeout(function() {
      var saved = _scrollPositions[location.hash];
      var newContent = document.querySelector('.m-content');
      if (newContent && saved) {
        newContent.scrollTop = saved;
      }
    }, 100);

    // Init generic PTR on every page
    setTimeout(function() {
      window._genericPTRInit = false;
      initGenericPTR();
    animatePageEnter();
    if (M.autoPaginate) M.autoPaginate();
    }, 200);
  });
  window._lastHash = location.hash;



    content.addEventListener('touchstart', function(e) {
      if (content.scrollTop > 5) return;
      startY = e.touches[0].clientY;
    }, { passive: true });

    content.addEventListener('touchmove', function(e) {
      if (content.scrollTop > 5) return;
      var dy = e.touches[0].clientY - startY;
      if (dy > 10 && !pulling) {
        pulling = true;
        if (!indicator) {
          indicator = document.createElement('div');
          indicator.className = 'm-ptr-indicator';
          indicator.innerHTML = '<div class="m-ptr-spinner"></div>';
          content.insertBefore(indicator, content.firstChild);
        }
      }
      if (pulling && dy > 0) {
        var progress = Math.min(dy / threshold, 1);
        indicator.style.height = Math.min(dy * 0.5, 60) + 'px';
        indicator.style.opacity = progress;
        if (progress >= 1 && !indicator.classList.contains('ready')) {
          indicator.classList.add('ready');
          if (navigator.vibrate) navigator.vibrate(15);
        }
      }
    }, { passive: true });

    content.addEventListener('touchend', function() {
      if (!pulling) return;
      pulling = false;
      if (indicator && indicator.classList.contains('ready')) {
        // Trigger refresh
        indicator.style.height = '40px';
        indicator.innerHTML = '<div class="m-ptr-spinner spinning"></div>';
        // Reload current page
        var currentHash = location.hash;
        location.hash = '#/__ptr_reload__';
        setTimeout(function() {
          location.hash = currentHash;
          if (indicator) indicator.remove();
          indicator = null;
        }, 100);
      } else {
        if (indicator) indicator.remove();
        indicator = null;
      }
    });
  }







  // v8.1 — Undo toast for destructive actions
  function showUndoToast(message, undoCallback, duration) {
    duration = duration || 5000;
    var existing = document.querySelector('.m-toast-with-action');
    if (existing) existing.remove();

  // v8.1 — Swipe-to-reveal actions on mail items
  function initMailSwipeReveal(container) {
    if (!container) return;
    var items = container.querySelectorAll('.m-card, .m-mail-item');
    items.forEach(function(item) {
      if (item._swipeInit) return;
      item._swipeInit = true;

      var startX = 0, startY = 0, currentX = 0, swiping = false;

      item.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        swiping = false;
      }, {passive: true});

      item.addEventListener('touchmove', function(e) {
        var dx = e.touches[0].clientX - startX;
        var dy = e.touches[0].clientY - startY;

        if (!swiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
          swiping = true;
          item.style.transition = 'none';
        }

        if (swiping && dx < 0) {
          currentX = Math.max(dx, -120);
          item.style.transform = 'translateX(' + currentX + 'px)';
          e.preventDefault();
        }
      }, {passive: false});

      item.addEventListener('touchend', function() {
        if (!swiping) return;
        item.style.transition = 'transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)';

        if (currentX < -72) {
          // Show delete action area
          item.style.transform = 'translateX(-72px)';
          if (navigator.vibrate) navigator.vibrate(15);

          // Auto-reset after 3s
          setTimeout(function() {
            item.style.transform = '';
          }, 3000);
        } else {
          item.style.transform = '';
        }

        currentX = 0;
        swiping = false;
      });
    });
  }



    var toast = document.createElement('div');
    toast.className = 'm-toast m-toast-with-action';
    toast.innerHTML = '<span>' + message + '</span><button class="m-toast-action">Отменить</button>';
    toast.style.cssText = 'animation:m-toast-in 0.3s ease';
    document.body.appendChild(toast);

    if (navigator.vibrate) navigator.vibrate(15);

    var timer = setTimeout(function() {
      toast.style.animation = 'm-toast-out 0.3s ease forwards';
      setTimeout(function() { toast.remove(); }, 300);
    }, duration);

    toast.querySelector('.m-toast-action').addEventListener('click', function() {
      clearTimeout(timer);
      if (typeof undoCallback === 'function') undoCallback();
      toast.remove();
      if (navigator.vibrate) navigator.vibrate(10);
    });
  }





  var M = window.AsgardMobileUI;
  if (!M) { console.warn('[MobileRenders] AsgardMobileUI not loaded'); return; }

  /* ═══════════════════════════════════════════════════════════════
     УТИЛИТЫ
     ═══════════════════════════════════════════════════════════════ */
  var esc = M.esc;
  var _patchCount = 0;

  function money(n) {
    if (n == null || n === '') return '—';
    return Number(n).toLocaleString('ru-RU') + ' ₽';
  }

  function fmtDate(d) {
    if (!d) return '—';
    try { return new Date(d).toLocaleDateString('ru-RU'); } catch(e) { return String(d); }
  }

  function fmtDateShort(d) {
    if (!d) return '—';
    try { return new Date(d).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' }); } catch(e) { return String(d); }
  }

  function norm(s) { return String(s || '').toLowerCase().trim(); }

  var fmtMoney = money; /* alias */

  function showError(msg) {
    if (window.AsgardUI && AsgardUI.toast) {
      AsgardUI.toast('Ошибка', msg || 'Не удалось загрузить данные', 'err');
    }
  }

  function authCheck() {
    return AsgardAuth.requireUser().then(function(auth) {
      if (!auth) { location.hash = '#/login'; return null; }
      return auth;
    });
  }

  /* Универсальный патчер: оборачивает ЛЮБОЙ метод модуля.
     Автоматически определяет DOM-element аргумент (модули типа CashPage, TasksAdminPage)
     и оборачивает его в {layout, title} для единообразия мобильных рендеров.
     Показывает shimmer-скелетон во время загрузки данных (Sber-level UX). */
  function patchMethod(moduleName, methodName, mobileFn) {
    var mod = window[moduleName];
    if (!mod || typeof mod[methodName] !== 'function') return;
    var orig = mod[methodName];
    mod[methodName] = async function(opts) {
      if (M.isMobile()) {
        try {
          // Если аргумент — DOM-элемент (роутер уже вызвал layout(), передаёт контейнер)
          if (opts instanceof HTMLElement) {
            opts.setAttribute('data-mobile-native', '1');
            // Показываем скелетон пока данные грузятся
            opts.innerHTML = M.mSkeleton('stats', 3) + M.mSkeleton('card', 4);
            var wrappedOpts = {
              layout: async function(html) { opts.innerHTML = html; },
              title: '',
              container: opts
            };
            return await mobileFn(wrappedOpts);
          }

          // Для {layout, title} паттерна — скелетон с задержкой 120мс
          // Если данные загрузятся быстрее — скелетон не покажется (нет мерцания)
          // Если данные грузятся дольше — появится shimmer (как в Сбере/Яндексе)
          if (opts && typeof opts.layout === 'function') {
            var origLayout = opts.layout;
            var skeletonHtml = '<div class="m-page" data-mobile-native="1">' +
              M.mSkeleton('stats', 3) + M.mSkeleton('card', 4) + '</div>';
            var skeletonTimer = setTimeout(function() {
              try { origLayout(skeletonHtml, { title: opts.title || '' }); } catch(x) {}
            }, 120);
            var wrappedLayout = async function(html, layoutOpts) {
              clearTimeout(skeletonTimer);
              return origLayout(html, layoutOpts);
            };
            opts = Object.assign({}, opts, { layout: wrappedLayout });
          }

          return await mobileFn(opts);
        } catch(e) {
          console.error('[MobileRenders] Error in ' + moduleName + '.' + methodName + ':', e);
          return orig.call(mod, opts);
        }
      }
      return orig.call(mod, opts);
    };
    _patchCount++;
  }

  /* Совместимый патчер .render() */
  function patchModule(moduleName, renderMobileFn) {
    patchMethod(moduleName, 'render', renderMobileFn);
  }


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PERSONNEL  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  
  // v8.1.2 — Page enter animation
  function animatePageEnter() {
    var content = document.querySelector('.m-content');
    if (content) {
      content.classList.remove('m-content-enter');
      void content.offsetWidth; // force reflow
      content.classList.add('m-content-enter');
    }
  }

  
  // v8.1.2 — Pagination wrapper for heavy lists
  function paginateList(items, renderFn, containerId) {
    if (!items || items.length === 0) return M.mEmpty('\u041D\u0435\u0442 \u0434\u0430\u043D\u043D\u044B\u0445');
    if (items.length <= PAGE_SIZE) {
      return '<div id="' + containerId + '">' + items.map(renderFn).join('') + '</div>';
    }
    var all = items.map(renderFn);
    var visible = all.slice(0, PAGE_SIZE).join('');
    var hidden = all.slice(PAGE_SIZE).map(function(h) {
      return h.replace('class="m-card', 'class="m-card m-list-hidden" style="display:none');
    }).join('');
    var total = items.length;
    return '<div id="' + containerId + '" data-shown="' + PAGE_SIZE + '" data-total="' + total + '">' +
      visible + hidden + '</div>' +
      '<div class="m-load-more" id="' + containerId + '_more">' +
        '<button class="m-load-more-btn">\u041F\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0435\u0449\u0451</button>' +
        '<div class="m-load-more-info">\u041F\u043E\u043A\u0430\u0437\u0430\u043D\u043E ' + PAGE_SIZE + ' \u0438\u0437 ' + total + '</div>' +
      '</div>';
  }

  
  // v8.1.2 — Responsive chart wrapper
  function chartWrap(canvasId) {
    return '<div class="m-chart-wrap"><canvas id="' + canvasId + '"></canvas></div>';
  }

  patchModule('AsgardPersonnelPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var user = auth.user;

    var list = await AsgardDB.all('employees');
    var rows = (list || []).slice();
    rows.sort(function(a, b) {
      return (b.rating_avg || 0) - (a.rating_avg || 0) || String(a.fio || '').localeCompare(String(b.fio || ''), 'ru');
    });

    // Stats
    var total = rows.length;
    var available = rows.filter(function(e) { return (e.availability_status || '').toLowerCase() === 'свободен'; }).length;
    var avgRating = 0;
    var ratedCount = 0;
    rows.forEach(function(e) {
      if (e.rating_avg != null && e.rating_avg !== '') { avgRating += Number(e.rating_avg); ratedCount++; }
    });
    avgRating = ratedCount > 0 ? (avgRating / ratedCount).toFixed(1) : '—';

        // Monthly hires chart
    var _pMonths = ['Янв','Фев','Мар','Апр','Май','Июн','Июл','Авг','Сен','Окт','Ноя','Дек'];
    var _pMonthData = new Array(12).fill(0);
    users.forEach(function(u) {
      var d = new Date(u.hire_date || u.created_at || '');
      if (!isNaN(d.getTime()) && d.getFullYear() === new Date().getFullYear()) {
        _pMonthData[d.getMonth()]++;
      }
    });
    var _pCurM = new Date().getMonth();
    var personnelChartData = [];
    for (var _pi = Math.max(0, _pCurM - 5); _pi <= _pCurM; _pi++) {
      personnelChartData.push({ label: _pMonths[_pi], value: _pMonthData[_pi] });
    }

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(total), label: 'Сотрудники компании', sub: activeCount + ' активных · ' + avgRat, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' }),
      chart: (personnelChartData.some(function(d) { return d.value > 0; }) ? M.mBarChart(personnelChartData, { height: 100, accentColor: 'var(--ok-t, #21bf73)' }) : ''),

      stats: [
        { label: 'Всего', value: total, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', color: 'var(--info)' },
        { label: 'Свободны', value: available, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t, #21bf73)" stroke-width="2.5" style="vertical-align:-2px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', color: 'var(--ok-t)' },
        { label: 'Ср. рейтинг', value: avgRating, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold, #f59e0b)" stroke="var(--gold, #f59e0b)" stroke-width="1" style="vertical-align:-2px"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск: ФИО, роль, город...' },
        actions: [
          { id: 'btnSchedule', label: 'График', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>', cls: 'ghost' },
          { id: 'btnAdd', label: 'Добавить', icon: '+', cls: 'primary' }
        ]
      },
      items: rows,
      renderCard: function(e) {
        return M.mCard({
          id: e.id,
          title: esc(e.fio || ''),
          subtitle: esc(e.role_tag || ''),
          badge: e.availability_status || '',
          badgeColor: (e.availability_status || '').toLowerCase() === 'свободен' ? 'ok' : 'warn',
          fields: [
            { label: 'Город', value: esc(e.city || '—') },
            { label: 'Телефон', value: esc(e.phone || '—') },
            { label: 'Рейтинг', value: e.rating_avg != null && e.rating_avg !== '' ? Number(e.rating_avg).toFixed(1) + ' <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--gold, #f59e0b)" stroke="none" style="vertical-align:-1px"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>' : '—' },
            { label: 'Разряд', value: esc(e.grade || '—') }
          ],
          onClick: true
        });
      },
      emptyText: 'Нет сотрудников'
    });

    await layout(body, { title: title || 'Дружина' });
    // Mark as custom detail handler
    var listEl = document.getElementById('mobileList'); if (listEl) listEl.setAttribute('data-custom-detail', '1');


    // Search handler
    var searchEl = document.getElementById('mSearch');
    if (searchEl) {
      searchEl.addEventListener('input', function() {
        _debounce('search4', function() {
        var q = norm(searchEl.value);
        var cards = document.querySelectorAll('.m-card');
        var listEl = document.getElementById('mobileList');
        var visibleCount = 0;
        cards.forEach(function(card) {
          var id = card.dataset.id;
          var emp = rows.find(function(e) { return String(e.id) === id; });
          if (!emp) return;
          var haystack = norm((emp.fio || '') + ' ' + (emp.role_tag || '') + ' ' + (emp.city || ''));
          var show = !q || haystack.indexOf(q) !== -1;
          card.style.display = show ? '' : 'none';
          if (show) visibleCount++;
        });
      }, 250);
        });
    }

    // Card click -> open employee
    var listEl = document.getElementById('mobileList');
    if (listEl) {
      listEl.addEventListener('click', function(e) {
        var card = e.target.closest('.m-card');
        if (card && card.dataset.id) {
          location.hash = '#/employee?id=' + card.dataset.id;
        }
      });
    }

    // Schedule button
    var btnSch = document.getElementById('btnSchedule');
    if (btnSch) btnSch.addEventListener('click', function() { location.hash = '#/workers-schedule'; });

    // Add button
    var btnAdd = document.getElementById('btnAdd');
    if (btnAdd) {
      btnAdd.addEventListener('click', function() {
        M.showSheet('Новый сотрудник', M.mForm([
          { type: 'text', id: 'e_fio', label: 'ФИО', placeholder: 'Фамилия Имя Отчество', required: true },
          { type: 'text', id: 'e_role', label: 'Роль', placeholder: 'Слесарь / Мастер...' },
          { type: 'text', id: 'e_city', label: 'Город', placeholder: 'Москва' },
          { type: 'tel', id: 'e_phone', label: 'Телефон', placeholder: '+7...' },
          { type: 'text', id: 'e_grade', label: 'Разряд', placeholder: '3..6' }
        ], {
          buttons: [
            { id: 'btnSave', label: 'Сохранить', cls: 'primary' }
          ]
        }));
        setTimeout(function() {
          var btnSave = document.getElementById('btnSave');
          if (btnSave) {
            btnSave.addEventListener('click', async function() {
              var fio = (document.getElementById('e_fio').value || '').trim();
              if (!fio) { AsgardUI.toast('Ошибка', 'ФИО обязательно', 'err'); return; }
              await AsgardDB.add('employees', {
                fio: fio,
                role_tag: (document.getElementById('e_role').value || '').trim(),
                city: (document.getElementById('e_city').value || '').trim(),
                phone: (document.getElementById('e_phone').value || '').trim(),
                grade: (document.getElementById('e_grade').value || '').trim(),
                availability_status: 'Свободен',
                rating_avg: null,
                created_at: new Date().toISOString()
              });
              M.hideSheet();
              AsgardUI.toast('Готово', 'Сотрудник добавлен');
              location.hash = '#/personnel';
            });
          }
        }, 100);
      });
    }
  });


