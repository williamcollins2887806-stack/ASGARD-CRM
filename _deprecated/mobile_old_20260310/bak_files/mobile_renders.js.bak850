  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TRAVEL  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardTravelPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var items = await AsgardDB.all('travel') || [];
    items.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Командировки', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>' }),

      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: items,
      renderCard: function(t) {
        return M.mCard({
          id: t.id,
          title: esc(t.employee_name || t.fio || ''),
          subtitle: esc(t.destination || t.city || ''),
          badge: t.status || '—',
          badgeColor: M.statusColor(t.status),
          fields: [
            { label: 'Даты', value: fmtDateShort(t.start_date) + ' — ' + fmtDateShort(t.end_date) },
            { label: 'Стоимость', value: money(t.cost || t.amount), mono: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Жильё и билеты' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  ALERTS / NOTIFICATIONS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardAlertsPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var items = [];
    try { items = await AsgardDB.byIndex('notifications', 'user_id', auth.user.id) || []; } catch(e) {
      try { items = await AsgardDB.all('notifications') || []; } catch(e2) {}
    }
    items.sort(function(a, b) { return String(b.created_at || '').localeCompare(String(a.created_at || '')); });

    var unread = items.filter(function(n) { return !n.is_read; }).length;

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Уведомления', sub: unreadCount > 0 ? unreadCount + ' непрочитанных' : 'Все прочитаны', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/><line x1="1" x2="23" y1="1" y2="23"/></svg>' }),

      stats: [
        { label: 'Всего', value: items.length, icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>', color: 'var(--info)' },
        { label: 'Непрочитано', value: unread, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>', color: 'var(--gold)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск...' },
        actions: [
          { id: 'btnMarkAll', label: 'Прочитать все', icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align:-2px"><polyline points="20 6 9 17 4 12"/></svg>', cls: 'ghost' }
        ]
      },
      items: items,
      renderCard: function(n) {
        return M.mCard({
          id: n.id,
          title: esc(n.title || 'Уведомление'),
          subtitle: timeAgo(n.created_at),
          badge: n.is_read ? 'Прочитано' : 'Новое',
          badgeColor: n.is_read ? 'draft' : 'gold',
          fields: [
            { label: 'Сообщение', value: esc((n.message || '').substring(0, 80)), full: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Уведомления' });

    // Mark all read
    var btnMark = document.getElementById('btnMarkAll');
    if (btnMark) {
      btnMark.addEventListener('click', async function() {
        for (var i = 0; i < items.length; i++) {
          if (!items[i].is_read) {
            items[i].is_read = true;
            try { await AsgardDB.put('notifications', items[i]); } catch(e) { console.warn('[MobileRender]', e.message || e); }
          }
        }
        AsgardUI.toast('Готово', 'Все уведомления прочитаны');
        location.hash = '#/alerts';
      });
    }

    // Card click -> navigate to link
    document.getElementById('mobileList')?.addEventListener('click', function(e) {
      var card = e.target.closest('.m-card[data-id]');
      if (!card) return;
      var n = items.find(function(x) { return String(x.id) === card.dataset.id; });
      if (n && n.link_hash) location.hash = n.link_hash;
    });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  PRE-TENDERS  ██████
     ═══════════════════════════════════════════════════════════════════════════ */
  patchModule('AsgardPreTendersPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }

    var items = await AsgardDB.all('pre_tenders') || [];
    items.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Предварительные тендеры', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>' }),

      stats: [
        { label: 'Заявок', value: items.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>', color: 'var(--info)' }
      ],
      toolbar: {
        search: { id: 'mSearch', placeholder: 'Поиск заявок...' },
        actions: [{ id: 'btnAdd', label: 'Новая заявка', icon: '+', cls: 'primary' }]
      },
      items: items,
      renderCard: function(pt) {
        return M.mCard({
          id: pt.id,
          title: esc(pt.customer_name || pt.title || ''),
          subtitle: esc(pt.source || ''),
          badge: pt.status || '—',
          badgeColor: M.statusColor(pt.status),
          fields: [
            { label: 'Дата', value: fmtDate(pt.created_at) },
            { label: 'Сумма', value: money(pt.estimated_price), mono: true }
          ],
          onClick: true
        });
      }
    });

    await layout(body, { title: title || 'Предварительные заявки' });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     GENERIC TABLE PAGE PATCHER — для модулей с простым паттерном table→cards
     ═══════════════════════════════════════════════════════════════════════════ */
  var simpleModules = [
    { name: 'AsgardBonusApproval', store: 'bonus_requests', title: 'Согласование премий' },
    { name: 'AsgardTkpPage', store: 'tkp', title: 'ТКП' },
    { name: 'AsgardPassRequestsPage', store: 'pass_requests', title: 'Заявки на пропуск' },
    { name: 'AsgardBuhRegistryPage', store: 'buh_registry', title: 'Реестр расходов' },
    { name: 'AsgardAllEstimatesPage', store: 'estimates', title: 'Свод Расчётов' },
    { name: 'AsgardProxiesPage', store: 'proxies', title: 'Доверенности' },
    { name: 'AsgardSealsPage', store: 'seals', title: 'Реестр печатей' },
    { name: 'AsgardProcRequestsPage', store: 'proc_requests', title: 'Заявки закупок' },
    { name: 'AsgardOfficeExpensesPage', store: 'office_expenses', title: 'Офисные расходы' },
    { name: 'AsgardBooking', store: 'booking', title: 'Бронирование' },
    { name: 'AsgardMeetings', store: 'meetings', title: 'Совещания' },
    { name: 'AsgardInboxApplicationsPage', store: 'inbox_applications', title: 'Входящие заявки' }
  ];

  simpleModules.forEach(function(cfg) {
    patchModule(cfg.name, async function({ layout, title }) {
      var auth = await AsgardAuth.requireUser();
      if (!auth) { location.hash = '#/login'; return; }

      var items = [];
      try { items = await AsgardDB.all(cfg.store) || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
      items.sort(function(a, b) { return (b.id || 0) - (a.id || 0); });

      var body = M.mTablePage({
        stats: [
          { label: 'Записей', value: items.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' }
        ],
        toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
        items: items,
        renderCard: function(item) {
          // Auto-detect best title/subtitle from available fields
          var t = item.title || item.name || item.number || item.fio || item.subject || item.customer_name || ('Запись #' + item.id);
          var sub = item.description || item.comment || item.type || item.category || '';
          return M.mCard({
            id: item.id,
            title: esc(t),
            subtitle: esc(sub).substring(0, 50),
            badge: item.status || '—',
            badgeColor: M.statusColor(item.status),
            fields: [
              { label: 'Дата', value: fmtDate(item.date || item.created_at) },
              { label: 'Сумма', value: item.amount ? money(item.amount) : '—', mono: true }
            ],
            onClick: true
          });
        }
      });

      await layout(body, { title: title || cfg.title });
    });
  });


  /* ═══════════════════════════════════════════════════════════════════════════
     ██████  TIER 2 — DASHBOARDS / KPI  ██████
     ═══════════════════════════════════════════════════════════════════════════ */

  /* Dashboard */
  patchModule('AsgardDashboardPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var tenders = await AsgardDB.all('tenders') || [];
    var works = await AsgardDB.all('works') || [];
    var estimates = await AsgardDB.all('estimates') || [];
    var invoices = []; try { invoices = await AsgardDB.all('invoices') || []; } catch(e) {}
    var won = tenders.filter(function(t) { return norm(t.tender_status) === 'выигран'; }).length;
    var active = works.filter(function(w) { return ['в работе','монтаж','пуско-наладка'].indexOf(norm(w.work_status)) !== -1; }).length;
    var pending = estimates.filter(function(e) { return e.approval_status === 'sent'; }).length;
    var totalContract = 0, totalCost = 0;
    works.forEach(function(w) { totalContract += Number(w.contract_value || 0); totalCost += Number(w.cost_fact || w.cost_plan || 0); });
    var margin = totalContract - totalCost;
    var marginPct = totalContract > 0 ? Math.round((margin / totalContract) * 100) : 0;

    // Build monthly data for mini chart (last 6 months)
    var months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
    var now = new Date();
    var chartData = [];
    for (var mi = 5; mi >= 0; mi--) {
      var md = new Date(now.getFullYear(), now.getMonth() - mi, 1);
      var monthWorks = works.filter(function(w) {
        if (!w.created_at) return false;
        var d = new Date(w.created_at);
        return d.getMonth() === md.getMonth() && d.getFullYear() === md.getFullYear();
      });
      var monthSum = 0;
      monthWorks.forEach(function(w) { monthSum += Number(w.contract_value || 0); });
      chartData.push({ label: months[md.getMonth()], value: monthSum });
    }

    var body = '';

    // Hero stat — total contract value (Sber-style big number)
    // Page subtitle (like Sber "Актуально на 7 марта")
    var dateNow = new Date();
    var monthNames = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
    body += '<div class="m-page-subtitle">Актуально на ' + dateNow.getDate() + ' ' + monthNames[dateNow.getMonth()] + '</div>';

    body += M.mBigNumber({ value: money(totalContract), suffix: '', subtitle: money(margin) + ' · ' + marginPct + '%  Маржа' });

    // Mini chart + margin widget (Sber 2-column grid)
    body += M.mWidgetGrid([
      {
        title: 'Динамика контрактов',
        value: money(totalContract),
        icon: M.mMiniChart(chartData, { height: 50, barWidth: 10, barGap: 3, accentColor: 'var(--ok-t, #21bf73)' })
      },
      {
        title: 'Рентабельность',
        value: marginPct + '%',
        subtitle: 'от контрактов',
        icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--ok-t)" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>'
      }
    ]);



    // Sber-style full bar chart (like Sber analytics page)
    body += M.mBarChart(chartData, { height: 130, accentColor: 'var(--ok-t, #21bf73)', suffix: '' });

    // Sber-style quick action shortcuts
    body += M.mQuickActions([
      { label: 'Задачи', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>', onClick: "location.hash=\'#/tasks\'" },
      { label: 'Тендеры', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', onClick: "location.hash=\'#/tenders\'" },
      { label: 'Работы', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', onClick: "location.hash=\'#/pm-works\'" },
      { label: 'Счета', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>', onClick: "location.hash=\'#/invoices\'" },
      { label: 'Почта', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>', onClick: "location.hash=\'#/my-mail\'" },
      { label: 'Персонал', icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', onClick: "location.hash=\'#/personnel\'" }
    ]);

    // Quick filter pills (like Sber: По месяцам / По кварталам / По годам)
    body += M.mFilterPills([
      { label: 'Все', value: 'all' },
      { label: 'Активные', value: 'active' },
      { label: 'Выигранные', value: 'won' },
      { label: 'На согласов.', value: 'pending' }
    ], { id: 'dashFilter' });

    // Stats row
    body += M.mStats([
      { label: 'Тендеров', value: tenders.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/></svg>', color: 'var(--info)' },
      { label: 'Выиграно', value: won, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>', color: 'var(--ok-t)' },
      { label: 'Работ', value: active, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--gold)' },
      { label: 'Согласов.', value: pending, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', color: 'var(--warn)' }
    ]);

    // Collapsible sections (like Sber: Вклады и счета ^)
    body += M.mSection('Тендеры', M.mList(tenders.slice(0, 5), function(t) {
      return M.mCard({
        id: t.id, title: esc(t.customer_name || ''), subtitle: esc(t.tender_title || ''),
        badge: t.tender_status || '—', badgeColor: M.statusColor(t.tender_status),
        fields: [
          { label: 'Сумма', value: money(t.tender_price), mono: true }
        ], onClick: true
      });
    }), { collapsible: true, action: 'Все', actionHref: '#/tenders' });

    body += M.mSection('Активные работы', M.mList(works.filter(function(w) { return ['в работе','монтаж'].indexOf(norm(w.work_status)) !== -1; }).slice(0, 5), function(w) {
      return M.mCard({
        id: w.id, title: esc(w.customer_name || ''), subtitle: esc(w.work_title || ''),
        badge: w.work_status || '—', badgeColor: M.statusColor(w.work_status),
        fields: [
          { label: 'Контракт', value: money(w.contract_value), mono: true }
        ], onClick: true
      });
    }), { collapsible: true, action: 'Все', actionHref: '#/pm-works' });

    if (pending > 0) {
      body += M.mSection('На согласовании', M.mList(estimates.filter(function(e) { return e.approval_status === 'sent'; }).slice(0, 3), function(e) {
        return M.mCard({
          id: e.id, title: esc(e.project_name || e.work_title || ''), subtitle: esc(e.description || ''),
          badge: 'На согласовании', badgeColor: 'var(--warn)',
          fields: [
            { label: 'Сумма', value: money(e.amount || e.total), mono: true }
          ], onClick: true
        });
      }), { collapsible: true, action: 'Все', actionHref: '#/approvals' });
    }

    // Full-width button at bottom (like Sber "События за период")
    body += M.mFullWidthBtn('Все финансы за период', { href: '#/finances' });

    await layout(body, { title: title || 'Дашборд' });

    // Filter pills handler
    setTimeout(function() {
      var pillsEl = document.getElementById('dashFilter');
      if (pillsEl) {
        pillsEl.addEventListener('click', function(e) {
          var pill = e.target.closest('.m-filter-pill');
          if (!pill) return;
          pillsEl.querySelectorAll('.m-filter-pill').forEach(function(p) { p.classList.remove('active'); });
          pill.classList.add('active');
        });
      }
    }, 100);
  });

  /* Finances — Sber-style analytics */
  patchModule('AsgardFinancesPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var works = await AsgardDB.all('works') || [];
    var invoices = [];
    try { invoices = await AsgardDB.all('invoices') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
    var totalContract = 0, totalCost = 0, invoiceSum = 0, invoicePaid = 0;
    works.forEach(function(w) { totalContract += Number(w.contract_value || 0); totalCost += Number(w.cost_fact || w.cost_plan || 0); });
    invoices.forEach(function(i) { invoiceSum += Number(i.amount || 0); if (i.status === 'paid') invoicePaid += Number(i.amount || 0); });
    var margin = totalContract - totalCost;
    var marginPct = totalContract > 0 ? Math.round((margin / totalContract) * 100) : 0;

    // Monthly breakdown for chart
    var months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
    var now = new Date();
    var monthlyData = [];
    for (var mi = 5; mi >= 0; mi--) {
      var md = new Date(now.getFullYear(), now.getMonth() - mi, 1);
      var mSum = 0;
      works.forEach(function(w) {
        if (!w.created_at) return;
        var d = new Date(w.created_at);
        if (d.getMonth() === md.getMonth() && d.getFullYear() === md.getFullYear()) {
          mSum += Number(w.contract_value || 0);
        }
      });
      monthlyData.push({ label: months[md.getMonth()], value: mSum });
    }

    var body = '';

    // Hero — total contract value (Sber big number)
    body += M.mBigNumber({ value: money(totalContract), subtitle: money(margin) + ' · ' + marginPct + '%  Маржа' });

    // Sber-style pro bar chart with Y-axis and grid
    body += M.mBarChart(monthlyData, { height: 140, accentColor: 'var(--ok-t, #21bf73)', suffix: '' });

    // Filter pills
    body += M.mFilterPills([
      { label: 'По месяцам', value: 'month' },
      { label: 'По кварталам', value: 'quarter' },
      { label: 'По годам', value: 'year' }
    ], { id: 'finPeriod' });

    // Category breakdown (like Sber "Доходность по типам продуктов")
    body += M.mSectionPro({ title: 'Финансы по направлениям', subtitle: 'За текущий период', dropdown: { id: 'finType', options: [{ value: 'all', label: 'По направлениям' }, { value: 'pm', label: 'По РП' }, { value: 'status', label: 'По статусу' }] }, content:
      M.mCategoryItem({
        name: 'Контракты',
        amount: money(totalContract),
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
        iconBg: 'rgba(33, 191, 115, 0.15)',
        right: { value: money(totalContract), sub: '100%' }
      }) +
      M.mCategoryItem({
        name: 'Себестоимость',
        amount: money(totalCost),
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>',
        iconBg: 'rgba(88, 166, 255, 0.15)',
        right: { value: money(totalCost), sub: totalContract > 0 ? Math.round((totalCost / totalContract) * 100) + '%' : '0%' }
      }) +
      M.mCategoryItem({
        name: 'Маржа',
        amount: money(margin),
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
        iconBg: 'rgba(255, 193, 7, 0.15)',
        right: { value: money(margin), sub: marginPct + '%' }
      }) +
      M.mCategoryItem({
        name: 'Счета',
        amount: money(invoiceSum),
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>',
        iconBg: 'rgba(156, 120, 255, 0.15)',
        right: { value: money(invoiceSum), sub: invoices.length + ' шт' }
      })
    });

    // Collapsible: Works
    body += M.mSection('Работы', M.mList(works.slice(0, 5), function(w) {
      return M.mCard({
        id: w.id, title: esc(w.customer_name || ''), subtitle: esc(w.work_title || ''),
        badge: w.work_status || '—', badgeColor: M.statusColor(w.work_status),
        fields: [
          { label: 'Контракт', value: money(w.contract_value), mono: true },
          { label: 'Маржа', value: money(Number(w.contract_value || 0) - Number(w.cost_fact || w.cost_plan || 0)), mono: true }
        ], onClick: true
      });
    }), { collapsible: true, action: 'Все работы', actionHref: '#/pm-works' });

    // Full-width button
    body += M.mFullWidthBtn('Подробная аналитика', { href: '#/kpi-money' });

    await layout(body, { title: title || 'Финансы' });
  });

  /* KPI Works + KPI Money */
  ['AsgardKpiWorksPage', 'AsgardKpiMoneyPage'].forEach(function(name) {
    patchModule(name, async function({ layout, title }) {
      var auth = await AsgardAuth.requireUser();
      if (!auth) { location.hash = '#/login'; return; }
      var works = await AsgardDB.all('works') || [];
      var users = []; try { users = await AsgardDB.all('users') || []; } catch(e) { console.warn('[MobileRender]', e.message || e); }
      var byId = {}; users.forEach(function(u) { byId[u.id] = u; });

      // Group by PM
      var pmStats = {};
      works.forEach(function(w) {
        var pmId = w.pm_id || 'unknown';
        if (!pmStats[pmId]) pmStats[pmId] = { count: 0, contract: 0, cost: 0 };
        pmStats[pmId].count++;
        pmStats[pmId].contract += Number(w.contract_value || 0);
        pmStats[pmId].cost += Number(w.cost_fact || w.cost_plan || 0);
      });
      var pmList = Object.keys(pmStats).map(function(pmId) {
        var pm = byId[pmId] || {};
        var s = pmStats[pmId];
        return { pmId: pmId, name: pm.name || 'Неизвестен', count: s.count, contract: s.contract, cost: s.cost, margin: s.contract - s.cost };
      });
      pmList.sort(function(a, b) { return b.contract - a.contract; });

      var body = M.mTablePage({
        stats: [
          { label: 'Работ', value: works.length, icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>', color: 'var(--info)' },
          { label: 'РП', value: pmList.length, icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>', color: 'var(--gold)' }
        ],
        items: pmList,
        renderCard: function(pm) {
          return M.mCard({
            id: pm.id || pm.name,
            title: esc(pm.name),
            subtitle: pm.count + ' работ',
            fields: [
              { label: 'Контракты', value: money(pm.contract), mono: true },
              { label: 'Себестоим.', value: money(pm.cost), mono: true },
              { label: 'Маржа', value: money(pm.margin), mono: true },
              { label: 'Маржа %', value: pm.contract > 0 ? Math.round((pm.margin / pm.contract) * 100) + '%' : '—' }
            ]
          });
        }
      });
      await layout(body, { title: title || (name === 'AsgardKpiWorksPage' ? 'KPI Работ' : 'KPI Финансы') });
    });
  });

  /* HR Rating */
  patchModule('AsgardHrRatingPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var employees = await AsgardDB.all('employees') || [];
    var rated = employees.filter(function(e) { return e.rating_avg != null; });
    rated.sort(function(a, b) { return (b.rating_avg || 0) - (a.rating_avg || 0); });
    var avgRating = 0;
    if (rated.length > 0) {
      var sum = 0;
      rated.forEach(function(e) { sum += Number(e.rating_avg || 0); });
      avgRating = (sum / rated.length).toFixed(1);
    }

    var body = '';

    // Big number — average rating
    body += M.mBigNumber({ value: String(avgRating), suffix: '/ 5.0', subtitle: rated.length + ' сотрудников с оценкой' });

    // Mini chart — top 8 ratings
    var chartData = rated.slice(0, 8).map(function(e) {
      return { label: (e.fio || '').split(' ')[0], value: Math.round((Number(e.rating_avg || 0)) * 20) };
    });
    if (chartData.length > 0) {
      body += '<div class="m-chart-container">';
      body += M.mMiniChart(chartData, { height: 60, barWidth: 20, barGap: 6, accentColor: 'var(--gold)' });
      body += '<div class="m-chart-labels">';
      chartData.forEach(function(d) {
        body += '<span class="m-chart-label">' + esc(d.label) + '</span>';
      });
      body += '</div></div>';
    }

    // Filter pills
    body += M.mFilterPills([
      { label: 'Все', value: 'all' },
      { label: 'Топ-10', value: 'top10' },
      { label: 'Высокий', value: 'high' },
      { label: 'Низкий', value: 'low' }
    ], { id: 'ratingFilter' });

    // Leaderboard as category items (Sber-style)
    var topContent = '';
    rated.slice(0, 10).forEach(function(e, i) {
      var ratingVal = Number(e.rating_avg || 0).toFixed(1);
      var colors = ['rgba(255,193,7,0.2)', 'rgba(192,192,192,0.2)', 'rgba(205,127,50,0.2)', 'rgba(88,166,255,0.15)', 'rgba(156,120,255,0.15)'];
      topContent += M.mCategoryItem({
        name: (i + 1) + '. ' + (e.fio || '—'),
        amount: e.role_tag || '—',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
        iconBg: i < 5 ? colors[i] : 'rgba(255,255,255,0.08)',
        right: { value: ratingVal, sub: Number(ratingVal) >= 4 ? 'Отлично' : Number(ratingVal) >= 3 ? 'Хорошо' : 'Ниже нормы' }
      });
    });
    body += M.mSection('Лидерборд', topContent);

    // Full list (collapsible)
    body += M.mSection('Все сотрудники', M.mList(rated, function(e, i) {
      return M.mCard({
        id: e.id, title: (i + 1) + '. ' + esc(e.fio || ''),
        subtitle: esc(e.role_tag || ''),
        badge: Number(e.rating_avg).toFixed(1),
        badgeColor: Number(e.rating_avg) >= 4 ? 'ok' : Number(e.rating_avg) >= 3 ? 'warn' : 'err',
        fields: [
          { label: 'Город', value: esc(e.city || '—') },
          { label: 'Разряд', value: esc(e.grade || '—') }
        ]
      });
    }), { collapsible: true, collapsed: true, action: rated.length + ' чел.' });

    await layout(body, { title: title || 'Рейтинг Дружины' });
  });

  /* Birthdays */
  patchModule('AsgardBirthdaysPage', async function({ layout, title }) {
    var auth = await AsgardAuth.requireUser();
    if (!auth) { location.hash = '#/login'; return; }
    var employees = await AsgardDB.all('employees') || [];
    var today = new Date();
    var todayMD = String(today.getMonth() + 1).padStart(2, '0') + '-' + String(today.getDate()).padStart(2, '0');
    employees = employees.filter(function(e) { return e.birth_date; });
    employees.sort(function(a, b) {
      var amd = String(a.birth_date || '').slice(5);
      var bmd = String(b.birth_date || '').slice(5);
      return amd.localeCompare(bmd);
    });
    var body = M.mTablePage({
      bigNumber: M.mBigNumber({ value: String(items.length), label: 'Дни рождения', sub: '', icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/></svg>' }),

      toolbar: { search: { id: 'mSearch', placeholder: 'Поиск...' } },
      items: employees,
      renderCard: function(e) {
        var bd = String(e.birth_date || '').slice(5);
        var isToday = bd === todayMD;
        return M.mCard({
          id: e.id, title: esc(e.fio || ''),
          subtitle: esc(e.role_tag || ''),
          badge: isToday ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/></svg> Сегодня!' : fmtDate(e.birth_date),
          badgeColor: isToday ? 'gold' : 'draft',
          fields: [
            { label: 'Должность', value: esc(e.role_tag || '—') },
            { label: 'Город', value: esc(e.city || '—') }
          ]
        });
      }
    });
    await layout(body, { title: title || 'Дни рождения' });
  });

