# ═══════════════════════════════════════════════════════════════════════════
# ASGARD CRM — пример конфигурации окружения (.env.example)
# Скопируйте в .env и заполните значения. .env в git НЕ коммитится.
# ═══════════════════════════════════════════════════════════════════════════

# ─── База данных (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asgard_crm
DB_USER=asgard
DB_PASSWORD=

# ─── AI Provider ─────────────────────────────────────────────────────────────
# ВАЖНО: все альтернативные модели (Perplexity Sonar, Voyage embeddings,
# DeepSeek, GPT-5, Yandex и т.д.) вызываются ЧЕРЕЗ ЕДИНЫЙ ПРОКСИ routerai.ru
# (OpenAI-совместимый эндпоинт). Отдельные ключи PERPLEXITY_API_KEY /
# DEEPSEEK_API_KEY / VOYAGE_API_KEY НЕ НУЖНЫ — конкретная модель задаётся
# параметром `model` в теле запроса (см. src/services/mimir-conductor/models-config.js).
#
# OPENAI_API_KEY — единый ключ routerai.
#   - Conductor-режим Мимира в dev: если ключ начинается с 'stub-', расширения
#     ai-provider (searchWeb/embed/completeWithStream) работают в mock-режиме
#     и НЕ тратят баланс.
#   - Ключи также могут храниться в БД (settings.ai_config) и подхватываться
#     автоматически, когда переменные окружения пусты.
OPENAI_URL=https://routerai.ru/api/v1/chat/completions
OPENAI_API_KEY=
OPENAI_MODEL=anthropic/claude-sonnet-4.6

# ANTHROPIC_API_KEY — для ПРЯМЫХ вызовов Claude (api.anthropic.com), когда нужны
# фичи, которых нет в routerai (например, нативный streaming thinking-блоков).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# Yandex GPT (нормативный агент ГЭСН/ФЕР, сессия 6). Отдельный эндпоинт Yandex
# Cloud — НЕ через routerai. Через эту интеграцию могут идти и сторонние модели
# (в дефолте qwen3-235b-a22b-fp8/latest).
YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_GPT_MODEL=qwen3-235b-a22b-fp8/latest

# AI общие настройки
AI_PROVIDER=openai
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.3
AI_TIMEOUT_MS=600000

# (опционально) модель-исполнитель web search в agent loop
# WEB_SEARCH_MODEL=google/gemini-2.5-flash

# ─── JWT и Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=

# ─── Среда ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
