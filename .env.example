# ═══════════════════════════════════════════════════════════
# ASGARD CRM — Environment Variables
# Copy this file to .env and fill in actual values
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── Database (PostgreSQL) ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asgard_crm
DB_USER=asgard
DB_PASSWORD=          # REQUIRED — no default

# ── Authentication ──────────────────────────────────────
JWT_SECRET=           # REQUIRED — min 32 chars, e.g. openssl rand -hex 32
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=https://asgard-crm.ru

# ── File uploads ────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ── Rate limiting ───────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── SMTP (email sending) ───────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="АСГАРД CRM" <noreply@asgard-service.ru>

# ── IMAP (email receiving) ─────────────────────────────
IMAP_HOST=            # e.g. imap.yandex.ru, imap.mail.ru
IMAP_PORT=993
IMAP_USER=            # same as SMTP_USER if same mailbox
IMAP_PASS=            # same as SMTP_PASS if same mailbox
IMAP_TLS=true
IMAP_FOLDER=INBOX
MAIL_ENC_KEY=         # 32-char encryption key for stored IMAP credentials

# ── AI Provider ─────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.6

# ── DaData (customer INN lookup) ───────────────────────
DADATA_TOKEN=

# ── Telegram notifications ─────────────────────────────
TELEGRAM_BOT_TOKEN=
