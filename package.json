{
  "name": "asgard-crm-server",
  "version": "1.0.0",
  "description": "ASGARD CRM - Backend API Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node migrations/run.js",
    "migrate:down": "node migrations/run.js down",
    "seed": "node scripts/seed.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "node tests/e2e_test.js",
    "test:load": "node tests/load_test.js",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint src/ --ext .js && eslint public/assets/js/ --ext .js --config .eslintrc.frontend.json",
    "lint:fix": "eslint src/ --ext .js --fix && eslint public/assets/js/ --ext .js --config .eslintrc.frontend.json --fix"
  },
  "dependencies": {
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^4.25.0",
    "iconv-lite": "^0.7.2",
    "imapflow": "^1.2.9",
    "mailparser": "^3.9.3",
    "mammoth": "^1.8.0",
    "node-telegram-bot-api": "^0.64.0",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pino-pretty": "^13.1.3",
    "sanitize-html": "^2.17.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "puppeteer": "^24.36.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true,
    "setupFiles": [
      "./tests/helpers/env-setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 40,
        "lines": 40,
        "statements": 40
      }
    },
    "projects": [
      {
        "displayName": "unit",
        "testMatch": [
          "<rootDir>/tests/unit/**/*.test.js"
        ],
        "setupFiles": [
          "<rootDir>/tests/helpers/env-setup.js"
        ]
      },
      {
        "displayName": "integration",
        "testMatch": [
          "<rootDir>/tests/integration/**/*.test.js"
        ],
        "setupFiles": [
          "<rootDir>/tests/helpers/env-setup.js"
        ],
        "globalSetup": "<rootDir>/tests/helpers/global-setup.js",
        "globalTeardown": "<rootDir>/tests/helpers/global-teardown.js"
      }
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "ASGARD Team",
  "license": "PROPRIETARY"
}
