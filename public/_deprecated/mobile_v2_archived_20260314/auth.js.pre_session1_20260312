      ...DS.font('sm'), color: 'rgba(255,255,255,0.55)', margin: '0',
      letterSpacing: '3px', textTransform: 'uppercase',
      opacity: '0', transform: 'translateY(24px)',
      transition: 'all 0.7s ease 0.55s',
    });
    center.appendChild(sub);
