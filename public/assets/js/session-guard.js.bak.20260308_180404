  /* ═══════════════════════════════════════════ */
  /*  УТИЛИТЫ                                    */
  /* ═══════════════════════════════════════════ */
  function esc(s) {
    if (!s) return '';
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function isExemptPage() {
    var h = location.hash || '';
    for (var i = 0; i < EXEMPT_HASHES.length; i++) {
      if (h === EXEMPT_HASHES[i] || h.indexOf(EXEMPT_HASHES[i] + '?') === 0) return true;
    }
    return false;
  }

  function getQuotes() {
    /* Пытаемся взять из глобального LOADING_QUOTES (app.js) */
    if (window.ASGARD_LOADING_QUOTES && window.ASGARD_LOADING_QUOTES.length) {
      return window.ASGARD_LOADING_QUOTES;
    }
    return QUOTES;
  }

  function randomQuote() {
    var q = getQuotes();
    return q[Math.floor(Math.random() * q.length)];
  }

  function vibrate(ms) {
    try { if (navigator.vibrate) navigator.vibrate(ms); } catch(e) {}
  }

  function getLogoSrc() {
    /* Определяем путь к логотипу */
    var img = document.querySelector('.loading-logo img, .sidebar-logo img, .welcome-logo img');
    if (img && img.src) return img.src;
    return 'assets/img/logo.png';
  }

  /* Face ID SVG */
  function biometricSVG() {
    var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    if (isIOS) {
      /* Face ID icon */
      return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">' +
        '<path d="M7 2H4a2 2 0 0 0-2 2v3m18-5h-3m3 0v3m0 11v3a2 2 0 0 1-2 2h-3M2 17v3a2 2 0 0 0 2 2h3' +
        'M9 8v2m6-2v2m-3 1v3h-1m-2 2a5 5 0 0 0 8 0"/>' +
        '</svg>';
    }
    /* Fingerprint icon */
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M12 2a10 10 0 0 0-7.07 2.93M2 12a10 10 0 0 0 .93 4.24' +
      'M12 2a10 10 0 0 1 7.07 2.93M22 12a10 10 0 0 1-.93 4.24' +
      'M12 6a6 6 0 0 0-6 6c0 1.8.8 3.4 2 4.5M12 6a6 6 0 0 1 6 6c0 1.8-.8 3.4-2 4.5' +
      'M12 10a2 2 0 0 0-2 2c0 2.2 1 4 2 5.5M12 10a2 2 0 0 1 2 2c0 2.2-1 4-2 5.5"/>' +
      '</svg>';
  }

  function biometricLabel() {
    var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    if (isIOS) return 'Face ID';
    if (/Android/i.test(navigator.userAgent)) return 'Отпечаток';
    if (/Mac/i.test(navigator.platform)) return 'Touch ID';
    return 'Биометрия';
  }

  /* ═══════════════════════════════════════════ */
  /*  ТАЙМЕР НЕАКТИВНОСТИ                        */
  /* ═══════════════════════════════════════════ */
  function resetTimer() {
    if (_locked) return;
    if (isExemptPage()) return;
    clearTimeout(_timer);
    _timer = setTimeout(lock, IDLE_TIMEOUT);
  }

  function onActivity() {
    if (_locked) return;
    resetTimer();
  }

  function onMouseMove() {
    var now = Date.now();
    if (now - _lastMove < THROTTLE_MOVE) return;
    _lastMove = now;
    onActivity();
  }

  function onHashChange() {
    if (_locked) return;
    if (isExemptPage()) {
      /* На exempt странице — останавливаем таймер */
      clearTimeout(_timer);
    } else {
      resetTimer();
    }
  }

  var EVENTS = ['mousedown', 'keydown', 'scroll', 'touchstart', 'click'];

  function bindEvents() {
    for (var i = 0; i < EVENTS.length; i++) {
      window.addEventListener(EVENTS[i], onActivity, { passive: true });
    }
    window.addEventListener('mousemove', onMouseMove, { passive: true });
    window.addEventListener('hashchange', onHashChange);
  }

  function unbindEvents() {
    for (var i = 0; i < EVENTS.length; i++) {
      window.removeEventListener(EVENTS[i], onActivity);
    }
    window.removeEventListener('mousemove', onMouseMove);
    window.removeEventListener('hashchange', onHashChange);
  }


