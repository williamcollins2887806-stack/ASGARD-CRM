        '<div class="sg-logo"><img src="' + esc(logoSrc) + '" alt="ASGARD" onerror="this.style.display=\'none\'"/></div>' +
        '<div class="sg-user" id="sg-user"></div>' +
        '<div class="sg-dots" id="sg-dots">' +
          '<div class="sg-dot"></div><div class="sg-dot"></div><div class="sg-dot"></div><div class="sg-dot"></div>' +
        '</div>' +
        '<div class="sg-hint" id="sg-hint">Введите ПИН-код</div>' +
