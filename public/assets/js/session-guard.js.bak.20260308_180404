          '<div class="sg-key" data-digit="5">5</div>' +
          '<div class="sg-key" data-digit="6">6</div>' +
          '<div class="sg-key" data-digit="7">7</div>' +
          '<div class="sg-key" data-digit="8">8</div>' +
          '<div class="sg-key" data-digit="9">9</div>' +
          '<div class="sg-key action" data-action="delete" aria-label="Удалить">' +
            '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 18l6-6m-6 0l6 6M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' +
          '</div>' +
          '<div class="sg-key" data-digit="0">0</div>' +
          bioBtn +
        '</div>' +
        '<button class="sg-logout" id="sg-logout">Выйти из аккаунта</button>' +
      '</div>' +
      '<div class="sg-splash" id="sg-splash">' +
        '<div class="sg-splash-logo"><img src="' + esc(logoSrc) + '" alt="ASGARD" onerror="this.style.display=\'none\'"/></div>' +
        '<div class="sg-spinner">' +
          '<div class="sg-spinner-ring"></div>' +
          '<div class="sg-spinner-ring"></div>' +
          '<div class="sg-spinner-ring"></div>' +
        '</div>' +
        '<div class="sg-splash-quote" id="sg-splash-quote"></div>' +
        '<div class="sg-splash-runes">\u16A0\u16A2\u16A6\u16A8\u16B1\u16B2\u16B7\u16B9\u16BA\u16BE\u16C1\u16C3\u16C7\u16C8\u16C9\u16CA\u16CF\u16D2\u16D6\u16D7\u16DA\u16DC\u16DE\u16DF</div>' +
      '</div>';

    document.body.appendChild(el);
    _overlay = el;

    /* События клавиатуры */
    var keypad = el.querySelector('#sg-keypad');
    keypad.addEventListener('click', function(e) {
      var key = e.target.closest('.sg-key');
      if (!key || _checking) return;

      /* Ripple */
      var ripple = document.createElement('span');
      ripple.className = 'sg-ripple';
      var rect = key.getBoundingClientRect();
      var size = Math.max(rect.width, rect.height) * 2;
      ripple.style.width = ripple.style.height = size + 'px';
      ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
      ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
      key.appendChild(ripple);
      setTimeout(function(){ ripple.remove(); }, 500);

      var digit = key.getAttribute('data-digit');
      var action = key.getAttribute('data-action');

      if (digit !== null) {
        vibrate(15);
        addDigit(digit);
      } else if (action === 'delete') {
        vibrate(10);
        removeDigit();
      } else if (action === 'biometric') {
        vibrate(15);
        tryBiometric();
      }
    });

    /* Touchstart для предотвращения задержки на iOS */
    keypad.addEventListener('touchstart', function(e) {
      e.preventDefault();
      var touch = e.touches[0];
      var el = document.elementFromPoint(touch.clientX, touch.clientY);
      if (el) {
        var clickEvt = new MouseEvent('click', {
          bubbles: true,
          clientX: touch.clientX,
          clientY: touch.clientY
        });
        el.dispatchEvent(clickEvt);
      }
    }, { passive: false });

    /* Клавиатура (физическая) */
    el.addEventListener('keydown', function(e) {
      if (_checking) return;
      if (/^\d$/.test(e.key)) {
        vibrate(15);
        addDigit(e.key);
      } else if (e.key === 'Backspace') {
        vibrate(10);
        removeDigit();
      }
    });

    /* Выход */
    el.querySelector('#sg-logout').addEventListener('click', function() {
      doFullLogout();
    });

    return el;
  }


  /* ═══════════════════════════════════════════ */
  /*  ПИН ЛОГИКА                                 */
  /* ═══════════════════════════════════════════ */
  function updateDots() {
    if (!_overlay) return;
    var dots = _overlay.querySelectorAll('.sg-dot');
    for (var i = 0; i < dots.length; i++) {
      dots[i].className = 'sg-dot' + (i < _pinDigits.length ? ' filled' : '');
    }
  }

  function addDigit(d) {
    if (_pinDigits.length >= PIN_LENGTH) return;
    _pinDigits.push(d);
    updateDots();

    if (_pinDigits.length === PIN_LENGTH) {
      submitPin();
    }
  }

  function removeDigit() {
    if (_pinDigits.length === 0) return;
    _pinDigits.pop();
    updateDots();
  }

  function clearPin() {
    _pinDigits = [];
    updateDots();
  }

  function setHint(text, isError) {
    if (!_overlay) return;
    var hint = _overlay.querySelector('#sg-hint');
    hint.textContent = text;
    hint.className = 'sg-hint' + (isError ? ' error' : '');
  }

  function setDotsState(state) {
    if (!_overlay) return;
    var dots = _overlay.querySelectorAll('.sg-dot');
    for (var i = 0; i < dots.length; i++) {
      dots[i].className = 'sg-dot ' + state;
    }
  }

  async function submitPin() {
    if (_checking) return;
    _checking = true;

    var pin = _pinDigits.join('');

    try {
      var auth = AsgardAuth.getAuth();
      if (!auth || !auth.token) {
        doFullLogout();
        return;
      }

      var resp = await fetch('/api/auth/verify-pin', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + auth.token
        },
        body: JSON.stringify({ userId: _userId, pin: pin })
      });

      var data = await resp.json();

      if (!resp.ok) {
        _attempts++;
        vibrate(200);

        /* Анимация ошибки */
        setDotsState('error');
        var dotsEl = _overlay.querySelector('#sg-dots');
        dotsEl.classList.add('shake');

        var remaining = MAX_ATTEMPTS - _attempts;
        if (remaining <= 0) {
          setHint('Превышено число попыток', true);
          setTimeout(doFullLogout, 1000);
          return;
        }

        setHint(
          remaining <= 2
            ? 'Неверный ПИН. Осталось попыток: ' + remaining
            : 'Неверный ПИН-код',
          true
        );

        setTimeout(function() {
          dotsEl.classList.remove('shake');
          clearPin();
          _checking = false;
        }, 600);
        return;
      }

      /* Успех — обновляем токен */
      if (data.token) localStorage.setItem('asgard_token', data.token);
      if (data.user) {
        localStorage.setItem('asgard_user', JSON.stringify(data.user));
        if (data.user.permissions) localStorage.setItem('asgard_permissions', JSON.stringify(data.user.permissions));
        if (data.user.menu_settings) localStorage.setItem('asgard_menu_settings', JSON.stringify(data.user.menu_settings));
      }

      /* Анимация успеха → сплэш */
      setDotsState('success');
      vibrate(30);

      setTimeout(function() {
        showSplash();
      }, 400);

    } catch(e) {
      console.error('[SessionGuard] PIN error:', e);
      setHint('Ошибка соединения', true);
      setTimeout(function() {
        clearPin();
        _checking = false;
      }, 1000);
    }
  }

  async function tryBiometric() {
    if (_checking) return;
    if (!_biometricAvailable) return;
    if (!window.AsgardWebAuthn || !AsgardWebAuthn.loginWithBiometric) return;

    _checking = true;
    setHint('Ожидание биометрии...');

    try {
      await AsgardWebAuthn.loginWithBiometric(_userLogin);

      /* Успех */
      setDotsState('success');
      vibrate(30);
      setTimeout(showSplash, 400);

    } catch(e) {
      console.warn('[SessionGuard] Biometric failed:', e);
      setHint('Биометрия не удалась. Введите ПИН', true);
      _checking = false;
    }
  }


  /* ═══════════════════════════════════════════ */
  /*  СПЛЭШ ЭКРАН                               */
  /* ═══════════════════════════════════════════ */
  function showSplash() {
    if (!_overlay) return;

    /* Скрываем клавиатуру */
    var center = _overlay.querySelector('.sg-center');
    center.style.transition = 'opacity .3s ease';
    center.style.opacity = '0';

    var splash = _overlay.querySelector('#sg-splash');
    splash.querySelector('#sg-splash-quote').textContent = randomQuote();

    setTimeout(function() {
      center.style.display = 'none';
      splash.classList.add('visible');
    }, 300);

    setTimeout(function() {
      unlock();
    }, SPLASH_DURATION);
  }


  /* ═══════════════════════════════════════════ */
  /*  LOCK / UNLOCK                              */
  /* ═══════════════════════════════════════════ */
  function lock() {
    if (_locked) return;
    if (isExemptPage()) return;

    /* Проверяем что пользователь залогинен */
    var auth = AsgardAuth.getAuth();
    if (!auth || !auth.user) return;

    _locked = true;
    _pinDigits = [];
    _attempts = 0;
    _checking = false;
    _userId = auth.user.id;
    _userName = auth.user.name || auth.user.login || '';
    _userLogin = auth.user.login || localStorage.getItem('asgard_last_login') || '';

    injectStyles();

    /* Проверяем биометрию */
    checkBiometric(function() {
      var overlay = buildOverlay();

      /* Обновляем имя */
      overlay.querySelector('#sg-user').textContent = _userName;

      /* Сбрасываем состояние */
      clearPin();
      setHint('Введите ПИН-код');

      /* Показываем центр, скрываем сплэш */
      var center = overlay.querySelector('.sg-center');
      center.style.display = '';
      center.style.opacity = '1';
      overlay.querySelector('#sg-splash').classList.remove('visible');

      /* Появление */
      overlay.style.display = 'flex';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          overlay.classList.add('visible');
        });
      });

      /* Фокус для клавиатуры */
      overlay.setAttribute('tabindex', '-1');
      overlay.focus();

      /* Автоматически предложить биометрию */
      if (_biometricAvailable) {
        setTimeout(function() {
          tryBiometric();
        }, 500);
      }
    });
  }

  function unlock() {
    if (!_locked) return;
    _locked = false;
    _checking = false;
    _pinDigits = [];
    _attempts = 0;

    /* Скрываем оверлей */
    if (_overlay) {
      _overlay.classList.remove('visible');
      setTimeout(function() {
        _overlay.style.display = 'none';
        /* Сбрасываем сплэш */
        var splash = _overlay.querySelector('#sg-splash');
        if (splash) splash.classList.remove('visible');
        var center = _overlay.querySelector('.sg-center');
        if (center) {
          center.style.display = '';
          center.style.opacity = '1';
        }
      }, 400);
    }

    /* Перезапускаем таймер */
    resetTimer();

    /* Обновляем кэш auth (токен мог измениться) */
    if (window.AsgardAuth && AsgardAuth.requireUser) {
      AsgardAuth.requireUser();
    }
  }

  function doFullLogout() {
    _locked = false;
    _checking = false;
    destroy();
    if (window.AsgardAuth && AsgardAuth.logout) {
      AsgardAuth.logout();
    }
    if (window.AsgardUI && AsgardUI.toast) {
      AsgardUI.toast('Сессия', 'Сессия завершена', 'info');
    }
    location.hash = '#/welcome';
  }


  /* ═══════════════════════════════════════════ */
  /*  БИОМЕТРИЯ                                  */
  /* ═══════════════════════════════════════════ */
  function checkBiometric(cb) {
    _biometricAvailable = false;

    if (!window.AsgardWebAuthn || !AsgardWebAuthn.isSupported) {
      cb();
      return;
    }

    try {
      var result = AsgardWebAuthn.isSupported();
      if (result && typeof result.then === 'function') {
        result.then(function(supported) {
          _biometricAvailable = !!supported;
          cb();
        }).catch(function() { cb(); });
      } else {
        _biometricAvailable = !!result;
        cb();
      }
    } catch(e) {
      cb();
    }
  }


  /* ═══════════════════════════════════════════ */
  /*  ПУБЛИЧНЫЙ API                              */
  /* ═══════════════════════════════════════════ */
  function init() {
    if (_initialized) return;

    /* Проверяем что есть залогиненный пользователь */
    var auth = AsgardAuth.getAuth();
    if (!auth || !auth.user) return;

    /* Проверяем что у пользователя есть ПИН (иначе нечем блокировать) */
    var user = auth.user;
    if (user.has_pin === false) {
      /* У пользователя явно нет ПИН-кода — guard не активируем */
      return;
    }

    _initialized = true;
    _userId = user.id;
    _userName = user.name || user.login || '';
    _userLogin = user.login || '';

    injectStyles();
    bindEvents();
    resetTimer();

    console.log('[SessionGuard] Initialized, timeout: ' + (IDLE_TIMEOUT / 60000) + ' min');
  }

  function destroy() {
    _initialized = false;
    _locked = false;
    _checking = false;
    clearTimeout(_timer);
    unbindEvents();

    if (_overlay) {
      _overlay.remove();
      _overlay = null;
    }
  }


  /* ═══════════════════════════════════════════ */
  /*  ЭКСПОРТ (виртуальная клавиатура для auth)  */
  /* ═══════════════════════════════════════════ */
  /**
   * Создаёт виртуальную ПИН-клавиатуру для встраивания в любой контейнер
   * @param {HTMLElement} container — куда вставить
   * @param {Object} opts — { onComplete(pin), onBiometric(), showBiometric, theme }
   * @returns {{ clear(), destroy() }}
   */
  function createPinKeypad(container, opts) {
    opts = opts || {};
    var digits = [];
    var checking = false;
    var bioAvailable = opts.showBiometric || false;

    injectStyles();

    var bioBtn = bioAvailable
      ? '<div class="sg-key biometric" data-action="biometric" role="button">' + biometricSVG() + '</div>'
      : '<div class="sg-key action" style="visibility:hidden"></div>';

    var html =
      '<div class="sg-dots" id="pk-dots" style="margin-bottom:12px">' +
        '<div class="sg-dot"></div><div class="sg-dot"></div><div class="sg-dot"></div><div class="sg-dot"></div>' +
      '</div>' +
      '<div class="sg-hint" id="pk-hint" style="margin-bottom:8px">Введите ПИН-код</div>' +
      '<div class="sg-keypad" id="pk-keypad">' +
        '<div class="sg-key" data-digit="1">1</div>' +
        '<div class="sg-key" data-digit="2">2</div>' +
        '<div class="sg-key" data-digit="3">3</div>' +
        '<div class="sg-key" data-digit="4">4</div>' +
        '<div class="sg-key" data-digit="5">5</div>' +
        '<div class="sg-key" data-digit="6">6</div>' +
        '<div class="sg-key" data-digit="7">7</div>' +
        '<div class="sg-key" data-digit="8">8</div>' +
        '<div class="sg-key" data-digit="9">9</div>' +
        '<div class="sg-key action" data-action="delete">' +
          '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 18l6-6m-6 0l6 6M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' +
        '</div>' +
        '<div class="sg-key" data-digit="0">0</div>' +
        bioBtn +
      '</div>';

    container.innerHTML = html;

    var dotsEl = container.querySelector('#pk-dots');
    var hintEl = container.querySelector('#pk-hint');
    var keypad = container.querySelector('#pk-keypad');

    function updDots() {
      var dots = dotsEl.querySelectorAll('.sg-dot');
      for (var i = 0; i < dots.length; i++) {
        dots[i].className = 'sg-dot' + (i < digits.length ? ' filled' : '');
      }
    }

    function setDotsClass(cls) {
      var dots = dotsEl.querySelectorAll('.sg-dot');
      for (var i = 0; i < dots.length; i++) {
        dots[i].className = 'sg-dot ' + cls;
      }
    }

    keypad.addEventListener('click', function(e) {
      var key = e.target.closest('.sg-key');
      if (!key || checking) return;

      var digit = key.getAttribute('data-digit');
      var action = key.getAttribute('data-action');

      if (digit !== null) {
        vibrate(15);
        if (digits.length < PIN_LENGTH) {
          digits.push(digit);
          updDots();
          if (digits.length === PIN_LENGTH && opts.onComplete) {
            checking = true;
            opts.onComplete(digits.join(''), {
              success: function() {
                setDotsClass('success');
                checking = false;
              },
              error: function(msg) {
                vibrate(200);
                setDotsClass('error');
                dotsEl.classList.add('shake');
                hintEl.textContent = msg || 'Неверный ПИН';
                hintEl.className = 'sg-hint error';
                setTimeout(function() {
                  dotsEl.classList.remove('shake');
                  digits = [];
                  updDots();
                  checking = false;
                }, 600);
              }
            });
          }
        }
      } else if (action === 'delete') {
        vibrate(10);
        digits.pop();
        updDots();
      } else if (action === 'biometric' && opts.onBiometric) {
        vibrate(15);
        opts.onBiometric();
      }
    });

    keypad.addEventListener('touchstart', function(e) {
      e.preventDefault();
      var touch = e.touches[0];
      var el = document.elementFromPoint(touch.clientX, touch.clientY);
      if (el) el.dispatchEvent(new MouseEvent('click', { bubbles: true, clientX: touch.clientX, clientY: touch.clientY }));
    }, { passive: false });

    return {
      clear: function() {
        digits = [];
        updDots();
        hintEl.textContent = 'Введите ПИН-код';
        hintEl.className = 'sg-hint';
        checking = false;
      },
      setHint: function(text, isErr) {
        hintEl.textContent = text;
        hintEl.className = 'sg-hint' + (isErr ? ' error' : '');
      },
      destroy: function() {
        container.innerHTML = '';
      }
    };
  }


  /* ═══════════════════════════════════════════ */
  /*  ПУБЛИЧНЫЙ ЭКСПОРТ                          */
  /* ═══════════════════════════════════════════ */
  window.AsgardSessionGuard = {
    init: init,
    reset: resetTimer,
    lock: lock,
    unlock: unlock,
    isLocked: function() { return _locked; },
    destroy: destroy,
    createPinKeypad: createPinKeypad
  };

})();
