  fastify.get('/routing', {
    preHandler: [fastify.authenticate]
  }, async (request, reply) => {
    const rules = await db.query(
      'SELECT r.*, u.name as created_by_name FROM call_routing_rules r LEFT JOIN users u ON u.id = r.created_by ORDER BY r.priority DESC, r.id'
    );
